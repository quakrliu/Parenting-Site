---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Page Not Found | BloomPath" description="The page you're looking for doesn't exist." lang="en">
  <Header lang="en" />
  <main class="not-found">
    <div class="container">
      <div class="not-found__inner">
        <span class="not-found__code">404</span>
        <h1>Page Not Found</h1>
        <p>The page you're looking for doesn't exist or has been moved.</p>
        <div class="not-found__actions">
          <a href="/en/" class="btn btn--primary">Go to Homepage (EN)</a>
          <a href="/zh/" class="btn btn--ghost">返回首頁 (ZH)</a>
        </div>
      </div>
    </div>
  </main>
  <Footer lang="en" />
</BaseLayout>

<style>
  .not-found {
    min-height: 60vh;
    display: flex;
    align-items: center;
    padding: 6rem 0;
  }

  .not-found__inner {
    text-align: center;
    max-width: 480px;
    margin: 0 auto;
  }

  .not-found__code {
    display: block;
    font-size: 6rem;
    font-weight: 800;
    letter-spacing: -0.05em;
    color: var(--color-forest);
    opacity: 0.3;
    line-height: 1;
    margin-bottom: 1rem;
  }

  .not-found__inner h1 {
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 0.75rem;
  }

  .not-found__inner p {
    color: var(--color-text-light);
    font-size: 1rem;
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .not-found__actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
