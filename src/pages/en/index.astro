---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import AlertBanner from '../../components/AlertBanner.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';
import { useTranslations } from '../../i18n/utils';

const lang = 'en';
const t = useTranslations(lang);

const allPosts = await getCollection('blog');
const now = new Date();
const publishedPosts = allPosts
  .filter((post) => post.data.pubDate <= now && post.data.lang === 'en')
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const featuredPosts = publishedPosts.slice(0, 6);

const ageStages = [
  { key: 'infant', img: '/images/age-newborn.jpg', color: 'forest' },
  { key: 'toddler', img: '/images/age-toddler.jpg', color: 'orange' },
  { key: 'preschool', img: '/images/age-preschool.jpg', color: 'pink' },
  { key: 'school', img: '/images/age-explorer.jpg', color: 'forest' },
  { key: 'teen', img: '/images/age-talker.jpg', color: 'orange' },
];

const stats = [
  { value: '224+', label: t('stats.indicators') },
  { value: '8', label: t('stats.domains') },
  { value: '0-18', label: t('stats.years') },
];
---

<BaseLayout title={`${t('site.title')} | ${t('site.tagline')}`} description={t('site.description')} lang={lang}>
  <Header lang={lang} />
  <AlertBanner lang={lang} />

  <!-- HERO: Full-width asymmetric split with background imagery -->
  <section class="hero">
    <div class="hero__bg" aria-hidden="true">
      <img
        src="/images/hero-family.jpg"
        alt=""
        width="1920"
        height="1080"
        loading="eager"
        class="hero__bg-img"
      />
      <div class="hero__bg-overlay"></div>
    </div>
    <div class="container hero__grid">
      <div class="hero__content">
        <h1>The science of growing up, simplified.</h1>
        <p class="hero__desc">{t('hero.desc')}</p>
        <div class="hero__actions">
          <a href={`/${lang}/blog`} class="btn btn--primary btn--lg">
            {t('hero.cta.articles')}
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
        <div class="hero__trust">
          <span class="hero__trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            {t('hero.trust.evidence')}
          </span>
          <span class="hero__trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            {t('hero.trust.parents')}
          </span>
          <span class="hero__trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            {t('hero.trust.free')}
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- AGE NAVIGATOR: Horizontal card grid -->
  <section class="age-nav">
    <div class="container">
      <div class="section-header section-header--center">
        <span class="eyebrow">{t('age.section')}</span>
        <h2>{t('age.section.title')}</h2>
        <p class="section-desc section-desc--center">{t('age.section.desc')}</p>
      </div>
      <div class="age-nav__grid">
        {ageStages.map((stage) => (
          <a href={`/${lang}/blog`} class={`age-nav__card age-nav__card--${stage.color}`}>
            <div class="age-nav__img-wrap">
              <img
                src={stage.img}
                alt={t(`age.${stage.key}` as any)}
                width="480"
                height="560"
                loading="lazy"
                class="age-nav__img"
              />
            </div>
            <div class="age-nav__label">
              <span class="age-nav__name">{t(`age.${stage.key}` as any)}</span>
              <span class="age-nav__range">{t(`age.${stage.key}.range` as any)}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- TWO PILLARS: Montessori + Positive Parenting with imagery -->
  <section class="pillars">
    <div class="container">
      <div class="section-header section-header--center">
        <span class="eyebrow">{t('section.philosophy')}</span>
        <h2>{t('section.philosophy.title')}</h2>
        <p class="section-desc section-desc--center">{t('section.philosophy.desc')}</p>
      </div>
      <div class="pillars__grid">
        <div class="pillars__card">
          <div class="pillars__img-wrap">
            <img
              src="/images/montessori-play.jpg"
              alt="Child exploring Montessori materials"
              width="800"
              height="600"
              loading="lazy"
              class="pillars__img"
            />
          </div>
          <div class="pillars__body">
            <div class="pillars__icon pillars__icon--forest">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>
              </svg>
            </div>
            <h3>{t('philosophy.montessori.title')}</h3>
            <p>{t('philosophy.montessori.desc')}</p>
            <ul class="pillars__points">
              <li>{t('philosophy.montessori.point1')}</li>
              <li>{t('philosophy.montessori.point2')}</li>
              <li>{t('philosophy.montessori.point3')}</li>
            </ul>
          </div>
        </div>
        <div class="pillars__card">
          <div class="pillars__img-wrap">
            <img
              src="/images/parent-reading.jpg"
              alt="Parent and child sharing a warm moment"
              width="800"
              height="600"
              loading="lazy"
              class="pillars__img"
            />
          </div>
          <div class="pillars__body">
            <div class="pillars__icon pillars__icon--orange">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
              </svg>
            </div>
            <h3>{t('philosophy.positive.title')}</h3>
            <p>{t('philosophy.positive.desc')}</p>
            <ul class="pillars__points">
              <li>{t('philosophy.positive.point1')}</li>
              <li>{t('philosophy.positive.point2')}</li>
              <li>{t('philosophy.positive.point3')}</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- STATS BAR: Full-width accent strip -->
  <section class="stats-bar">
    <div class="container">
      <div class="stats-bar__grid">
        {stats.map((stat) => (
          <div class="stats-bar__item">
            <span class="stats-bar__value">{stat.value}</span>
            <span class="stats-bar__label">{stat.label}</span>
          </div>
        ))}
        <div class="stats-bar__item stats-bar__item--badge">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <span class="stats-bar__label">{t('stats.research')}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- DAILY STICKINESS: Dynamic daily-changing features -->
  <section class="daily">
    <div class="container">
      <div class="section-header section-header--center">
        <span class="eyebrow">{t('daily.section')}</span>
        <h2>{t('daily.section.title')}</h2>
        <p class="section-desc section-desc--center">{t('daily.section.desc')}</p>
      </div>
      <div class="daily__grid">
        <!-- Today's Growth Activity -->
        <div class="daily__card daily__card--task">
          <div class="daily__card-header">
            <div class="daily__icon daily__icon--forest">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <span class="daily__badge">{t('daily.task.time')}</span>
          </div>
          <h3>{t('daily.task.title')}</h3>
          <p id="daily-task-text" class="daily__body">Loading...</p>
          <div id="daily-task-age" class="daily__tag"></div>
        </div>

        <!-- Weekly Focus -->
        <div class="daily__card daily__card--focus">
          <div class="daily__card-header">
            <div class="daily__icon daily__icon--orange">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
            </div>
          </div>
          <h3>{t('daily.focus.title')}</h3>
          <p id="weekly-focus-text" class="daily__body">Loading...</p>
          <div id="weekly-focus-age" class="daily__tag"></div>
        </div>

        <!-- Daily Quote -->
        <div class="daily__card daily__card--quote">
          <div class="daily__card-header">
            <div class="daily__icon daily__icon--pink">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V21z"/><path d="M15 21c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2h.75c0 2.25.25 4-2.75 4v3c0 1 0 1 1 1z"/></svg>
            </div>
            <button id="quote-copy-btn" class="daily__copy-btn" aria-label="Copy quote">{t('daily.quote.btn')}</button>
          </div>
          <h3>{t('daily.quote.title')}</h3>
          <blockquote id="daily-quote-text" class="daily__quote">Loading...</blockquote>
          <cite id="daily-quote-author" class="daily__cite"></cite>
        </div>

        <!-- Is This Normal? -->
        <div class="daily__card daily__card--normal">
          <div class="daily__card-header">
            <div class="daily__icon daily__icon--forest">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            </div>
          </div>
          <h3>{t('daily.normal.title')}</h3>
          <p class="daily__body-sm">{t('daily.normal.desc')}</p>
          <div class="daily__form">
            <select id="normal-age" class="daily__select" aria-label={t('daily.normal.select.age')}>
              <option value="">{t('daily.normal.select.age')}</option>
              <option value="infant">0-1</option>
              <option value="toddler">1-3</option>
              <option value="preschool">3-6</option>
              <option value="school">6-12</option>
              <option value="teen">12-18</option>
            </select>
            <select id="normal-behavior" class="daily__select" aria-label={t('daily.normal.select.behavior')}>
              <option value="">{t('daily.normal.select.behavior')}</option>
            </select>
            <button id="normal-check-btn" class="btn btn--primary btn--sm">{t('daily.normal.check')}</button>
          </div>
          <div id="normal-result" class="daily__result"></div>
          <p class="daily__disclaimer">{t('daily.normal.disclaimer')}</p>
        </div>

        <!-- Parenting Journal -->
        <div class="daily__card daily__card--journal">
          <div class="daily__card-header">
            <div class="daily__icon daily__icon--orange">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
            </div>
            <div id="journal-streak" class="daily__streak"></div>
          </div>
          <h3>{t('daily.journal.title')}</h3>
          <textarea id="journal-input" class="daily__textarea" placeholder={t('daily.journal.prompt')} rows="3"></textarea>
          <button id="journal-save-btn" class="btn btn--primary btn--sm">{t('daily.journal.save')}</button>
          <div id="journal-saved" class="daily__saved"></div>
        </div>
      </div>
    </div>
  </section>

  <script>
    (function() {
      const today = new Date();
      const dayOfYear = Math.floor((today.getTime() - new Date(today.getFullYear(), 0, 0).getTime()) / 86400000);
      const weekOfYear = Math.floor(dayOfYear / 7);

      // === TODAY'S GROWTH ACTIVITY ===
      const activities = [
        { text: 'Build a blanket fort together and read a story inside it. Let your child choose the book and lead the setup.', age: 'Preschool (3-6)' },
        { text: 'Play "I Spy" using only colors during a walk. Great for vocabulary and observation skills.', age: 'Toddler (1-3)' },
        { text: 'Let your baby explore different textures: silk, wool, sandpaper, a cool spoon. Narrate what they feel.', age: 'Infant (0-1)' },
        { text: 'Ask your school-age child to teach you something they learned this week. Reversal of roles builds confidence.', age: 'School Age (6-12)' },
        { text: 'Cook a simple meal together. Measuring ingredients teaches math; following steps teaches sequencing.', age: 'Preschool (3-6)' },
        { text: 'Have a "feelings check-in" at dinner: everyone shares one high and one low from their day.', age: 'All Ages' },
        { text: 'Create a nature journal: go outside for 10 minutes and sketch or describe three things you notice.', age: 'School Age (6-12)' },
        { text: 'Practice pouring water between two cups. Start with a small pitcher for little hands.', age: 'Toddler (1-3)' },
        { text: 'Ask your teen: "What is something you wish adults understood better?" Then just listen.', age: 'Adolescent (12-18)' },
        { text: 'Do tummy time with your baby while lying face-to-face. Sing a simple song and watch them respond.', age: 'Infant (0-1)' },
        { text: 'Challenge your child to sort laundry by color. Practical life skill + pattern recognition.', age: 'Preschool (3-6)' },
        { text: 'Write a short note to your teen and leave it in their backpack. Simple, no strings attached.', age: 'Adolescent (12-18)' },
        { text: 'Play "grocery store" with real items from the pantry. Practice counting and making change.', age: 'School Age (6-12)' },
        { text: 'Dance party. Put on music and move together for 5 minutes. No rules, just movement.', age: 'All Ages' },
      ];
      const todayActivity = activities[dayOfYear % activities.length];
      const taskEl = document.getElementById('daily-task-text');
      const taskAgeEl = document.getElementById('daily-task-age');
      if (taskEl) taskEl.textContent = todayActivity.text;
      if (taskAgeEl) taskAgeEl.textContent = todayActivity.age;

      // === WEEKLY FOCUS ===
      const weeklyFocuses = [
        { text: 'Emotional Vocabulary: Help your child name their feelings this week. "You seem frustrated" is more powerful than "Stop crying."', age: 'All Ages' },
        { text: 'Independence Practice: Let your child do one thing themselves that you normally do for them. Button a shirt, pour their own drink, walk to school.', age: 'Toddler - School Age' },
        { text: 'Screen-Free Connection: Spend 15 uninterrupted minutes with your child each day this week. No phones, no agenda.', age: 'All Ages' },
        { text: 'Routine Building: Create a visual schedule for morning or bedtime. Let your child help design it.', age: 'Preschool (3-6)' },
        { text: 'Gratitude Practice: At dinner, each family member shares one thing they are grateful for today.', age: 'School Age - Adolescent' },
        { text: 'Sensory Exploration: Offer your baby one new sensory experience each day: music, texture, scent, taste, movement.', age: 'Infant (0-1)' },
        { text: 'Active Listening Week: When your teen talks, pause before responding. Repeat back what you heard before offering your thoughts.', age: 'Adolescent (12-18)' },
        { text: 'Movement & Coordination: Set up a simple obstacle course indoors or outdoors. Crawl, jump, balance.', age: 'Toddler - Preschool' },
      ];
      const thisWeekFocus = weeklyFocuses[weekOfYear % weeklyFocuses.length];
      const focusEl = document.getElementById('weekly-focus-text');
      const focusAgeEl = document.getElementById('weekly-focus-age');
      if (focusEl) focusEl.textContent = thisWeekFocus.text;
      if (focusAgeEl) focusAgeEl.textContent = thisWeekFocus.age;

      // === DAILY QUOTE ===
      const quotes = [
        { text: 'The child is both a hope and a promise for mankind.', author: 'Maria Montessori' },
        { text: 'Children are not things to be molded, but people to be unfolded.', author: 'Jess Lair' },
        { text: 'Connection is the energy that is created between people when they feel seen, heard, and valued.', author: 'Brene Brown' },
        { text: 'Play is the highest form of research.', author: 'Albert Einstein' },
        { text: 'The greatest gifts we can give our children are the roots of responsibility and the wings of independence.', author: 'Maria Montessori' },
        { text: 'When little people are overwhelmed by big emotions, it is our job to share our calm, not join their chaos.', author: 'L.R. Knost' },
        { text: 'Every child deserves a champion: an adult who will never give up on them.', author: 'Rita Pierson' },
        { text: 'Do not train a child to learn by force or harshness; direct them to it by what amuses their minds.', author: 'Plato' },
        { text: 'Behind every young child who believes in themselves is a parent who believed first.', author: 'Matthew Jacobson' },
        { text: 'The way we talk to our children becomes their inner voice.', author: 'Peggy O\'Mara' },
        { text: 'It is easier to build strong children than to repair broken adults.', author: 'Frederick Douglass' },
        { text: 'Children need at least one person in their life who thinks the sun rises and sets on them.', author: 'Pamela Leo' },
        { text: 'The child who concentrates is immensely happy.', author: 'Maria Montessori' },
        { text: 'Your children need your presence more than your presents.', author: 'Jesse Jackson' },
      ];
      const todayQuote = quotes[dayOfYear % quotes.length];
      const quoteEl = document.getElementById('daily-quote-text');
      const authorEl = document.getElementById('daily-quote-author');
      if (quoteEl) quoteEl.textContent = '"' + todayQuote.text + '"';
      if (authorEl) authorEl.textContent = '-- ' + todayQuote.author;

      const copyBtn = document.getElementById('quote-copy-btn');
      if (copyBtn) {
        copyBtn.addEventListener('click', function() {
          navigator.clipboard.writeText(todayQuote.text + ' -- ' + todayQuote.author).then(function() {
            copyBtn.textContent = copyBtn.dataset.copied || 'Copied!';
            setTimeout(function() { copyBtn.textContent = copyBtn.dataset.label || 'Copy'; }, 2000);
          });
        });
        copyBtn.dataset.copied = copyBtn.textContent === 'Copy' ? 'Copied!' : copyBtn.textContent;
        copyBtn.dataset.label = copyBtn.textContent;
      }

      // === IS THIS NORMAL? ===
      var behaviorsByAge = {
        infant: [
          { label: 'Not smiling yet', value: 'no-smile' },
          { label: 'Startles at loud sounds', value: 'startle' },
          { label: 'Cries a lot', value: 'cries' },
          { label: 'Not rolling over', value: 'no-roll' },
        ],
        toddler: [
          { label: 'Biting other children', value: 'biting' },
          { label: 'Not talking yet', value: 'no-talk' },
          { label: 'Frequent tantrums', value: 'tantrums' },
          { label: 'Picky eating', value: 'picky-eat' },
        ],
        preschool: [
          { label: 'Imaginary friends', value: 'imaginary' },
          { label: 'Refusing to share', value: 'no-share' },
          { label: 'Bedwetting', value: 'bedwet' },
          { label: 'Asks "why" constantly', value: 'why' },
        ],
        school: [
          { label: 'Struggles with reading', value: 'read-struggle' },
          { label: 'Doesn\'t want to go to school', value: 'school-avoid' },
          { label: 'Frequent stomach aches', value: 'stomach' },
          { label: 'Trouble making friends', value: 'friend-trouble' },
        ],
        teen: [
          { label: 'Stays in room all day', value: 'isolation' },
          { label: 'Mood swings', value: 'moods' },
          { label: 'Talks back constantly', value: 'talks-back' },
          { label: 'Sleeps too much', value: 'oversleep' },
        ],
      };

      var normalAnswers = {
        'infant-no-smile': { status: 'watch', text: 'Most babies smile by 2 months. If no social smile by 3 months, mention it to your pediatrician at the next visit.' },
        'infant-startle': { status: 'normal', text: 'Completely normal. The Moro reflex is present at birth and usually fades by 4-6 months.' },
        'infant-cries': { status: 'normal', text: 'Newborns cry 1-3 hours per day on average. Peaks around 6-8 weeks, then decreases. If inconsolable for hours, consult your pediatrician.' },
        'infant-no-roll': { status: 'watch', text: 'Most babies roll by 4-6 months. Offer plenty of tummy time. If no rolling by 7 months, consult your pediatrician.' },
        'toddler-biting': { status: 'normal', text: 'Very common between 1-3 years. They lack words for frustration. Stay calm, say "No biting," and redirect. Usually resolves by age 3.' },
        'toddler-no-talk': { status: 'watch', text: 'By 18 months, most toddlers say at least a few words. By 2, they combine two words. If concerned, ask about early intervention screening.' },
        'toddler-tantrums': { status: 'normal', text: 'Peak tantrum age is 18 months to 3 years. Their emotional brain is developing faster than their ability to regulate. Stay calm and present.' },
        'toddler-picky-eat': { status: 'normal', text: 'Food neophobia is developmentally normal from ages 2-6. Keep offering variety without pressure. It can take 15-20 exposures before acceptance.' },
        'preschool-imaginary': { status: 'normal', text: 'Imaginary friends are a sign of healthy creativity and social development. About 65% of children have them at some point. No cause for concern.' },
        'preschool-no-share': { status: 'normal', text: 'True sharing develops around age 4-5. Before that, children are still developing theory of mind. Model sharing and take turns, but don\'t force it.' },
        'preschool-bedwet': { status: 'normal', text: 'Nighttime bladder control develops between ages 4-7. About 15% of 5-year-olds still wet the bed. It\'s usually not a concern until after age 7.' },
        'preschool-why': { status: 'normal', text: 'A beautiful sign of cognitive development. They are building their understanding of cause and effect. Engage when you can, and it\'s okay to say "What do you think?"' },
        'school-read-struggle': { status: 'watch', text: 'Reading ability varies widely in early grades. If struggling significantly by age 7-8, consider screening for dyslexia or learning differences. Early support helps enormously.' },
        'school-school-avoid': { status: 'watch', text: 'Occasional reluctance is normal. Persistent avoidance (especially with physical complaints) may signal anxiety, bullying, or learning difficulties. Talk to the school counselor.' },
        'school-stomach': { status: 'watch', text: 'Recurring stomachaches without medical cause are often linked to anxiety. If happening before school regularly, explore what might be causing stress.' },
        'school-friend-trouble': { status: 'watch', text: 'Social skills develop at different rates. If your child wants friends but struggles, consider social skills groups. If they\'re content alone, that can be okay too.' },
        'teen-isolation': { status: 'watch', text: 'Some alone time is normal for teens. But near-total withdrawal from family AND friends for 2+ weeks, combined with other changes, may signal depression. Check in gently.' },
        'teen-moods': { status: 'normal', text: 'Hormonal changes make mood swings common in adolescence. If mood shifts last 2+ weeks and affect daily functioning, it may be more than typical teen behavior.' },
        'teen-talks-back': { status: 'normal', text: 'Pushing back is a normal part of developing autonomy and identity. Pick your battles. Set clear boundaries on respectful communication, but allow room for disagreement.' },
        'teen-oversleep': { status: 'normal', text: 'Teens biologically need 8-10 hours and their circadian rhythm shifts later. Sleeping until noon on weekends is common. Concern if sleeping 12+ hours daily with loss of interest.' },
      };

      var ageSelect = document.getElementById('normal-age');
      var behaviorSelect = document.getElementById('normal-behavior');
      var checkBtn = document.getElementById('normal-check-btn');
      var resultEl = document.getElementById('normal-result');

      if (ageSelect && behaviorSelect) {
        ageSelect.addEventListener('change', function() {
          var age = ageSelect.value;
          behaviorSelect.innerHTML = '<option value="">Select behavior</option>';
          if (resultEl) resultEl.innerHTML = '';
          if (age && behaviorsByAge[age]) {
            behaviorsByAge[age].forEach(function(b) {
              var opt = document.createElement('option');
              opt.value = b.value;
              opt.textContent = b.label;
              behaviorSelect.appendChild(opt);
            });
          }
        });

        if (checkBtn) {
          checkBtn.addEventListener('click', function() {
            var age = ageSelect.value;
            var behavior = behaviorSelect.value;
            if (!age || !behavior) return;
            var key = age + '-' + behavior;
            var answer = normalAnswers[key];
            if (answer && resultEl) {
              var statusClass = answer.status === 'normal' ? 'daily__result--normal' : 'daily__result--watch';
              var statusIcon = answer.status === 'normal' ? 'Typically Normal' : 'Worth Watching';
              resultEl.innerHTML = '<div class="daily__result-badge ' + statusClass + '">' + statusIcon + '</div><p>' + answer.text + '</p>';
            }
          });
        }
      }

      // === PARENTING JOURNAL ===
      var journalInput = document.getElementById('journal-input');
      var journalSaveBtn = document.getElementById('journal-save-btn');
      var journalSaved = document.getElementById('journal-saved');
      var journalStreak = document.getElementById('journal-streak');

      function getDateKey() {
        return today.toISOString().split('T')[0];
      }

      function calcStreak() {
        var entries = JSON.parse(localStorage.getItem('bp-journal') || '{}');
        var streak = 0;
        var d = new Date(today);
        while (true) {
          var key = d.toISOString().split('T')[0];
          if (entries[key]) {
            streak++;
            d.setDate(d.getDate() - 1);
          } else {
            break;
          }
        }
        return streak;
      }

      function updateStreakUI() {
        var streak = calcStreak();
        if (journalStreak && streak > 0) {
          journalStreak.textContent = streak + ' day streak';
          journalStreak.style.display = 'inline-block';
        }
      }

      // Load existing entry for today
      var entries = JSON.parse(localStorage.getItem('bp-journal') || '{}');
      var todayKey = getDateKey();
      if (entries[todayKey] && journalInput) {
        journalInput.value = entries[todayKey];
      }

      updateStreakUI();

      if (journalSaveBtn && journalInput) {
        journalSaveBtn.addEventListener('click', function() {
          var text = journalInput.value.trim();
          if (!text) return;
          var entries = JSON.parse(localStorage.getItem('bp-journal') || '{}');
          entries[todayKey] = text;
          localStorage.setItem('bp-journal', JSON.stringify(entries));
          if (journalSaved) {
            journalSaved.textContent = 'Saved!';
            journalSaved.style.opacity = '1';
            setTimeout(function() { journalSaved.style.opacity = '0'; }, 2000);
          }
          updateStreakUI();
        });
      }
    })();
  </script>

