---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import AlertBanner from '../../components/AlertBanner.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';
import { useTranslations } from '../../i18n/utils';

const lang = 'en';
const t = useTranslations(lang);

const allPosts = await getCollection('blog');
const now = new Date();
const publishedPosts = allPosts
  .filter((post) => post.data.pubDate <= now && post.data.lang === 'en')
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const featuredPosts = publishedPosts.slice(0, 6);

const ageStages = [
  { key: '0-6m', img: '/images/age-newborn.jpg', color: 'forest' },
  { key: '6-12m', img: '/images/age-explorer.jpg', color: 'orange' },
  { key: '1-2y', img: '/images/age-toddler.jpg', color: 'pink' },
  { key: '2-3y', img: '/images/age-talker.jpg', color: 'forest' },
  { key: '3-6y', img: '/images/age-preschool.jpg', color: 'orange' },
];

const stats = [
  { value: '224+', label: t('stats.indicators') },
  { value: '8', label: t('stats.domains') },
  { value: '0-18', label: t('stats.years') },
];
---

<BaseLayout title={`${t('site.title')} | ${t('site.tagline')}`} description={t('site.description')} lang={lang}>
  <Header lang={lang} />
  <AlertBanner lang={lang} />

  <!-- HERO: Full-width asymmetric split with background imagery -->
  <section class="hero">
    <div class="hero__bg" aria-hidden="true">
      <img
        src="/images/hero-family.jpg"
        alt=""
        width="1920"
        height="1080"
        loading="eager"
        class="hero__bg-img"
      />
      <div class="hero__bg-overlay"></div>
    </div>
    <div class="container hero__grid">
      <div class="hero__content">
        <h1>The science of growing up, simplified.</h1>
        <p class="hero__desc">{t('hero.desc')}</p>
        <div class="hero__actions">
          <a href={`/${lang}/blog`} class="btn btn--primary btn--lg">
            {t('hero.cta.articles')}
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
        <div class="hero__trust">
          <span class="hero__trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            {t('hero.trust.evidence')}
          </span>
          <span class="hero__trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            {t('hero.trust.parents')}
          </span>
          <span class="hero__trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            {t('hero.trust.free')}
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- AGE NAVIGATOR: Horizontal card grid -->
  <section class="age-nav">
    <div class="container">
      <div class="section-header section-header--center">
        <span class="eyebrow">{t('age.section')}</span>
        <h2>{t('age.section.title')}</h2>
        <p class="section-desc section-desc--center">{t('age.section.desc')}</p>
      </div>
      <div class="age-nav__grid">
        {ageStages.map((stage) => (
          <a href={`/${lang}/blog`} class={`age-nav__card age-nav__card--${stage.color}`}>
            <div class="age-nav__img-wrap">
              <img
                src={stage.img}
                alt={t(`age.${stage.key}` as any)}
                width="480"
                height="560"
                loading="lazy"
                class="age-nav__img"
              />
            </div>
            <div class="age-nav__label">
              <span class="age-nav__name">{t(`age.${stage.key}` as any)}</span>
              <span class="age-nav__range">{t(`age.${stage.key}.range` as any)}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- TWO PILLARS: Montessori + Positive Parenting with imagery -->
  <section class="pillars">
    <div class="container">
      <div class="section-header section-header--center">
        <span class="eyebrow">{t('section.philosophy')}</span>
        <h2>{t('section.philosophy.title')}</h2>
        <p class="section-desc section-desc--center">{t('section.philosophy.desc')}</p>
      </div>
      <div class="pillars__grid">
        <div class="pillars__card">
          <div class="pillars__img-wrap">
            <img
              src="/images/montessori-play.jpg"
              alt="Child exploring Montessori materials"
              width="800"
              height="600"
              loading="lazy"
              class="pillars__img"
            />
          </div>
          <div class="pillars__body">
            <div class="pillars__icon pillars__icon--forest">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>
              </svg>
            </div>
            <h3>{t('philosophy.montessori.title')}</h3>
            <p>{t('philosophy.montessori.desc')}</p>
            <ul class="pillars__points">
              <li>{t('philosophy.montessori.point1')}</li>
              <li>{t('philosophy.montessori.point2')}</li>
              <li>{t('philosophy.montessori.point3')}</li>
            </ul>
          </div>
        </div>
        <div class="pillars__card">
          <div class="pillars__img-wrap">
            <img
              src="/images/parent-reading.jpg"
              alt="Parent and child sharing a warm moment"
              width="800"
              height="600"
              loading="lazy"
              class="pillars__img"
            />
          </div>
          <div class="pillars__body">
            <div class="pillars__icon pillars__icon--orange">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
              </svg>
            </div>
            <h3>{t('philosophy.positive.title')}</h3>
            <p>{t('philosophy.positive.desc')}</p>
            <ul class="pillars__points">
              <li>{t('philosophy.positive.point1')}</li>
              <li>{t('philosophy.positive.point2')}</li>
              <li>{t('philosophy.positive.point3')}</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- STATS BAR: Full-width accent strip -->
  <section class="stats-bar">
    <div class="container">
      <div class="stats-bar__grid">
        {stats.map((stat) => (
          <div class="stats-bar__item">
            <span class="stats-bar__value">{stat.value}</span>
            <span class="stats-bar__label">{stat.label}</span>
          </div>
        ))}
        <div class="stats-bar__item stats-bar__item--badge">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <span class="stats-bar__label">{t('stats.research')}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURED ARTICLES: Asymmetric grid -->
  {featuredPosts.length > 0 && (
    <section class="articles">
      <div class="container">
        <div class="section-header">
          <span class="eyebrow">{t('section.latest')}</span>
          <h2>{t('section.latest.title')}</h2>
          <p class="section-desc">{t('section.latest.desc')}</p>
        </div>
        <div class="articles__grid">
          {featuredPosts.map((post, i) => (
            <article class={`articles__card ${i === 0 ? 'articles__card--featured' : ''}`}>
              <div class="articles__meta">
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                </time>
              </div>
              <h3><a href={`/${lang}/blog/${post.id}`}>{post.data.title}</a></h3>
              <p>{post.data.description}</p>
              {post.data.tags && post.data.tags.length > 0 && (
                <div class="articles__tags">
                  {post.data.tags.slice(0, 3).map((tag: string) => (<span class="tag">{tag}</span>))}
                </div>
              )}
            </article>
          ))}
        </div>
        <div class="section-cta">
          <a href={`/${lang}/blog`} class="btn btn--ghost">{t('section.latest.viewAll')}</a>
        </div>
      </div>
    </section>
  )}

  <!-- APP PREVIEW: Soft CTA -->
  <section class="app-preview">
    <div class="container">
      <div class="app-preview__inner">
        <div class="app-preview__content">
          <span class="eyebrow">{t('app.section')}</span>
          <h2>{t('app.section.title')}</h2>
          <p>{t('app.section.desc')}</p>
          <a href="#newsletter" class="btn btn--primary">{t('app.cta')}</a>
        </div>
        <div class="app-preview__visual" aria-hidden="true">
          <div class="app-preview__phone">
            <div class="app-preview__screen">
              <img
                src="/images/montessori-play.jpg"
                alt=""
                width="390"
                height="844"
                loading="lazy"
                class="app-preview__screen-img"
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- NEWSLETTER -->
  <section id="newsletter" class="newsletter">
    <div class="container">
      <div class="newsletter__inner">
        <div class="newsletter__content">
          <span class="eyebrow eyebrow--light">{t('section.newsletter')}</span>
          <h2>{t('section.newsletter.title')}</h2>
          <p>{t('section.newsletter.desc')}</p>
        </div>
        <div class="newsletter__form">
          <p class="newsletter__placeholder">{t('section.newsletter.placeholder')}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section id="about" class="about">
    <div class="container">
      <div class="about__inner">
        <div class="about__content">
          <span class="eyebrow">{t('section.about')}</span>
          <h2>{t('section.about.title')}</h2>
          <p>{t('section.about.p1')}</p>
          <p>{t('section.about.p2')}</p>
          <div class="about__values">
            <div class="about__value">
              <strong>{t('section.about.evidence')}</strong>
              <span>{t('section.about.evidence.desc')}</span>
            </div>
            <div class="about__value">
              <strong>{t('section.about.practical')}</strong>
              <span>{t('section.about.practical.desc')}</span>
            </div>
            <div class="about__value">
              <strong>{t('section.about.inclusive')}</strong>
              <span>{t('section.about.inclusive.desc')}</span>
            </div>
          </div>
        </div>
        <div class="about__visual" aria-hidden="true">
          <img
            src="/images/about-family.jpg"
            alt=""
            width="640"
            height="800"
            loading="lazy"
            class="about__img"
          />
        </div>
      </div>
    </div>
  </section>

  <Footer lang={lang} />
</BaseLayout>

<style>
  /* ================================================
     BLOOMPATH HOMEPAGE — LOVEVERY-QUALITY REBUILD
     Desktop-first. 1440px target. Morandi palette.
     Font: Outfit. No Tailwind — pure CSS.
     DESIGN_VARIANCE: 8 | MOTION_INTENSITY: 6 | VISUAL_DENSITY: 4
     ================================================ */

  /* ===== SHARED TOKENS ===== */
  .eyebrow {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-orange-dark);
    background: rgba(196, 168, 130, 0.1);
    padding: 0.3125rem 0.875rem;
    border-radius: 100px;
    margin-bottom: 1rem;
  }

  .eyebrow--light {
    background: rgba(255, 255, 255, 0.1);
    color: var(--color-orange);
  }

  .section-header { margin-bottom: 3.5rem; }
  .section-header--center { text-align: center; }

  .section-header h2 {
    font-size: 2.75rem;
    font-weight: 800;
    letter-spacing: -0.035em;
    color: var(--color-text);
    line-height: 1.1;
    text-wrap: balance;
  }

  .section-desc {
    font-size: 1.0625rem;
    color: var(--color-text-light);
    margin-top: 0.875rem;
    max-width: 55ch;
    line-height: 1.7;
  }

  .section-desc--center { margin-inline: auto; }

  .section-cta {
    text-align: center;
    margin-top: 3.5rem;
  }

  /* ===== BUTTONS ===== */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-primary);
    font-size: 0.9375rem;
    font-weight: 600;
    padding: 0.8125rem 1.75rem;
    border-radius: 12px;
    border: none;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.32, 0.72, 0, 1);
  }

  .btn:active { transform: translateY(1px) scale(0.98); }

  .btn--primary {
    background: var(--color-forest);
    color: var(--color-white);
  }

  .btn--primary:hover {
    background: var(--color-forest-dark);
    color: var(--color-white);
    transform: translateY(-1px);
    box-shadow: 0 8px 28px -8px rgba(112, 125, 114, 0.35);
  }

  .btn--lg { padding: 0.9375rem 2rem; font-size: 1rem; }

  .btn--ghost {
    background: transparent;
    color: var(--color-forest);
    border: 1.5px solid rgba(141, 155, 142, 0.25);
  }

  .btn--ghost:hover {
    border-color: var(--color-forest);
    background: rgba(141, 155, 142, 0.04);
    color: var(--color-forest);
  }

  /* ===== HERO — Full-width with background image ===== */
  .hero {
    position: relative;
    min-height: 92vh;
    min-height: 92dvh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero__bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
  }

  .hero__bg-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(105deg, rgba(250, 248, 245, 0.95) 0%, rgba(250, 248, 245, 0.82) 45%, rgba(250, 248, 245, 0.3) 75%, transparent 100%);
  }

  .hero__grid {
    position: relative;
    z-index: 1;
    padding: 8rem 0 6rem;
  }

  .hero__content {
    max-width: 620px;
  }

  .hero h1 {
    font-size: 4rem;
    font-weight: 800;
    line-height: 1.04;
    letter-spacing: -0.04em;
    color: var(--color-text);
    text-wrap: balance;
  }

  .hero__desc {
    font-size: 1.1875rem;
    color: var(--color-text-light);
    line-height: 1.7;
    max-width: 50ch;
    margin-top: 1.75rem;
  }

  .hero__actions {
    margin-top: 2.5rem;
  }

  .hero__trust {
    display: flex;
    gap: 1.75rem;
    margin-top: 2.75rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(141, 155, 142, 0.12);
  }

  .hero__trust-item {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-text-light);
  }

  .hero__trust-item svg {
    color: var(--color-forest);
    flex-shrink: 0;
  }

  /* ===== AGE NAVIGATOR ===== */
  .age-nav {
    padding: 7rem 0 6rem;
  }

  .age-nav__grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1.25rem;
  }

  .age-nav__card {
    display: flex;
    flex-direction: column;
    border-radius: 20px;
    overflow: hidden;
    text-decoration: none;
    background: var(--color-white);
    border: 1px solid rgba(141, 155, 142, 0.06);
    transition: all 0.35s cubic-bezier(0.32, 0.72, 0, 1);
  }

  .age-nav__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 48px -16px rgba(74, 69, 67, 0.1);
  }

  .age-nav__card:hover .age-nav__img {
    transform: scale(1.04);
  }

  .age-nav__img-wrap {
    aspect-ratio: 6 / 7;
    overflow: hidden;
    position: relative;
  }

  .age-nav__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s cubic-bezier(0.32, 0.72, 0, 1);
  }

  .age-nav__label {
    padding: 1.125rem 1.25rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .age-nav__name {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-text);
    letter-spacing: -0.01em;
  }

  .age-nav__range {
    font-size: 0.8125rem;
    color: var(--color-text-light);
  }

  .age-nav__card--forest { border-bottom: 3px solid var(--color-forest); }
  .age-nav__card--orange { border-bottom: 3px solid var(--color-orange); }
  .age-nav__card--pink { border-bottom: 3px solid var(--color-pink); }

  /* ===== PILLARS: Two-column with imagery ===== */
  .pillars {
    padding: 7rem 0;
    background: var(--color-cream);
  }

  .pillars__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .pillars__card {
    background: var(--color-white);
    border-radius: 24px;
    overflow: hidden;
    border: 1px solid rgba(141, 155, 142, 0.06);
    transition: all 0.35s cubic-bezier(0.32, 0.72, 0, 1);
  }

  .pillars__card:hover {
    transform: translateY(-3px);
    box-shadow: 0 24px 56px -16px rgba(74, 69, 67, 0.08);
  }

  .pillars__img-wrap {
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }

  .pillars__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s cubic-bezier(0.32, 0.72, 0, 1);
  }

  .pillars__card:hover .pillars__img {
    transform: scale(1.03);
  }

  .pillars__body {
    padding: 2.25rem 2rem 2.5rem;
  }

  .pillars__icon {
    width: 52px;
    height: 52px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.25rem;
  }

  .pillars__icon--forest { background: rgba(141, 155, 142, 0.08); color: var(--color-forest); }
  .pillars__icon--orange { background: rgba(196, 168, 130, 0.1); color: var(--color-orange-dark); }

  .pillars__body h3 {
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin-bottom: 0.625rem;
  }

  .pillars__body p {
    font-size: 0.9375rem;
    color: var(--color-text-light);
    line-height: 1.7;
    max-width: 50ch;
  }

  .pillars__points {
    list-style: none;
    margin-top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .pillars__points li {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text);
    padding-left: 1.375rem;
    position: relative;
    line-height: 1.5;
  }

  .pillars__points li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.5em;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--color-forest-light);
  }

  /* ===== STATS BAR ===== */
  .stats-bar {
    padding: 4rem 0;
    background: var(--color-forest-dark);
    color: var(--color-white);
  }

  .stats-bar__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    text-align: center;
  }

  .stats-bar__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }

  .stats-bar__value {
    font-size: 2.5rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1;
    color: var(--color-white);
    font-variant-numeric: tabular-nums;
  }

  .stats-bar__label {
    font-size: 0.875rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.7);
    margin-top: 0.25rem;
  }

  .stats-bar__item--badge {
    flex-direction: row;
    gap: 0.625rem;
  }

  .stats-bar__item--badge svg {
    color: var(--color-orange);
    flex-shrink: 0;
  }

  .stats-bar__item--badge .stats-bar__label {
    font-size: 1rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.85);
    margin-top: 0;
  }

  /* ===== FEATURED ARTICLES ===== */
  .articles {
    padding: 7rem 0;
  }

  .articles__grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    grid-template-rows: auto auto;
    gap: 1.25rem;
  }

  .articles__card {
    background: var(--color-white);
    border-radius: 20px;
    padding: 2rem;
    border: 1px solid rgba(141, 155, 142, 0.06);
    transition: all 0.3s cubic-bezier(0.32, 0.72, 0, 1);
    display: flex;
    flex-direction: column;
  }

