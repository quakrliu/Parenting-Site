---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import AlertBanner from '../../components/AlertBanner.astro';
import Footer from '../../components/Footer.astro';
import HomeHero from '../../components/HomeHero.astro';
import AgeNavigator from '../../components/AgeNavigator.astro';
import PhilosophyPillars from '../../components/PhilosophyPillars.astro';
import StatsBar from '../../components/StatsBar.astro';
import DailyStickiness from '../../components/DailyStickiness.astro';
import FeaturedArticles from '../../components/FeaturedArticles.astro';
import TopicsSection from '../../components/TopicsSection.astro';
import DevelopmentalWindows from '../../components/DevelopmentalWindows.astro';
import CommunitySection from '../../components/CommunitySection.astro';
import NewsletterSection from '../../components/NewsletterSection.astro';
import AboutSection from '../../components/AboutSection.astro';
import { getCollection } from 'astro:content';
import { useTranslations } from '../../i18n/utils';

const lang = 'en';
const t = useTranslations(lang);

const allPosts = await getCollection('blog');
const now = new Date();
const featuredPosts = allPosts
  .filter((post) => post.data.pubDate <= now && post.data.lang === 'en')
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);
---

<BaseLayout title={`${t('site.title')} | ${t('site.tagline')}`} description={t('site.description')} lang={lang}>
  <Header lang={lang} />
  <AlertBanner lang={lang} />
  <HomeHero lang={lang} />
  <AgeNavigator lang={lang} />
  <TopicsSection lang={lang} />
  <DevelopmentalWindows lang={lang} />
  <PhilosophyPillars lang={lang} />
  <StatsBar lang={lang} />
  <DailyStickiness lang={lang} />
  <FeaturedArticles lang={lang} posts={featuredPosts} />
  <CommunitySection lang={lang} />
  <NewsletterSection lang={lang} />
  <AboutSection lang={lang} />
  <Footer lang={lang} />
</BaseLayout>
