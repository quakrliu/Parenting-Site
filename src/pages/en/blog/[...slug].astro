---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import DisqusComments from '../../../components/DisqusComments.astro';
import { getCollection, render } from 'astro:content';
import { useTranslations } from '../../../i18n/utils';

const lang = 'en';
const t = useTranslations(lang);

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const postLang = post.data.lang === 'zh-TW' ? 'zh' : 'en';
---

<BaseLayout
  title={`${post.data.title} | ${t('site.title')}`}
  description={post.data.description}
  lang={postLang}
>
  <Header lang={lang} />

  <main class="blog-post">
    <div class="container">
      <article>
        <header class="post-header">
          <div class="post-meta">
            <time datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString(postLang === 'zh' ? 'zh-TW' : 'en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
            </time>
          </div>
          <h1>{post.data.title}</h1>
          {post.data.author && <p class="post-author">By {post.data.author}</p>}
        </header>

        <div class="post-content">
          <Content />
        </div>

        {post.data.tags && post.data.tags.length > 0 && (
          <footer class="post-footer">
            <div class="post-tags">
              {post.data.tags.map((tag: string) => (<span class="tag">{tag}</span>))}
            </div>
          </footer>
        )}
      </article>

      <DisqusComments
        lang="en"
        pageUrl={Astro.url.href}
        pageIdentifier={`/en/blog/${post.id}`}
      />

      <nav class="post-nav">
        <a href={`/${lang}/blog`} class="back-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
          {t('blog.back')}
        </a>
      </nav>
    </div>
  </main>

  <Footer lang={lang} />
</BaseLayout>

<style>
  .blog-post { padding: 3rem 0; }
  .post-header { margin-bottom: 2.5rem; padding-bottom: 2rem; border-bottom: 1px solid rgba(141, 155, 142, 0.1); }
  .post-meta { display: flex; align-items: center; gap: 0.625rem; margin-bottom: 1rem; }
  .post-meta time { font-size: 0.875rem; color: var(--color-text-light); }
  .post-header h1 { font-size: clamp(1.75rem, 4vw, 2.5rem); font-weight: 700; line-height: 1.25; letter-spacing: -0.02em; max-width: 70ch; }
  .post-author { font-size: 0.9375rem; color: var(--color-text-light); margin-top: 0.75rem; }
  .post-content { max-width: 72ch; font-size: 1.0625rem; line-height: 1.8; color: var(--color-text); }
  .post-content :global(h2) { font-size: 1.5rem; font-weight: 700; margin-top: 2.5rem; margin-bottom: 1rem; letter-spacing: -0.01em; }
  .post-content :global(h3) { font-size: 1.25rem; font-weight: 600; margin-top: 2rem; margin-bottom: 0.75rem; }
  .post-content :global(p) { margin-bottom: 1.25rem; }
  .post-content :global(ul), .post-content :global(ol) { margin-bottom: 1.25rem; padding-left: 1.5rem; }
  .post-content :global(li) { margin-bottom: 0.375rem; }
  .post-content :global(blockquote) { border-left: 3px solid var(--color-forest); padding: 0.75rem 1.25rem; margin: 1.5rem 0; background: rgba(141, 155, 142, 0.04); border-radius: 0 8px 8px 0; font-style: italic; color: var(--color-text-light); }
  .post-content :global(a) { color: var(--color-forest); text-decoration: underline; text-decoration-thickness: 1px; text-underline-offset: 2px; }
  .post-content :global(strong) { font-weight: 600; color: var(--color-text); }
  .post-content :global(table) { width: 100%; border-collapse: collapse; margin: 1.5rem 0; font-size: 0.9375rem; }
  .post-content :global(th), .post-content :global(td) { padding: 0.75rem 1rem; text-align: left; border-bottom: 1px solid rgba(141, 155, 142, 0.1); }
  .post-content :global(th) { font-weight: 600; background: rgba(141, 155, 142, 0.04); }
  .post-footer { margin-top: 3rem; padding-top: 2rem; border-top: 1px solid rgba(141, 155, 142, 0.1); }
  .post-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .tag { font-size: 0.8125rem; color: var(--color-text-light); background: rgba(141, 155, 142, 0.06); padding: 0.25rem 0.75rem; border-radius: 6px; }
  .post-nav { margin-top: 3rem; }
  .back-link { display: inline-flex; align-items: center; gap: 0.5rem; font-size: 0.9375rem; font-weight: 500; color: var(--color-forest); text-decoration: none; transition: gap 0.2s ease; }
  .back-link:hover { gap: 0.75rem; color: var(--color-forest-dark); }
</style>
