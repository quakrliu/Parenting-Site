---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { getCollection } from 'astro:content';
import { useTranslations } from '../../../i18n/utils';

const lang = 'en';
const t = useTranslations(lang);

const allPosts = await getCollection('blog');
const now = new Date();
const posts = allPosts
  .filter((post) => post.data.pubDate <= now && post.data.lang === 'en')
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title={`${t('blog.title')} | ${t('site.title')}`} description={t('blog.desc')} lang={lang}>
  <Header lang={lang} />

  <main class="blog-listing">
    <div class="container">
      <div class="listing-header">
        <h1>{t('blog.title')}</h1>
        <p>{t('blog.desc')}</p>
      </div>

      <div class="posts-grid">
        {posts.map((post) => (
          <article class="post-card">
            <div class="post-meta">
              <time datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
              </time>
            </div>
            <h2><a href={`/${lang}/blog/${post.id}`}>{post.data.title}</a></h2>
            <p>{post.data.description}</p>
            {post.data.tags && post.data.tags.length > 0 && (
              <div class="post-tags">
                {post.data.tags.slice(0, 3).map((tag: string) => (<span class="tag">{tag}</span>))}
              </div>
            )}
          </article>
        ))}
      </div>

      {posts.length === 0 && (
        <div class="empty-state">
          <p>{t('blog.empty')}</p>
        </div>
      )}
    </div>
  </main>

  <Footer lang={lang} />
</BaseLayout>

<style>
  .blog-listing { padding: 4rem 0; }
  .listing-header { margin-bottom: 3rem; }
  .listing-header h1 { font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; letter-spacing: -0.02em; }
  .listing-header p { font-size: 1.0625rem; color: var(--color-text-light); margin-top: 0.5rem; }
  .posts-grid { display: grid; grid-template-columns: 1fr; gap: 1.25rem; }
  .post-card { background: var(--color-white); border-radius: 16px; padding: 1.75rem; border: 1px solid rgba(45, 106, 79, 0.06); transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1); }
  .post-card:hover { border-color: rgba(45, 106, 79, 0.15); box-shadow: 0 8px 30px -10px rgba(45, 106, 79, 0.08); }
  .post-meta { display: flex; align-items: center; gap: 0.625rem; margin-bottom: 0.75rem; }
  .post-meta time { font-size: 0.8125rem; color: var(--color-text-light); }
  .post-card h2 { font-size: 1.125rem; font-weight: 600; line-height: 1.4; }
  .post-card h2 a { color: var(--color-text); text-decoration: none; }
  .post-card h2 a:hover { color: var(--color-forest); }
  .post-card p { font-size: 0.9375rem; color: var(--color-text-light); line-height: 1.6; margin-top: 0.5rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .post-tags { display: flex; flex-wrap: wrap; gap: 0.375rem; margin-top: 0.875rem; }
  .tag { font-size: 0.75rem; color: var(--color-text-light); background: rgba(45, 106, 79, 0.05); padding: 0.1875rem 0.625rem; border-radius: 6px; }
  .empty-state { text-align: center; padding: 4rem 0; color: var(--color-text-light); }
  @media (min-width: 640px) { .posts-grid { grid-template-columns: repeat(2, 1fr); } }
</style>
