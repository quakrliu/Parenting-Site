---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import ToolsNav from '../../../components/ToolsNav.astro';

const lang = 'en';
---

<BaseLayout
  title="Bilingual Vocabulary Tracker | BloomPath"
  description="Track your bilingual child's vocabulary development. Compare total words across both languages to see how they're progressing."
  lang={lang}
>
  <Header lang={lang} />
  <div class="container" style="padding-top:1.5rem"><ToolsNav lang={lang} current="vocabulary-tracker" /></div>

  <main class="tool-page">
    <div class="container">
      <div class="tool-header">
        <div class="tool-icon">🗣️</div>
        <h1>Bilingual Vocabulary Tracker</h1>
        <p class="tool-subtitle">
          For bilingual children, total vocabulary across both languages is what matters — not each language separately. Enter your child's words to see how they compare.
        </p>
      </div>

      <div class="key-insight">
        <span class="insight-icon">💡</span>
        <div>
          <strong>The bilingual advantage:</strong> Research shows bilingual children's <em>combined</em> vocabulary across both languages should be compared to typical ranges — not each language individually.
        </div>
      </div>

      <div class="tool-card">
        <div class="inputs-grid">
          <div class="input-group full-width">
            <label for="child-age" class="input-label">Child age (months)</label>
            <div class="age-input-row">
              <input type="number" id="child-age" min="12" max="72" value="24" class="number-input" />
              <span class="input-unit">months old</span>
            </div>
          </div>

          <div class="input-group">
            <label for="lang1-name" class="input-label">Language 1 name</label>
            <input type="text" id="lang1-name" placeholder="e.g. English" class="text-input" value="English" />
          </div>

          <div class="input-group">
            <label for="lang1-words" class="input-label">Words in Language 1</label>
            <div class="age-input-row">
              <input type="number" id="lang1-words" min="0" max="2000" value="25" class="number-input wide" />
              <span class="input-unit">words</span>
            </div>
          </div>

          <div class="input-group">
            <label for="lang2-name" class="input-label">Language 2 name</label>
            <input type="text" id="lang2-name" placeholder="e.g. Mandarin" class="text-input" value="Mandarin" />
          </div>

          <div class="input-group">
            <label for="lang2-words" class="input-label">Words in Language 2</label>
            <div class="age-input-row">
              <input type="number" id="lang2-words" min="0" max="2000" value="20" class="number-input wide" />
              <span class="input-unit">words</span>
            </div>
          </div>
        </div>

        <button id="track-btn" class="track-btn">Check Vocabulary</button>
      </div>

      <div id="results" class="results hidden">
        <div class="vocab-summary" id="vocab-summary"></div>

        <div class="progress-section" id="progress-section">
          <h3 class="section-title">Vocabulary Breakdown</h3>
          <div id="lang-bars" class="lang-bars"></div>
        </div>

        <div id="status-card" class="status-card"></div>

        <div class="tips-section">
          <h3 class="section-title">Tips for Bilingual Language Development</h3>
          <ul id="tips-list" class="tips-list"></ul>
        </div>

        <div class="disclaimer">
          <span class="disclaimer-icon">💛</span>
          <p>Language development varies widely among children. These ranges are guidelines, not strict targets. If you have concerns about your child's language development, speak with a speech-language pathologist who specializes in bilingualism.</p>
        </div>

        <div class="related-articles">
          <h3>Related Articles</h3>
          <div class="article-links">
            <a href="https://bloom-path.app/en/blog/raising-bilingual-children" class="article-link">Raising Bilingual Children</a>
            <a href="https://bloom-path.app/en/blog/bilingual-language-milestones" class="article-link">Bilingual Language Milestones</a>
            <a href="https://bloom-path.app/en/blog/opol-method-one-parent-one-language" class="article-link">The OPOL Method</a>
          </div>
        </div>
      </div>
    </div>
  </main>

  <Footer lang={lang} />
</BaseLayout>

<style>
  .tool-page { min-height: 80vh; padding: 3rem 0 6rem; background: #F5F0EB; }
  .container { max-width: 820px; margin: 0 auto; padding: 0 1.5rem; }
  .tool-header { text-align: center; margin-bottom: 1.5rem; }
  .tool-icon { font-size: 3rem; margin-bottom: 1rem; }
  h1 { font-size: clamp(1.75rem, 4vw, 2.5rem); font-weight: 700; color: #4A4543; margin-bottom: 0.75rem; letter-spacing: -0.02em; }
  .tool-subtitle { font-size: 1.0625rem; color: #6b6461; max-width: 56ch; margin: 0 auto; line-height: 1.65; }

  .key-insight { background: rgba(196,168,130,0.15); border: 1px solid rgba(196,168,130,0.4); border-radius: 12px; padding: 1.125rem 1.5rem; display: flex; gap: 0.875rem; align-items: flex-start; font-size: 0.9375rem; color: #5c5030; line-height: 1.65; margin-bottom: 2rem; }
  .insight-icon { font-size: 1.25rem; flex-shrink: 0; margin-top: 0.05rem; }

  .tool-card { background: #fff; border-radius: 16px; padding: 2rem; box-shadow: 0 2px 16px rgba(74,69,67,0.06); margin-bottom: 2rem; }
  .inputs-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; margin-bottom: 2rem; }
  .full-width { grid-column: 1 / -1; }
  .input-label { display: block; font-size: 0.875rem; font-weight: 600; color: #4A4543; margin-bottom: 0.5rem; }
  .age-input-row { display: flex; align-items: center; gap: 0.625rem; border: 2px solid #e8e4e0; border-radius: 10px; padding: 0.625rem 1rem; background: #faf8f6; transition: border-color 0.2s; }
  .age-input-row:focus-within { border-color: #8D9B8E; }
  .number-input { border: none; background: transparent; font-size: 1.125rem; font-weight: 700; color: #4A4543; width: 60px; outline: none; }
  .number-input.wide { width: 80px; }
  .input-unit { font-size: 0.875rem; color: #9d9896; }
  .text-input { width: 100%; border: 2px solid #e8e4e0; border-radius: 10px; padding: 0.75rem 1rem; font-size: 0.9375rem; color: #4A4543; background: #faf8f6; outline: none; transition: border-color 0.2s; }
  .text-input:focus { border-color: #8D9B8E; }

  .track-btn { width: 100%; padding: 0.875rem; background: #8D9B8E; color: #fff; font-size: 1rem; font-weight: 700; border: none; border-radius: 10px; cursor: pointer; transition: background 0.2s, transform 0.1s; }
  .track-btn:hover { background: #7a8a7b; }
  .track-btn:active { transform: scale(0.98); }

  .hidden { display: none; }
  .results { animation: fadeIn 0.35s ease; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

  .vocab-summary { display: grid; grid-template-columns: repeat(3,1fr); gap: 1rem; margin-bottom: 2rem; }
  .summary-card { background: #fff; border-radius: 14px; padding: 1.25rem; text-align: center; box-shadow: 0 2px 12px rgba(74,69,67,0.05); }
  .summary-icon { font-size: 1.5rem; margin-bottom: 0.375rem; }
  .summary-value { font-size: 1.5rem; font-weight: 800; color: #4A4543; margin-bottom: 0.25rem; }
  .summary-label { font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: #9d9896; }

  .progress-section { background: #fff; border-radius: 16px; padding: 2rem; box-shadow: 0 2px 12px rgba(74,69,67,0.05); margin-bottom: 1.5rem; }
  .section-title { font-size: 1rem; font-weight: 700; color: #4A4543; margin-bottom: 1.25rem; }
  .lang-bars { display: flex; flex-direction: column; gap: 1.25rem; }

  .lang-bar-item { display: flex; flex-direction: column; gap: 0.375rem; }
  .lang-bar-header { display: flex; justify-content: space-between; font-size: 0.9375rem; font-weight: 600; color: #4A4543; }
  .lang-bar-track { height: 14px; background: #ede9e5; border-radius: 7px; overflow: hidden; }
  .lang-bar-fill { height: 100%; border-radius: 7px; transition: width 0.6s cubic-bezier(0.16,1,0.3,1); }

  .status-card { border-radius: 14px; padding: 1.5rem; margin-bottom: 1.5rem; }
  .status-card.on-track { background: rgba(141,155,142,0.12); border: 1px solid rgba(141,155,142,0.35); }
  .status-card.monitor { background: rgba(196,168,130,0.12); border: 1px solid rgba(196,168,130,0.35); }
  .status-card.concern { background: rgba(212,181,176,0.18); border: 1px solid rgba(212,181,176,0.45); }
  .status-title { font-size: 1rem; font-weight: 700; color: #4A4543; margin-bottom: 0.5rem; }
  .status-text { font-size: 0.9375rem; color: #5c5856; line-height: 1.65; }

  .tips-section { background: #fff; border-radius: 14px; padding: 1.5rem; box-shadow: 0 2px 12px rgba(74,69,67,0.05); margin-bottom: 1.5rem; }
  .tips-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.75rem; }
  .tips-list li { font-size: 0.9375rem; color: #5c5856; line-height: 1.55; padding-left: 1.5rem; position: relative; }
  .tips-list li::before { content: "\2192"; position: absolute; left: 0; color: #C4A882; font-weight: 700; }

  .disclaimer { background: rgba(212,181,176,0.15); border: 1px solid rgba(212,181,176,0.4); border-radius: 12px; padding: 1.25rem 1.5rem; display: flex; gap: 0.75rem; align-items: flex-start; margin-bottom: 2rem; }
  .disclaimer-icon { font-size: 1.125rem; flex-shrink: 0; margin-top: 0.1rem; }
  .disclaimer p { font-size: 0.875rem; color: #6b6461; line-height: 1.65; margin: 0; }

  .related-articles h3 { font-size: 1rem; font-weight: 700; color: #4A4543; margin-bottom: 0.875rem; }
  .article-links { display: flex; flex-wrap: wrap; gap: 0.625rem; }
  .article-link { font-size: 0.875rem; color: #8D9B8E; text-decoration: none; padding: 0.375rem 0.875rem; border: 1px solid rgba(141,155,142,0.4); border-radius: 20px; transition: all 0.2s ease; }
  .article-link:hover { background: #8D9B8E; color: #fff; border-color: #8D9B8E; }

  @media (max-width: 600px) { .inputs-grid { grid-template-columns: 1fr; } .vocab-summary { grid-template-columns: 1fr; } }
</style>

<script>
  interface VocabRange {
    label: string;
    typicalMin: number;
    typicalMax: number;
    concernBelow: number;
    description: string;
  }

  function getVocabRange(months: number): VocabRange {
    if (months < 12) return { label: "Under 12 months", typicalMin: 0, typicalMax: 5, concernBelow: 0, description: "Before 12 months, most children babble and say 1-3 words. Comprehension is developing rapidly even if output is limited." };
    if (months <= 15) return { label: "12-15 months", typicalMin: 5, typicalMax: 20, concernBelow: 3, description: "Children typically use 5-20 words. Pointing and gestures are also an important part of communication at this stage." };
    if (months <= 18) return { label: "16-18 months", typicalMin: 10, typicalMax: 50, concernBelow: 5, description: "Most children use 10-50 words. Vocabulary growth accelerates rapidly around 18 months (the vocabulary explosion)." };
    if (months <= 24) return { label: "19-24 months", typicalMin: 50, typicalMax: 200, concernBelow: 25, description: "By 24 months, most children use 50+ words and begin combining two words. A bilingual total of 50 words is the key milestone." };
    if (months <= 30) return { label: "25-30 months", typicalMin: 200, typicalMax: 450, concernBelow: 100, description: "Vocabulary grows rapidly. Children use 3-word phrases. For bilingual children, the total combined count is what matters." };
    if (months <= 36) return { label: "31-36 months", typicalMin: 400, typicalMax: 800, concernBelow: 200, description: "Children know hundreds of words and speak in sentences. Bilingual children may split vocabulary unevenly across languages, which is normal." };
    if (months <= 48) return { label: "37-48 months", typicalMin: 800, typicalMax: 1500, concernBelow: 400, description: "Vocabulary continues to expand dramatically. Bilingual children often have larger total vocabularies than monolingual peers." };
    return { label: "49-72 months", typicalMin: 1500, typicalMax: 3000, concernBelow: 800, description: "Children approaching school age have extensive vocabularies. Bilingual children may show varying fluency across contexts and languages." };
  }

  function getStatus(total: number, range: VocabRange): { type: string; title: string; text: string } {
    if (total >= range.typicalMin) {
      return { type: "on-track", title: "On Track", text: "Your child's combined vocabulary of " + total + " words is within the typical range for " + range.label + " (" + range.typicalMin + "-" + range.typicalMax + " words). Keep doing what you are doing!" };
    } else if (total >= range.concernBelow) {
      return { type: "monitor", title: "Slightly Below Typical Range", text: "A combined vocabulary of " + total + " words is a little below the typical range of " + range.typicalMin + "-" + range.typicalMax + " for " + range.label + ". This is not necessarily a concern, but worth monitoring. Continue rich language exposure in both languages." };
    } else {
      return { type: "concern", title: "Below Expected Range", text: "A combined vocabulary of " + total + " words is below what is typically expected (" + range.typicalMin + "+ words) for " + range.label + ". We recommend speaking with a speech-language pathologist who specializes in bilingual development for personalized guidance." };
    }
  }

  function getTips(months: number, total: number, lang1: number, lang2: number, l1Name: string, l2Name: string): string[] {
    const tips = [
      "Talk, read, and sing in both languages every day. Quality input beats quantity of formal lessons.",
      "Never correct language mixing (code-switching) — it is a normal sign of bilingual competence, not confusion.",
      "Read books in both languages. Bilingual books that switch languages on each page can be especially engaging.",
      "Connect each language to meaningful contexts: one language for cooking, another for bedtime stories.",
      "Find community exposure: playgroups, shows, or video calls with relatives in each language."
    ];
    if (lang1 === 0 || lang2 === 0) {
      tips.unshift("Consider increasing exposure to " + (lang1 === 0 ? l1Name : l2Name) + ". Even 30 minutes of daily input can make a significant difference.");
    }
    if (total < 50 && months >= 24) {
      tips.unshift("At 24 months, 50 combined words is the key milestone. Consider consulting a bilingual speech-language pathologist.");
    }
    return tips.slice(0, 5);
  }

  document.getElementById("track-btn")?.addEventListener("click", () => {
    const ageEl = document.getElementById("child-age") as HTMLInputElement;
    const l1NameEl = document.getElementById("lang1-name") as HTMLInputElement;
    const l1El = document.getElementById("lang1-words") as HTMLInputElement;
    const l2NameEl = document.getElementById("lang2-name") as HTMLInputElement;
    const l2El = document.getElementById("lang2-words") as HTMLInputElement;

    const months = parseInt(ageEl.value) || 24;
    const l1Name = l1NameEl.value || "Language 1";
    const l1 = parseInt(l1El.value) || 0;
    const l2Name = l2NameEl.value || "Language 2";
    const l2 = parseInt(l2El.value) || 0;
    const total = l1 + l2;

    const range = getVocabRange(months);
    const status = getStatus(total, range);
    const tips = getTips(months, total, l1, l2, l1Name, l2Name);

    const summaryEl = document.getElementById("vocab-summary")!;
    summaryEl.innerHTML =
      '<div class="summary-card"><div class="summary-icon">📊</div><div class="summary-value">' + total + '</div><div class="summary-label">Total vocabulary</div></div>' +
      '<div class="summary-card"><div class="summary-icon">🗣️</div><div class="summary-value">' + range.typicalMin + '-' + range.typicalMax + '</div><div class="summary-label">Typical for age</div></div>' +
      '<div class="summary-card"><div class="summary-icon">⚖️</div><div class="summary-value">' + (total > 0 ? Math.round(l1/total*100) + "/" + Math.round(l2/total*100) : "50/50") + '</div><div class="summary-label">' + l1Name + ' / ' + l2Name + ' split</div></div>';

    const maxWords = Math.max(total, range.typicalMax, 1);
    document.getElementById("lang-bars")!.innerHTML =
      '<div class="lang-bar-item"><div class="lang-bar-header"><span>' + l1Name + '</span><span>' + l1 + ' words</span></div><div class="lang-bar-track"><div class="lang-bar-fill" style="width:' + (l1/maxWords*100).toFixed(1) + '%;background:#8D9B8E"></div></div></div>' +
      '<div class="lang-bar-item"><div class="lang-bar-header"><span>' + l2Name + '</span><span>' + l2 + ' words</span></div><div class="lang-bar-track"><div class="lang-bar-fill" style="width:' + (l2/maxWords*100).toFixed(1) + '%;background:#C4A882"></div></div></div>' +
      '<div class="lang-bar-item"><div class="lang-bar-header"><span>Combined total</span><span>' + total + ' / typical ' + range.typicalMin + '-' + range.typicalMax + '</span></div><div class="lang-bar-track"><div class="lang-bar-fill" style="width:' + Math.min(total/maxWords*100, 100).toFixed(1) + '%;background:#D4B5B0"></div></div></div>' +
      '<p style="font-size:0.8125rem;color:#9d9896;margin-top:0.5rem">' + range.description + '</p>';

    const statusCard = document.getElementById("status-card")!;
    statusCard.className = "status-card " + status.type;
    statusCard.innerHTML = '<div class="status-title">' + status.title + '</div><div class="status-text">' + status.text + '</div>';

    document.getElementById("tips-list")!.innerHTML = tips.map(t => "<li>" + t + "</li>").join("");

    const res = document.getElementById("results")!;
    res.classList.remove("hidden");
    res.scrollIntoView({ behavior: "smooth", block: "nearest" });
  });
</script>
