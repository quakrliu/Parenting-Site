  const AREA_COLORS: Record<DomainKey, string> = {
    Motor: '#8D9B8E',
    Language: '#C4A882',
    Sensory: '#D4B5B0',
    'Practical Life': '#A3B0A5',
    Math: '#B09670',
    Culture: '#707D72',
  };

  const findBtn = document.getElementById('find-btn')!;
  const resultsEl = document.getElementById('results') as HTMLElement;

  findBtn.addEventListener('click', () => {
    const age = (document.getElementById('age-range') as HTMLSelectElement).value as AgeKey;
    const area = (document.getElementById('dev-area') as HTMLSelectElement).value as DomainKey;

    const activities = ACTIVITIES[age]?.[area] ?? [];
    const color = AREA_COLORS[area];
    const areaLabel = AREA_LABELS[area];

    if (!activities.length) {
      resultsEl.style.display = 'block';
      resultsEl.innerHTML = '<p style="color:#7A7573;font-size:0.9375rem">No activities found for this combination.</p>';
      return;
    }

    const cardsHtml = activities.map(act => `
      <div class="activity-card">
        <div class="activity-title">${act.title}</div>
        <div class="activity-desc">${act.desc}</div>
        <div class="activity-meta">
          <span class="activity-tag" style="background:${color}18;color:${color}">${areaLabel}</span>
          <span class="activity-tag materials">Materials: ${act.materials}</span>
        </div>
      </div>
    `).join('');

    resultsEl.style.display = 'block';
    resultsEl.innerHTML = `
      <p class="results-heading">Activities for <span>${(document.getElementById('age-range') as HTMLSelectElement).options[(document.getElementById('age-range') as HTMLSelectElement).selectedIndex].text}</span> · <span style="color:${color}">${areaLabel}</span></p>
      <div class="activities-grid">${cardsHtml}</div>
    `;
    resultsEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  });

  // Trigger initial results on load
  findBtn.click();
