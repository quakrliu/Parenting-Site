---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { getCollection, render } from 'astro:content';
import { useTranslations } from '../../../i18n/utils';

const lang = 'en';
const t = useTranslations(lang);

export async function getStaticPaths() {
  const guides = await getCollection('guides');
  return guides.map((guide) => ({
    params: { slug: guide.id },
    props: { guide },
  }));
}

const { guide } = Astro.props;
const { Content } = await render(guide);
const guideLang = guide.data.lang === 'zh' ? 'zh' : 'en';
---

<BaseLayout
  title={`${guide.data.title} | ${t('site.title')}`}
  description={guide.data.description}
  lang={guideLang}
>
  <Header lang={lang} />

  <main class="guide-page">
    <div class="container">
      <article>
        <header class="guide-header">
          {guide.data.category && <span class="guide-category">{guide.data.category}</span>}
          <h1>{guide.data.title}</h1>
          <p class="guide-description">{guide.data.description}</p>
          <div class="guide-meta">
            <time datetime={guide.data.pubDate.toISOString()}>
              {guide.data.pubDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
            </time>
          </div>
        </header>

        <div class="guide-content">
          <Content />
        </div>
      </article>

      <nav class="guide-nav">
        <a href={`/${lang}/blog`} class="back-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
          Back to Articles
        </a>
      </nav>
    </div>
  </main>

  <Footer lang={lang} />
</BaseLayout>

<style>
  .guide-page { padding: 3rem 0; }
  .guide-header { margin-bottom: 2.5rem; padding-bottom: 2rem; border-bottom: 1px solid rgba(141, 155, 142, 0.1); }
  .guide-category { display: inline-block; font-size: 0.8125rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-forest); background: rgba(141, 155, 142, 0.08); padding: 0.25rem 0.75rem; border-radius: 6px; margin-bottom: 1rem; }
  .guide-header h1 { font-size: clamp(1.75rem, 4vw, 2.75rem); font-weight: 700; line-height: 1.2; letter-spacing: -0.02em; max-width: 70ch; }
  .guide-description { font-size: 1.125rem; color: var(--color-text-light); line-height: 1.6; margin-top: 1rem; max-width: 65ch; }
  .guide-meta { display: flex; align-items: center; gap: 0.625rem; margin-top: 1.25rem; }
  .guide-meta time { font-size: 0.875rem; color: var(--color-text-light); }
  .guide-content { max-width: 72ch; font-size: 1.0625rem; line-height: 1.8; color: var(--color-text); }
  .guide-content :global(h2) { font-size: 1.5rem; font-weight: 700; margin-top: 2.5rem; margin-bottom: 1rem; letter-spacing: -0.01em; }
  .guide-content :global(h3) { font-size: 1.25rem; font-weight: 600; margin-top: 2rem; margin-bottom: 0.75rem; }
  .guide-content :global(p) { margin-bottom: 1.25rem; }
  .guide-content :global(ul), .guide-content :global(ol) { margin-bottom: 1.25rem; padding-left: 1.5rem; }
  .guide-content :global(li) { margin-bottom: 0.375rem; }
  .guide-content :global(blockquote) { border-left: 3px solid var(--color-forest); padding: 0.75rem 1.25rem; margin: 1.5rem 0; background: rgba(141, 155, 142, 0.04); border-radius: 0 8px 8px 0; font-style: italic; color: var(--color-text-light); }
  .guide-content :global(a) { color: var(--color-forest); text-decoration: underline; text-decoration-thickness: 1px; text-underline-offset: 2px; }
  .guide-content :global(strong) { font-weight: 600; color: var(--color-text); }
  .guide-content :global(table) { width: 100%; border-collapse: collapse; margin: 1.5rem 0; font-size: 0.9375rem; }
  .guide-content :global(th), .guide-content :global(td) { padding: 0.75rem 1rem; text-align: left; border-bottom: 1px solid rgba(141, 155, 142, 0.1); }
  .guide-content :global(th) { font-weight: 600; background: rgba(141, 155, 142, 0.04); }
  .guide-nav { margin-top: 3rem; }
  .back-link { display: inline-flex; align-items: center; gap: 0.5rem; font-size: 0.9375rem; font-weight: 500; color: var(--color-forest); text-decoration: none; transition: gap 0.2s ease; }
  .back-link:hover { gap: 0.75rem; color: var(--color-forest-dark); }
</style>
