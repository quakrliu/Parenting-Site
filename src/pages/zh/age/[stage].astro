---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { getCollection } from 'astro:content';
import { useTranslations } from '../../../i18n/utils';

const lang = 'zh';
const t = useTranslations(lang);

const stageInfo: Record<string, { title: string; range: string; desc: string }> = {
  infant: { title: '嬰兒期', range: '0–1 歲', desc: '建立依附關係、餵養、睡眠與信任的基礎。' },
  toddler: { title: '學步期', range: '1–3 歲', desc: '獨立性、語言爆發、大情緒和第一次設界限。' },
  preschool: { title: '學齡前', range: '3–6 歲', desc: '社交技巧、入學準備、創造力和自我調節。' },
  school: { title: '學齡期', range: '6–12 歲', desc: '學習習慣、友誼、螢幕時間和成長中的獨立。' },
  teen: { title: '青少年', range: '12–18 歲', desc: '身分認同、心理健康、數位生活和迎向成年。' },
};

export function getStaticPaths() {
  return ['infant', 'toddler', 'preschool', 'school', 'teen'].map((stage) => ({ params: { stage } }));
}

const { stage } = Astro.params;
const info = stageInfo[stage] || stageInfo.infant;

const allPosts = await getCollection('blog');
const now = new Date();
const posts = allPosts
  .filter((post) => {
    if (post.data.pubDate > now) return false;
    if (post.data.lang && post.data.lang !== 'zh-TW') return false;
    const ag = post.data.ageGroup;
    if (!ag) return true;
    if (Array.isArray(ag)) return ag.includes(stage) || ag.includes('all');
    return ag === stage || ag === 'all';
  })
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title={`${info.title}（${info.range}）| ${t('site.title')}`} description={info.desc} lang={lang}>
  <Header lang={lang} />

  <main class="age-page">
    <div class="container">
      <header class="age-header">
        <a href={`/${lang}/`} class="back-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
          所有年齡
        </a>
        <h1>{info.title}</h1>
        <p class="age-range">{info.range}</p>
        <p class="age-desc">{info.desc}</p>
      </header>

      {posts.length > 0 ? (
        <div class="articles-grid">
          {posts.map((post) => (
            <a href={`/${lang}/blog/${post.id}`} class="article-card">
              <div class="article-meta">
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString('zh-TW', { month: 'long', day: 'numeric', year: 'numeric' })}
                </time>
              </div>
              <h3>{post.data.title}</h3>
              <p>{post.data.description}</p>
            </a>
          ))}
        </div>
      ) : (
        <p class="no-articles">這個年齡段還沒有文章，敬請期待！</p>
      )}
    </div>
  </main>

  <Footer lang={lang} />
</BaseLayout>

<style>
  .age-page { padding: 2rem 0 5rem; }
  .age-header { margin-bottom: 3rem; max-width: 600px; }
  .back-link { display: inline-flex; align-items: center; gap: 0.375rem; font-size: 0.875rem; font-weight: 500; color: var(--color-forest); text-decoration: none; margin-bottom: 1.5rem; }
  .back-link:hover { gap: 0.625rem; }
  .age-header h1 { font-size: 2.5rem; font-weight: 800; letter-spacing: -0.03em; color: var(--color-text); }
  .age-range { font-size: 1.125rem; font-weight: 600; color: var(--color-forest); margin-top: 0.25rem; }
  .age-desc { font-size: 1rem; color: var(--color-text-light); margin-top: 0.5rem; line-height: 1.6; }
  .articles-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.25rem; }
  .article-card { background: var(--color-white); border: 1px solid rgba(141, 155, 142, 0.06); border-radius: 16px; padding: 1.5rem; text-decoration: none; transition: all 0.3s cubic-bezier(0.32, 0.72, 0, 1); }
  .article-card:hover { transform: translateY(-2px); box-shadow: 0 12px 36px -12px rgba(74, 69, 67, 0.08); }
  .article-meta time { font-size: 0.75rem; color: var(--color-text-light); }
  .article-card h3 { font-size: 1.0625rem; font-weight: 700; color: var(--color-text); margin: 0.5rem 0; line-height: 1.3; }
  .article-card p { font-size: 0.875rem; color: var(--color-text-light); line-height: 1.6; margin: 0; }
  .no-articles { color: var(--color-text-light); font-style: italic; padding: 3rem 0; }
  @media (max-width: 768px) { .articles-grid { grid-template-columns: 1fr; } .age-header h1 { font-size: 2rem; } }
</style>
