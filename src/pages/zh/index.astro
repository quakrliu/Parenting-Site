---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';
import { useTranslations } from '../../i18n/utils';

const lang = 'zh';
const t = useTranslations(lang);

const allPosts = await getCollection('blog');
const now = new Date();
const publishedPosts = allPosts
  .filter((post) => post.data.pubDate <= now && post.data.lang === 'zh-TW')
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const featuredPosts = publishedPosts.slice(0, 6);

const categories = [
  { title: t('cat.montessori'), desc: t('cat.montessori.desc'), icon: 'M12 3L4 9v12h16V9l-8-6zm0 3l5 3.75V18h-3v-4h-4v4H7V9.75L12 6z', accent: 'forest' },
  { title: t('cat.positive'), desc: t('cat.positive.desc'), icon: 'M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z', accent: 'orange' },
  { title: t('cat.milestones'), desc: t('cat.milestones.desc'), icon: 'M13 2L3 14h9l-1 8 10-12h-9l1-8z', accent: 'forest' },
  { title: t('cat.home'), desc: t('cat.home.desc'), icon: 'M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z', accent: 'orange' },
  { title: t('cat.reviews'), desc: t('cat.reviews.desc'), icon: 'M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z', accent: 'forest' },
  { title: t('cat.nutrition'), desc: t('cat.nutrition.desc'), icon: 'M18.06 22.99h.01c.35-.01.67-.19.89-.49l.01-.02c.28-.38.4-.85.34-1.32-.06-.47-.26-.9-.57-1.22l-3.6-3.6c-.31-.31-.74-.49-1.18-.49h-1.44l-3.58-3.58c.74-1.54.47-3.42-.8-4.69-1.56-1.56-4.09-1.56-5.66 0-1.56 1.56-1.56 4.09 0 5.66 1.27 1.27 3.15 1.54 4.69.8l3.58 3.58v1.44c0 .44.18.87.49 1.18l3.6 3.6c.32.31.75.51 1.22.57.47.06.94-.06 1.32-.34z', accent: 'orange' },
];

const windows = [
  { title: t('windows.language.title'), age: t('windows.language.age'), desc: t('windows.language.desc'), color: 'forest' },
  { title: t('windows.movement.title'), age: t('windows.movement.age'), desc: t('windows.movement.desc'), color: 'orange' },
  { title: t('windows.order.title'), age: t('windows.order.age'), desc: t('windows.order.desc'), color: 'forest' },
  { title: t('windows.social.title'), age: t('windows.social.age'), desc: t('windows.social.desc'), color: 'orange' },
];
---

<BaseLayout title={`${t('site.title')} | ${t('site.tagline')}`} description={t('site.description')} lang={lang}>
  <Header lang={lang} />

  <!-- HERO: Asymmetric split layout, desktop-first -->
  <section class="hp-hero">
    <div class="container hp-hero__grid">
      <div class="hp-hero__content">
        <span class="hp-eyebrow">{t('hero.badge')}</span>
        <h1 set:html={t('hero.heading')} />
        <p class="hp-hero__desc">{t('hero.desc')}</p>
        <div class="hp-hero__actions">
          <a href={`/${lang}/blog`} class="hp-btn hp-btn--primary">
            {t('hero.cta.articles')}
            <span class="hp-btn__arrow" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </span>
          </a>
          <a href="#newsletter" class="hp-btn hp-btn--ghost">{t('hero.cta.newsletter')}</a>
        </div>
        <div class="hp-hero__trust">
          <div class="hp-trust-item">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <span>{t('hero.trust.evidence')}</span>
          </div>
          <div class="hp-trust-item">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <span>{t('hero.trust.parents')}</span>
          </div>
          <div class="hp-trust-item">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <span>{t('hero.trust.free')}</span>
          </div>
        </div>
      </div>
      <div class="hp-hero__visual" aria-hidden="true">
        <div class="hp-hero__logo-ring">
          <img src="/logo.png" alt="" width="120" height="120" loading="eager" />
        </div>
        <div class="hp-hero__float hp-hero__float--1">
          <div class="hp-hero__float-icon hp-hero__float-icon--forest">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#2D6A4F" stroke-width="2" stroke-linecap="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <span>{t('hero.card.trusted')}</span>
        </div>
        <div class="hp-hero__float hp-hero__float--2">
          <div class="hp-hero__float-icon hp-hero__float-icon--orange">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#F4A261" stroke-width="2" stroke-linecap="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
          </div>
          <span>{t('hero.card.milestones')}</span>
        </div>
        <div class="hp-hero__orb hp-hero__orb--1"></div>
        <div class="hp-hero__orb hp-hero__orb--2"></div>
        <div class="hp-hero__orb hp-hero__orb--3"></div>
      </div>
    </div>
  </section>

  <!-- PHILOSOPHY: Asymmetric two-card layout -->
  <section class="hp-philosophy">
    <div class="container">
      <div class="hp-section-header">
        <span class="hp-eyebrow">{t('section.philosophy')}</span>
        <h2>{t('section.philosophy.title')}</h2>
        <p class="hp-section-desc">{t('section.philosophy.desc')}</p>
      </div>
      <div class="hp-philosophy__grid">
        <div class="hp-philosophy__card hp-philosophy__card--montessori">
          <div class="hp-philosophy__icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#2D6A4F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>
            </svg>
          </div>
          <h3>{t('philosophy.montessori.title')}</h3>
          <p>{t('philosophy.montessori.desc')}</p>
          <ul class="hp-philosophy__points">
            <li>{t('philosophy.montessori.point1')}</li>
            <li>{t('philosophy.montessori.point2')}</li>
            <li>{t('philosophy.montessori.point3')}</li>
          </ul>
        </div>
        <div class="hp-philosophy__card hp-philosophy__card--positive">
          <div class="hp-philosophy__icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#F4A261" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
            </svg>
          </div>
          <h3>{t('philosophy.positive.title')}</h3>
          <p>{t('philosophy.positive.desc')}</p>
          <ul class="hp-philosophy__points">
            <li>{t('philosophy.positive.point1')}</li>
            <li>{t('philosophy.positive.point2')}</li>
            <li>{t('philosophy.positive.point3')}</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- TOPICS: Bento grid -->
  <section id="categories" class="hp-topics">
    <div class="container">
      <div class="hp-section-header">
        <span class="hp-eyebrow">{t('section.topics')}</span>
        <h2>{t('section.topics.title')}</h2>
        <p class="hp-section-desc">{t('section.topics.desc')}</p>
      </div>
      <div class="hp-topics__bento">
        {categories.map((cat, i) => (
          <div class={`hp-topics__tile hp-topics__tile--${i + 1}`}>
            <div class={`hp-topics__icon hp-topics__icon--${cat.accent}`}>
              <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" opacity="0.85"><path d={cat.icon}/></svg>
            </div>
            <h3>{cat.title}</h3>
            <p>{cat.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FEATURED ARTICLES: Asymmetric grid -->
  {featuredPosts.length > 0 && (
    <section class="hp-articles">
      <div class="container">
        <div class="hp-section-header">
          <span class="hp-eyebrow">{t('section.latest')}</span>
          <h2>{t('section.latest.title')}</h2>
          <p class="hp-section-desc">{t('section.latest.desc')}</p>
        </div>
        <div class="hp-articles__grid">
          {featuredPosts.map((post, i) => (
            <article class={`hp-articles__card ${i === 0 ? 'hp-articles__card--hero' : ''}`}>
              <div class="hp-articles__meta">
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString('zh-TW', { month: 'short', day: 'numeric', year: 'numeric' })}
                </time>
              </div>
              <h3><a href={`/${lang}/blog/${post.id}`}>{post.data.title}</a></h3>
              <p>{post.data.description}</p>
              {post.data.tags && post.data.tags.length > 0 && (
                <div class="hp-articles__tags">
                  {post.data.tags.slice(0, 3).map((tag: string) => (<span class="hp-tag">{tag}</span>))}
                </div>
              )}
            </article>
          ))}
        </div>
        <div class="hp-section-cta">
          <a href={`/${lang}/blog`} class="hp-btn hp-btn--ghost">{t('section.latest.viewAll')}</a>
        </div>
      </div>
    </section>
  )}

  <!-- DEVELOPMENTAL WINDOWS + TOOLS: Side by side on desktop -->
  <section class="hp-growth">
    <div class="container">
      <div class="hp-growth__layout">
        <!-- Left: Developmental Windows -->
        <div class="hp-growth__windows">
          <div class="hp-section-header">
            <span class="hp-eyebrow">{t('section.windows')}</span>
            <h2>{t('section.windows.title')}</h2>
            <p class="hp-section-desc">{t('section.windows.desc')}</p>
          </div>
          <div class="hp-windows__stack">
            {windows.map((w) => (
              <div class={`hp-windows__card hp-windows__card--${w.color}`}>
                <div class="hp-windows__age">{w.age}</div>
                <h3>{w.title}</h3>
                <p>{w.desc}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Right: Tools Preview -->
        <div class="hp-growth__tools" id="tools">
          <div class="hp-section-header">
            <span class="hp-eyebrow">{t('section.tools')}</span>
            <h2>{t('section.tools.title')}</h2>
            <p class="hp-section-desc">{t('section.tools.desc')}</p>
          </div>
          <div class="hp-tools__stack">
            <div class="hp-tools__card">
              <div class="hp-tools__badge">{t('section.tools.badge')}</div>
              <div class="hp-tools__card-icon hp-tools__card-icon--forest">
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><path d="M8 14l2 2 4-4"/></svg>
              </div>
              <h3>{t('section.tools.milestone')}</h3>
              <p>{t('section.tools.milestone.desc')}</p>
            </div>
            <div class="hp-tools__card">
              <div class="hp-tools__badge">{t('section.tools.badge')}</div>
              <div class="hp-tools__card-icon hp-tools__card-icon--orange">
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="M8 12l2 2 4-4"/></svg>
              </div>
              <h3>{t('section.tools.activity')}</h3>
              <p>{t('section.tools.activity.desc')}</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- NEWSLETTER -->
  <section id="newsletter" class="hp-newsletter">
    <div class="container">
      <div class="hp-newsletter__inner">
        <div class="hp-newsletter__content">
          <span class="hp-eyebrow hp-eyebrow--light">{t('section.newsletter')}</span>
          <h2>{t('section.newsletter.title')}</h2>
          <p>{t('section.newsletter.desc')}</p>
        </div>
        <div class="hp-newsletter__form">
          <p class="hp-newsletter__placeholder">{t('section.newsletter.placeholder')}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ABOUT: Split layout -->
  <section id="about" class="hp-about">
    <div class="container">
      <div class="hp-about__inner">
        <div class="hp-about__content">
          <span class="hp-eyebrow">{t('section.about')}</span>
          <h2>{t('section.about.title')}</h2>
          <p>{t('section.about.p1')}</p>
          <p>{t('section.about.p2')}</p>
          <div class="hp-about__values">
            <div class="hp-about__value">
              <strong>{t('section.about.evidence')}</strong>
              <span>{t('section.about.evidence.desc')}</span>
            </div>
            <div class="hp-about__value">
              <strong>{t('section.about.practical')}</strong>
              <span>{t('section.about.practical.desc')}</span>
            </div>
            <div class="hp-about__value">
              <strong>{t('section.about.inclusive')}</strong>
              <span>{t('section.about.inclusive.desc')}</span>
            </div>
          </div>
        </div>
        <div class="hp-about__visual" aria-hidden="true">
          <div class="hp-about__badge-ring">
            <img src="/logo.png" alt="" width="80" height="80" loading="lazy" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer lang={lang} />
</BaseLayout>

<style>
  /* ================================================
     BLOOMPATH HOMEPAGE ZH — DESKTOP-FIRST PREMIUM DESIGN
     Same layout as EN, styles are scoped per page.
     ================================================ */

  /* ===== SHARED TOKENS ===== */
  .hp-eyebrow {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-orange);
    background: rgba(244, 162, 97, 0.1);
    padding: 0.3125rem 0.875rem;
    border-radius: 100px;
    margin-bottom: 0.875rem;
  }

  .hp-eyebrow--light {
    background: rgba(244, 162, 97, 0.2);
    color: var(--color-orange);
  }

  .hp-section-header { margin-bottom: 3.5rem; }

  .hp-section-header h2 {
    font-size: 2.75rem;
    font-weight: 800;
    letter-spacing: -0.035em;
    color: var(--color-text);
    line-height: 1.1;
  }

  .hp-section-desc {
    font-size: 1.0625rem;
    color: var(--color-text-light);
    margin-top: 0.75rem;
    max-width: 55ch;
    line-height: 1.65;
  }

  .hp-section-cta {
    text-align: center;
    margin-top: 3rem;
  }

  /* ===== BUTTONS ===== */
  .hp-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9375rem;
    font-weight: 600;
    padding: 0.8125rem 1.75rem;
    border-radius: 12px;
    border: none;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.32, 0.72, 0, 1);
    cursor: pointer;
  }

  .hp-btn:active { transform: translateY(1px) scale(0.98); }

  .hp-btn--primary {
    background: var(--color-forest);
    color: var(--color-white);
  }

  .hp-btn--primary:hover {
    background: var(--color-forest-dark);
    color: var(--color-white);
    transform: translateY(-1px);
    box-shadow: 0 8px 24px -8px rgba(45, 106, 79, 0.3);
  }

  .hp-btn__arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.15);
    transition: all 0.3s cubic-bezier(0.32, 0.72, 0, 1);
  }

  .hp-btn--primary:hover .hp-btn__arrow {
    transform: translateX(2px);
    background: rgba(255, 255, 255, 0.25);
  }

  .hp-btn--ghost {
    background: transparent;
    color: var(--color-forest);
    border: 1.5px solid rgba(45, 106, 79, 0.25);
  }

  .hp-btn--ghost:hover {
    border-color: var(--color-forest);
    background: rgba(45, 106, 79, 0.04);
    color: var(--color-forest);
  }

  /* ===== HERO ===== */
  .hp-hero {
    padding: 6rem 0 7rem;
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(ellipse 80% 60% at 75% 40%, rgba(45, 106, 79, 0.04) 0%, transparent 70%),
      radial-gradient(ellipse 60% 50% at 20% 80%, rgba(244, 162, 97, 0.04) 0%, transparent 70%),
      linear-gradient(170deg, var(--color-bg) 40%, var(--color-cream) 100%);
  }

  .hp-hero__grid {
    display: grid;
    grid-template-columns: 52% 48%;
    gap: 4rem;
    align-items: center;
  }

  .hp-hero__content { padding-right: 2rem; }

  .hp-hero h1 {
    font-size: 3.5rem;
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--color-text);
    text-wrap: balance;
  }

  .hp-hero__desc {
    font-size: 1.125rem;
    color: var(--color-text-light);
    line-height: 1.8;
    max-width: 50ch;
    margin-top: 1.5rem;
  }

  .hp-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.875rem;
    margin-top: 2.25rem;
  }

  .hp-hero__trust {
    display: flex;
    gap: 1.5rem;
    margin-top: 2.25rem;
    padding-top: 1.75rem;
    border-top: 1px solid rgba(45, 106, 79, 0.08);
  }

  .hp-trust-item {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-text-light);
  }

  .hp-trust-item svg { color: var(--color-forest); flex-shrink: 0; }

  /* Hero Visual */
  .hp-hero__visual {
    position: relative;
    min-height: 420px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hp-hero__logo-ring {
    width: 180px;
    height: 180px;
    border-radius: 50%;
    background: var(--color-white);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow:
      0 0 0 1px rgba(45, 106, 79, 0.08),
      0 24px 64px -16px rgba(45, 106, 79, 0.12);
    position: relative;
    z-index: 2;
  }

  .hp-hero__logo-ring img {
    width: 120px;
    height: 120px;
    object-fit: contain;
  }

  .hp-hero__float {
    position: absolute;
    background: var(--color-white);
    border: 1px solid rgba(45, 106, 79, 0.08);
    border-radius: 16px;
    padding: 0.875rem 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text);
    box-shadow: 0 12px 40px -12px rgba(0, 0, 0, 0.06);
    z-index: 3;
  }

  .hp-hero__float-icon {
    width: 38px;
    height: 38px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .hp-hero__float-icon--forest { background: rgba(45, 106, 79, 0.08); }
  .hp-hero__float-icon--orange { background: rgba(244, 162, 97, 0.12); }

  .hp-hero__float--1 {
    top: 40px;
    right: 0;
    animation: hp-float 7s ease-in-out infinite;
  }

  .hp-hero__float--2 {
    bottom: 60px;
    left: 10px;
    animation: hp-float 7s ease-in-out infinite;
    animation-delay: -3.5s;
  }

  .hp-hero__orb {
    position: absolute;
    border-radius: 50%;
    z-index: 1;
  }

  .hp-hero__orb--1 {
    width: 320px;
    height: 320px;
    background: radial-gradient(circle, rgba(45, 106, 79, 0.07) 0%, transparent 70%);
    top: -20px;
    right: 20px;
    animation: hp-breathe 8s ease-in-out infinite;
  }

  .hp-hero__orb--2 {
    width: 200px;
    height: 200px;
    background: radial-gradient(circle, rgba(244, 162, 97, 0.1) 0%, transparent 70%);
    bottom: 20px;
    right: 140px;
    animation: hp-breathe 8s ease-in-out infinite;
    animation-delay: -4s;
  }

  .hp-hero__orb--3 {
    width: 130px;
    height: 130px;
    background: radial-gradient(circle, rgba(254, 250, 224, 0.35) 0%, transparent 70%);
    top: 100px;
    left: 20px;
    animation: hp-breathe 6s ease-in-out infinite;
    animation-delay: -2s;
  }

