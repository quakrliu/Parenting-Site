---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';
import { useTranslations } from '../../i18n/utils';

const lang = 'zh';
const t = useTranslations(lang);

const allPosts = await getCollection('blog');
const now = new Date();
const publishedPosts = allPosts
  .filter((post) => post.data.pubDate <= now && post.data.lang === 'zh-TW')
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const featuredPosts = publishedPosts.slice(0, 4);

const categories = [
  { title: t('cat.montessori'), desc: t('cat.montessori.desc'), icon: 'M12 3L4 9v12h16V9l-8-6zm0 3l5 3.75V18h-3v-4h-4v4H7V9.75L12 6z' },
  { title: t('cat.positive'), desc: t('cat.positive.desc'), icon: 'M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z' },
  { title: t('cat.milestones'), desc: t('cat.milestones.desc'), icon: 'M13 2L3 14h9l-1 8 10-12h-9l1-8z' },
  { title: t('cat.home'), desc: t('cat.home.desc'), icon: 'M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z' },
  { title: t('cat.reviews'), desc: t('cat.reviews.desc'), icon: 'M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z' },
  { title: t('cat.nutrition'), desc: t('cat.nutrition.desc'), icon: 'M18.06 22.99h.01c.35-.01.67-.19.89-.49l.01-.02c.28-.38.4-.85.34-1.32-.06-.47-.26-.9-.57-1.22l-3.6-3.6c-.31-.31-.74-.49-1.18-.49h-1.44l-3.58-3.58c.74-1.54.47-3.42-.8-4.69-1.56-1.56-4.09-1.56-5.66 0-1.56 1.56-1.56 4.09 0 5.66 1.27 1.27 3.15 1.54 4.69.8l3.58 3.58v1.44c0 .44.18.87.49 1.18l3.6 3.6c.32.31.75.51 1.22.57.47.06.94-.06 1.32-.34z' },
];
---

<BaseLayout title={`${t('site.title')} | ${t('site.tagline')}`} description={t('site.description')} lang={lang}>
  <Header lang={lang} />

  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-content">
        <span class="hero-badge">{t('hero.badge')}</span>
        <h1 set:html={t('hero.heading')} />
        <p class="hero-desc">{t('hero.desc')}</p>
        <div class="hero-actions">
          <a href={`/${lang}/blog`} class="btn btn-primary">{t('hero.cta.articles')}</a>
          <a href="#newsletter" class="btn btn-outline">{t('hero.cta.newsletter')}</a>
        </div>
        <div class="hero-trust">
          <div class="trust-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <span>{t('hero.trust.evidence')}</span>
          </div>
          <div class="trust-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <span>{t('hero.trust.parents')}</span>
          </div>
          <div class="trust-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <span>{t('hero.trust.free')}</span>
          </div>
        </div>
      </div>
      <div class="hero-visual">
        <div class="hero-shape hero-shape-1"></div>
        <div class="hero-shape hero-shape-2"></div>
        <div class="hero-shape hero-shape-3"></div>
        <div class="hero-card floating">
          <div class="card-icon"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#2D6A4F" stroke-width="2" stroke-linecap="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div>
          <span>{t('hero.card.trusted')}</span>
        </div>
        <div class="hero-card floating-delayed">
          <div class="card-icon"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#F4A261" stroke-width="2" stroke-linecap="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg></div>
          <span>{t('hero.card.milestones')}</span>
        </div>
      </div>
    </div>
  </section>

  <section id="categories" class="categories">
    <div class="container">
      <div class="section-header">
        <span class="section-label">{t('section.topics')}</span>
        <h2>{t('section.topics.title')}</h2>
        <p class="section-desc">{t('section.topics.desc')}</p>
      </div>
      <div class="categories-grid">
        {categories.map((cat, i) => (
          <div class="category-item" style={`--delay: ${i * 0.08}s`}>
            <div class="category-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="var(--color-forest)" opacity="0.8"><path d={cat.icon}/></svg>
            </div>
            <div class="category-text">
              <h3>{cat.title}</h3>
              <p>{cat.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {featuredPosts.length > 0 && (
    <section class="featured">
      <div class="container">
        <div class="section-header">
          <span class="section-label">{t('section.latest')}</span>
          <h2>{t('section.latest.title')}</h2>
          <p class="section-desc">{t('section.latest.desc')}</p>
        </div>
        <div class="articles-grid">
          {featuredPosts.map((post, i) => (
            <article class="article-card" style={`--delay: ${i * 0.1}s`}>
              <div class="article-meta">
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString('zh-TW', { month: 'short', day: 'numeric', year: 'numeric' })}
                </time>
              </div>
              <h3><a href={`/${lang}/blog/${post.id}`}>{post.data.title}</a></h3>
              <p>{post.data.description}</p>
              {post.data.tags && post.data.tags.length > 0 && (
                <div class="article-tags">
                  {post.data.tags.slice(0, 3).map((tag: string) => (<span class="tag">{tag}</span>))}
                </div>
              )}
            </article>
          ))}
        </div>
        <div class="section-cta">
          <a href={`/${lang}/blog`} class="btn btn-outline">{t('section.latest.viewAll')}</a>
        </div>
      </div>
    </section>
  )}

  <section id="tools" class="tools">
    <div class="container">
      <div class="section-header">
        <span class="section-label">{t('section.tools')}</span>
        <h2>{t('section.tools.title')}</h2>
        <p class="section-desc">{t('section.tools.desc')}</p>
      </div>
      <div class="tools-grid">
        <div class="tool-card">
          <div class="tool-badge">{t('section.tools.badge')}</div>
          <div class="tool-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-forest)" stroke-width="1.5" stroke-linecap="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><path d="M8 14l2 2 4-4"/></svg>
          </div>
          <h3>{t('section.tools.milestone')}</h3>
          <p>{t('section.tools.milestone.desc')}</p>
        </div>
        <div class="tool-card">
          <div class="tool-badge">{t('section.tools.badge')}</div>
          <div class="tool-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-orange)" stroke-width="1.5" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="M8 12l2 2 4-4"/></svg>
          </div>
          <h3>{t('section.tools.activity')}</h3>
          <p>{t('section.tools.activity.desc')}</p>
        </div>
      </div>
    </div>
  </section>

  <section id="newsletter" class="newsletter">
    <div class="container">
      <div class="newsletter-inner">
        <div class="newsletter-content">
          <span class="section-label">{t('section.newsletter')}</span>
          <h2>{t('section.newsletter.title')}</h2>
          <p>{t('section.newsletter.desc')}</p>
        </div>
        <div class="newsletter-form-area">
          <p class="newsletter-placeholder">{t('section.newsletter.placeholder')}</p>
        </div>
      </div>
    </div>
  </section>

  <section id="about" class="about">
    <div class="container">
      <div class="about-inner">
        <div class="about-content">
          <span class="section-label">{t('section.about')}</span>
          <h2>{t('section.about.title')}</h2>
          <p>{t('section.about.p1')}</p>
          <p>{t('section.about.p2')}</p>
          <div class="about-values">
            <div class="value">
              <strong>{t('section.about.evidence')}</strong>
              <span>{t('section.about.evidence.desc')}</span>
            </div>
            <div class="value">
              <strong>{t('section.about.practical')}</strong>
              <span>{t('section.about.practical.desc')}</span>
            </div>
            <div class="value">
              <strong>{t('section.about.inclusive')}</strong>
              <span>{t('section.about.inclusive.desc')}</span>
            </div>
          </div>
        </div>
        <div class="about-visual">
          <div class="about-shape"></div>
        </div>
      </div>
    </div>
  </section>

  <Footer lang={lang} />
</BaseLayout>

<style>
  .hero { padding: 4rem 0 5rem; position: relative; overflow: hidden; background: linear-gradient(135deg, var(--color-bg) 60%, var(--color-cream) 100%); }
  .hero-inner { display: grid; grid-template-columns: 1fr; gap: 3rem; align-items: center; }
  .hero-badge { display: inline-block; font-size: 0.8125rem; font-weight: 600; letter-spacing: 0.04em; color: var(--color-forest); background: rgba(45, 106, 79, 0.08); padding: 0.375rem 1rem; border-radius: 100px; margin-bottom: 1.25rem; }
  .hero h1 { font-size: clamp(2.25rem, 5vw, 3.75rem); font-weight: 800; line-height: 1.1; letter-spacing: -0.03em; color: var(--color-text); }
  .hero-desc { font-size: 1.0625rem; color: var(--color-text-light); line-height: 1.7; max-width: 50ch; margin-top: 1.25rem; }
  .hero-actions { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 2rem; }
  .btn { display: inline-flex; align-items: center; font-size: 0.9375rem; font-weight: 600; padding: 0.75rem 1.5rem; border-radius: 10px; border: none; text-decoration: none; transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1); }
  .btn:active { transform: translateY(1px) scale(0.98); }
  .btn-primary { background: var(--color-forest); color: var(--color-white); }
  .btn-primary:hover { background: var(--color-forest-dark); color: var(--color-white); }
  .btn-outline { background: transparent; color: var(--color-forest); border: 1.5px solid var(--color-forest); }
  .btn-outline:hover { background: var(--color-forest); color: var(--color-white); }
  .hero-trust { display: flex; flex-wrap: wrap; gap: 1.25rem; margin-top: 2rem; }
  .trust-item { display: flex; align-items: center; gap: 0.375rem; font-size: 0.8125rem; color: var(--color-text-light); }
  .trust-item svg { color: var(--color-forest); flex-shrink: 0; }
  .hero-visual { position: relative; min-height: 280px; display: none; }
  .hero-shape { position: absolute; border-radius: 50%; }
  .hero-shape-1 { width: 320px; height: 320px; background: radial-gradient(circle, rgba(45, 106, 79, 0.08) 0%, transparent 70%); top: -20px; right: 20px; }
  .hero-shape-2 { width: 200px; height: 200px; background: radial-gradient(circle, rgba(244, 162, 97, 0.1) 0%, transparent 70%); bottom: 20px; right: 140px; }
  .hero-shape-3 { width: 120px; height: 120px; background: radial-gradient(circle, rgba(45, 106, 79, 0.06) 0%, transparent 70%); top: 60px; left: 20px; }
  .hero-card { position: absolute; background: var(--color-white); border: 1px solid rgba(45, 106, 79, 0.1); border-radius: 16px; padding: 1.25rem 1.5rem; display: flex; align-items: center; gap: 0.875rem; box-shadow: 0 8px 30px -10px rgba(0, 0, 0, 0.06); font-size: 0.9375rem; font-weight: 500; color: var(--color-text); }
  .hero-card .card-icon { width: 44px; height: 44px; border-radius: 12px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .hero-card:nth-child(4) .card-icon { background: rgba(45, 106, 79, 0.08); }
  .hero-card:nth-child(5) .card-icon { background: rgba(244, 162, 97, 0.12); }
  .floating { top: 40px; right: 40px; animation: float 6s ease-in-out infinite; }
  .floating-delayed { bottom: 60px; left: 20px; animation: float 6s ease-in-out infinite; animation-delay: -3s; }
  @keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-12px); } }
  .section-header { margin-bottom: 3rem; }
  .section-label { display: inline-block; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-orange); margin-bottom: 0.5rem; }
  .section-header h2 { font-size: clamp(1.75rem, 3.5vw, 2.5rem); font-weight: 700; letter-spacing: -0.02em; color: var(--color-text); line-height: 1.2; }
  .section-desc { font-size: 1rem; color: var(--color-text-light); margin-top: 0.625rem; max-width: 55ch; line-height: 1.6; }
  .section-cta { text-align: center; margin-top: 2.5rem; }
  .categories { padding: 5rem 0; }
  .categories-grid { display: grid; grid-template-columns: 1fr; gap: 1px; background: rgba(45, 106, 79, 0.08); border-radius: 20px; overflow: hidden; }
  .category-item { display: flex; gap: 1.25rem; padding: 1.75rem; background: var(--color-white); transition: background 0.2s ease; }
  .category-item:hover { background: var(--color-cream); }
  .category-icon { width: 48px; height: 48px; border-radius: 14px; background: rgba(45, 106, 79, 0.06); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .category-text h3 { font-size: 1.0625rem; font-weight: 600; color: var(--color-text); line-height: 1.3; }
  .category-text p { font-size: 0.9375rem; color: var(--color-text-light); line-height: 1.6; margin-top: 0.375rem; }
  .featured { padding: 5rem 0; background: var(--color-cream); }
  .articles-grid { display: grid; grid-template-columns: 1fr; gap: 1.25rem; }
  .article-card { background: var(--color-white); border-radius: 16px; padding: 1.75rem; border: 1px solid rgba(45, 106, 79, 0.06); transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1); }
  .article-card:hover { border-color: rgba(45, 106, 79, 0.15); box-shadow: 0 8px 30px -10px rgba(45, 106, 79, 0.08); }
  .article-meta { display: flex; align-items: center; gap: 0.625rem; margin-bottom: 0.75rem; }
  .article-meta time { font-size: 0.8125rem; color: var(--color-text-light); }
  .article-card h3 { font-size: 1.125rem; font-weight: 600; line-height: 1.4; letter-spacing: -0.01em; }
  .article-card h3 a { color: var(--color-text); text-decoration: none; }
  .article-card h3 a:hover { color: var(--color-forest); }
  .article-card p { font-size: 0.9375rem; color: var(--color-text-light); line-height: 1.6; margin-top: 0.5rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .article-tags { display: flex; flex-wrap: wrap; gap: 0.375rem; margin-top: 0.875rem; }
  .tag { font-size: 0.75rem; color: var(--color-text-light); background: rgba(45, 106, 79, 0.05); padding: 0.1875rem 0.625rem; border-radius: 6px; }
  .tools { padding: 5rem 0; }
  .tools-grid { display: grid; grid-template-columns: 1fr; gap: 1.5rem; }
  .tool-card { position: relative; background: var(--color-white); border: 1px solid rgba(45, 106, 79, 0.08); border-radius: 20px; padding: 2.5rem 2rem; transition: all 0.25s ease; }
  .tool-card:hover { border-color: rgba(45, 106, 79, 0.15); box-shadow: 0 12px 40px -15px rgba(45, 106, 79, 0.08); }
  .tool-badge { position: absolute; top: 1.25rem; right: 1.25rem; font-size: 0.6875rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--color-orange-dark); background: rgba(244, 162, 97, 0.12); padding: 0.25rem 0.75rem; border-radius: 6px; }
  .tool-icon { width: 56px; height: 56px; border-radius: 16px; background: rgba(45, 106, 79, 0.06); display: flex; align-items: center; justify-content: center; margin-bottom: 1.25rem; }
  .tool-card:nth-child(2) .tool-icon { background: rgba(244, 162, 97, 0.1); }
  .tool-card h3 { font-size: 1.25rem; font-weight: 600; margin-bottom: 0.5rem; }
  .tool-card p { font-size: 0.9375rem; color: var(--color-text-light); line-height: 1.6; max-width: 45ch; }
  .newsletter { padding: 5rem 0; background: var(--color-forest-dark); color: var(--color-white); }
  .newsletter-inner { display: grid; grid-template-columns: 1fr; gap: 2.5rem; align-items: center; }
  .newsletter .section-label { color: var(--color-orange); }
  .newsletter h2 { color: var(--color-white); font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 700; letter-spacing: -0.02em; }
  .newsletter-content p { color: rgba(255, 255, 255, 0.7); font-size: 1rem; line-height: 1.7; margin-top: 0.75rem; max-width: 45ch; }
  .newsletter-placeholder { background: rgba(255, 255, 255, 0.08); border: 1px dashed rgba(255, 255, 255, 0.2); border-radius: 12px; padding: 2rem; text-align: center; color: rgba(255, 255, 255, 0.5); font-size: 0.9375rem; }
  .about { padding: 5rem 0; }
  .about-inner { display: grid; grid-template-columns: 1fr; gap: 3rem; align-items: center; }
  .about h2 { font-size: clamp(1.5rem, 3vw, 2rem); line-height: 1.25; }
  .about-content p { font-size: 1rem; color: var(--color-text-light); line-height: 1.7; margin-top: 1rem; max-width: 55ch; }
  .about-values { display: flex; flex-direction: column; gap: 1rem; margin-top: 2rem; padding-top: 2rem; border-top: 1px solid rgba(45, 106, 79, 0.1); }
  .value { display: flex; flex-direction: column; gap: 0.125rem; }
  .value strong { font-size: 0.9375rem; font-weight: 600; color: var(--color-forest); }
  .value span { font-size: 0.875rem; color: var(--color-text-light); }
  .about-visual { display: none; }
  .about-shape { width: 300px; height: 300px; border-radius: 50%; background: radial-gradient(circle, rgba(45, 106, 79, 0.06) 0%, rgba(244, 162, 97, 0.04) 50%, transparent 70%); }
  @media (min-width: 640px) { .categories-grid { grid-template-columns: repeat(2, 1fr); } .articles-grid { grid-template-columns: repeat(2, 1fr); } .tools-grid { grid-template-columns: repeat(2, 1fr); } .about-values { flex-direction: row; gap: 2rem; } }
  @media (min-width: 768px) { .hero { padding: 6rem 0 7rem; } .hero-inner { grid-template-columns: 1fr 1fr; } .hero-visual { display: block; } .newsletter-inner { grid-template-columns: 1fr 1fr; } .about-inner { grid-template-columns: 3fr 2fr; } .about-visual { display: flex; justify-content: center; } }
  @media (min-width: 1024px) { .categories-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (min-width: 1280px) { .hero-inner { grid-template-columns: 55% 45%; } }
</style>
