---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import AlertBanner from '../../components/AlertBanner.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';
import { useTranslations } from '../../i18n/utils';

const lang = 'zh';
const t = useTranslations(lang);

const allPosts = await getCollection('blog');
const now = new Date();
const publishedPosts = allPosts
  .filter((post) => post.data.pubDate <= now && post.data.lang === 'zh-TW')
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const featuredPosts = publishedPosts.slice(0, 4);

const ageGroups = [
  { key: '0-6m', icon: 'M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 15h-2v-2h2v2zm0-4h-2V7h2v6z' },
  { key: '6-12m', icon: 'M13.5 1.515a3 3 0 0 0-3 0L3.36 5.5a3 3 0 0 0-1.5 2.598v7.803a3 3 0 0 0 1.5 2.598l7.14 4.118a3 3 0 0 0 3 0l7.14-4.118a3 3 0 0 0 1.5-2.598V8.098a3 3 0 0 0-1.5-2.598L13.5 1.515z' },
  { key: '1-2y', icon: 'M12 3v10.55c-.59-.34-1.27-.55-2-.55-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z' },
  { key: '2-3y', icon: 'M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2z' },
  { key: '3-6y', icon: 'M5 13.18v4L12 21l7-3.82v-4L12 17l-7-3.82zM12 3L1 9l11 6 9-4.91V17h2V9L12 3z' },
];

const categories = [
  { title: t('cat.montessori'), desc: t('cat.montessori.desc'), href: `/${lang}/guides/montessori-ju-jia-zhinan`, accent: 'forest' },
  { title: t('cat.positive'), desc: t('cat.positive.desc'), href: `/${lang}/guides/zheng-xiang-jiao-yang-zhinan`, accent: 'orange' },
  { title: t('cat.milestones'), desc: t('cat.milestones.desc'), href: `/${lang}/guides/fa-zhan-li-cheng-bei-zhinan`, accent: 'forest' },
  { title: t('cat.home'), desc: t('cat.home.desc'), href: `/${lang}/guides/ju-jia-huan-jing-she-ji`, accent: 'orange' },
  { title: t('cat.reviews'), desc: t('cat.reviews.desc'), href: `/${lang}/guides/chan-pin-ping-ce-zhinan`, accent: 'forest' },
  { title: t('cat.nutrition'), desc: t('cat.nutrition.desc'), href: `/${lang}/guides/ying-er-ying-yang-jian-kang`, accent: 'orange' },
];
---

<BaseLayout title={`${t('site.title')} | ${t('site.tagline')}`} description={t('site.description')} lang={lang}>
  <Header lang={lang} />
  <AlertBanner lang={lang} />

  <!-- HERO -->
  <section class="hp-hero">
    <div class="hp-hero__grid">
      <div class="hp-hero__content">
        <span class="hp-eyebrow">{t('hero.badge')}</span>
        <h1 set:html={t('hero.heading')} />
        <p class="hp-hero__desc">{t('hero.desc')}</p>
        <div class="hp-hero__actions">
          <a href={`/${lang}/blog`} class="hp-btn hp-btn--primary">
            {t('hero.cta.articles')}
            <span class="hp-btn__arrow" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </span>
          </a>
          <a href="#newsletter" class="hp-btn hp-btn--ghost">{t('hero.cta.newsletter')}</a>
        </div>
        <div class="hp-hero__trust">
          <div class="hp-trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <span>{t('hero.trust.evidence')}</span>
          </div>
          <div class="hp-trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <span>{t('hero.trust.parents')}</span>
          </div>
          <div class="hp-trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <span>{t('hero.trust.free')}</span>
          </div>
        </div>
      </div>
      <div class="hp-hero__visual">
        <div class="hp-hero__img-wrapper">
          <img
            src="/images/hero-family.jpg"
            alt="Parent reading with child in a warm, natural setting"
            width="720"
            height="540"
            loading="eager"
          />
        </div>
        <div class="hp-hero__badge hp-hero__badge--1">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#8D9B8E" stroke-width="2" stroke-linecap="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <span>{t('hero.card.trusted')}</span>
        </div>
        <div class="hp-hero__badge hp-hero__badge--2">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#C4A882" stroke-width="2" stroke-linecap="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
          <span>{t('hero.card.milestones')}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- AGE NAVIGATOR -->
  <section class="hp-ages">
    <div class="container">
      <div class="hp-section-header">
        <span class="hp-eyebrow">{t('age.section')}</span>
        <h2>{t('age.section.title')}</h2>
        <p class="hp-section-desc">{t('age.section.desc')}</p>
      </div>
      <div class="hp-ages__grid">
        {ageGroups.map((ag) => (
          <a href={`/${lang}/blog`} class="hp-ages__card">
            <div class="hp-ages__icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" opacity="0.7"><path d={ag.icon}/></svg>
            </div>
            <span class="hp-ages__label">{t(`age.${ag.key}`)}</span>
            <span class="hp-ages__range">{t(`age.${ag.key}.range`)}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- TWO PILLARS -->
  <section class="hp-pillars">
    <div class="container">
      <div class="hp-section-header">
        <span class="hp-eyebrow">{t('section.philosophy')}</span>
        <h2>{t('section.philosophy.title')}</h2>
        <p class="hp-section-desc">{t('section.philosophy.desc')}</p>
      </div>
      <div class="hp-pillars__grid">
        <a href={`/${lang}/guides/montessori-ju-jia-zhinan`} class="hp-pillars__card hp-pillars__card--montessori">
          <div class="hp-pillars__img">
            <img src="/images/montessori-play.jpg" alt="Montessori learning environment" width="600" height="400" loading="lazy" />
          </div>
          <div class="hp-pillars__body">
            <div class="hp-pillars__icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#8D9B8E" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>
              </svg>
            </div>
            <h3>{t('philosophy.montessori.title')}</h3>
            <p>{t('philosophy.montessori.desc')}</p>
            <ul>
              <li>{t('philosophy.montessori.point1')}</li>
              <li>{t('philosophy.montessori.point2')}</li>
              <li>{t('philosophy.montessori.point3')}</li>
            </ul>
          </div>
        </a>
        <a href={`/${lang}/guides/zheng-xiang-jiao-yang-zhinan`} class="hp-pillars__card hp-pillars__card--positive">
          <div class="hp-pillars__img">
            <img src="/images/parent-reading.jpg" alt="Parent and child sharing a warm moment" width="600" height="400" loading="lazy" />
          </div>
          <div class="hp-pillars__body">
            <div class="hp-pillars__icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#C4A882" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
              </svg>
            </div>
            <h3>{t('philosophy.positive.title')}</h3>
            <p>{t('philosophy.positive.desc')}</p>
            <ul>
              <li>{t('philosophy.positive.point1')}</li>
              <li>{t('philosophy.positive.point2')}</li>
              <li>{t('philosophy.positive.point3')}</li>
            </ul>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- STATS BAR -->
  <section class="hp-stats">
    <div class="container">
      <div class="hp-stats__grid">
        <div class="hp-stats__item">
          <span class="hp-stats__number">224+</span>
          <span class="hp-stats__label">{t('stats.indicators')}</span>
        </div>
        <div class="hp-stats__divider"></div>
        <div class="hp-stats__item">
          <span class="hp-stats__number">8</span>
          <span class="hp-stats__label">{t('stats.domains')}</span>
        </div>
        <div class="hp-stats__divider"></div>
        <div class="hp-stats__item">
          <span class="hp-stats__number">0-18</span>
          <span class="hp-stats__label">{t('stats.years')}</span>
        </div>
        <div class="hp-stats__divider"></div>
        <div class="hp-stats__item">
          <span class="hp-stats__number">100%</span>
          <span class="hp-stats__label">{t('stats.research')}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- TOPIC CARDS -->
  <section class="hp-topics">
    <div class="container">
      <div class="hp-section-header">
        <span class="hp-eyebrow">{t('section.topics')}</span>
        <h2>{t('section.topics.title')}</h2>
        <p class="hp-section-desc">{t('section.topics.desc')}</p>
      </div>
      <div class="hp-topics__grid">
        {categories.map((cat, i) => (
          <a href={cat.href} class={`hp-topics__card hp-topics__card--${cat.accent} hp-topics__card--${i + 1}`}>
            <h3>{cat.title}</h3>
            <p>{cat.desc}</p>
            <span class="hp-topics__arrow">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FEATURED ARTICLES -->
  {featuredPosts.length > 0 && (
    <section class="hp-articles">
      <div class="container">
        <div class="hp-section-header">
          <span class="hp-eyebrow">{t('section.latest')}</span>
          <h2>{t('section.latest.title')}</h2>
          <p class="hp-section-desc">{t('section.latest.desc')}</p>
        </div>
        <div class="hp-articles__grid">
          {featuredPosts.map((post, i) => (
            <article class={`hp-articles__card ${i === 0 ? 'hp-articles__card--featured' : ''}`}>
              <div class="hp-articles__meta">
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString('zh-TW', { month: 'short', day: 'numeric' })}
                </time>
              </div>
              <h3><a href={`/${lang}/blog/${post.id}`}>{post.data.title}</a></h3>
              <p>{post.data.description}</p>
              {post.data.tags && post.data.tags.length > 0 && (
                <div class="hp-articles__tags">
                  {post.data.tags.slice(0, 2).map((tag: string) => (<span class="hp-tag">{tag}</span>))}
                </div>
              )}
            </article>
          ))}
        </div>
        <div class="hp-section-cta">
          <a href={`/${lang}/blog`} class="hp-btn hp-btn--ghost">{t('section.latest.viewAll')}</a>
        </div>
      </div>
    </section>
  )}

  <!-- APP PREVIEW -->
  <section class="hp-app">
    <div class="container">
      <div class="hp-app__inner">
        <div class="hp-app__content">
          <span class="hp-eyebrow">{t('app.section')}</span>
          <h2>{t('app.section.title')}</h2>
          <p>{t('app.section.desc')}</p>
          <a href="#newsletter" class="hp-btn hp-btn--primary">{t('app.cta')}</a>
        </div>
        <div class="hp-app__visual">
          <div class="hp-app__mockup">
            <div class="hp-app__screen">
              <div class="hp-app__screen-header">
                <div class="hp-app__screen-dot"></div>
                <span>BloomPath</span>
              </div>
              <div class="hp-app__screen-body">
                <div class="hp-app__screen-card"></div>
                <div class="hp-app__screen-card hp-app__screen-card--sm"></div>
                <div class="hp-app__screen-card hp-app__screen-card--sm"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- NEWSLETTER -->
  <section id="newsletter" class="hp-newsletter">
    <div class="container">
      <div class="hp-newsletter__inner">
        <div class="hp-newsletter__content">
          <span class="hp-eyebrow hp-eyebrow--light">{t('section.newsletter')}</span>
          <h2>{t('section.newsletter.title')}</h2>
          <p>{t('section.newsletter.desc')}</p>
        </div>
        <div class="hp-newsletter__form">
          <p class="hp-newsletter__placeholder">{t('section.newsletter.placeholder')}</p>
        </div>
      </div>
    </div>
  </section>

  <Footer lang={lang} />
</BaseLayout>

<style>
  /* Same styles as EN — shared via identical CSS */
  .hp-eyebrow {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-orange);
    background: rgba(196, 168, 130, 0.1);
    padding: 0.3125rem 0.875rem;
    border-radius: 100px;
    margin-bottom: 0.875rem;
  }

  .hp-eyebrow--light { background: rgba(196, 168, 130, 0.2); color: var(--color-orange); }

  .hp-section-header { margin-bottom: 3.5rem; }

  .hp-section-header h2 {
    font-size: 2.75rem;
    font-weight: 800;
    letter-spacing: -0.035em;
    color: var(--color-text);
    line-height: 1.08;
  }

  .hp-section-desc {
    font-size: 1.0625rem;
    color: var(--color-text-light);
    margin-top: 0.75rem;
    max-width: 55ch;
    line-height: 1.65;
  }

  .hp-section-cta { text-align: center; margin-top: 3rem; }

  .hp-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9375rem;
    font-weight: 600;
    padding: 0.8125rem 1.75rem;
    border-radius: 12px;
    border: none;
    text-decoration: none;
    transition: all 0.35s cubic-bezier(0.32, 0.72, 0, 1);
    cursor: pointer;
  }

  .hp-btn:active { transform: translateY(1px) scale(0.98); }
  .hp-btn--primary { background: var(--color-forest); color: var(--color-white); }

  .hp-btn--primary:hover {
    background: var(--color-forest-dark);
    color: var(--color-white);
    transform: translateY(-1px);
    box-shadow: 0 8px 24px -8px rgba(141, 155, 142, 0.35);
  }

  .hp-btn__arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.15);
    transition: all 0.35s cubic-bezier(0.32, 0.72, 0, 1);
  }

  .hp-btn--primary:hover .hp-btn__arrow { transform: translateX(2px); background: rgba(255, 255, 255, 0.25); }

  .hp-btn--ghost {
    background: transparent;
    color: var(--color-forest);
    border: 1.5px solid rgba(141, 155, 142, 0.25);
  }

  .hp-btn--ghost:hover {
    border-color: var(--color-forest);
    background: rgba(141, 155, 142, 0.04);
    color: var(--color-forest);
  }

  .hp-hero {
    padding: 5rem 0 6rem;
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(ellipse 80% 60% at 70% 40%, rgba(141, 155, 142, 0.05) 0%, transparent 70%),
      radial-gradient(ellipse 60% 50% at 25% 80%, rgba(196, 168, 130, 0.04) 0%, transparent 70%),
      linear-gradient(170deg, var(--color-bg) 40%, var(--color-cream) 100%);
  }

  .hp-hero__grid {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2.5rem;
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 5rem;
    align-items: center;
  }

  .hp-hero h1 {
    font-size: 3.25rem;
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: -0.035em;
    color: var(--color-text);
    text-wrap: balance;
  }

  .hp-hero__desc { font-size: 1.125rem; color: var(--color-text-light); line-height: 1.7; max-width: 48ch; margin-top: 1.5rem; }
  .hp-hero__actions { display: flex; flex-wrap: wrap; gap: 0.875rem; margin-top: 2.25rem; }

  .hp-hero__trust {
    display: flex;
    gap: 1.5rem;
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(141, 155, 142, 0.08);
  }

  .hp-trust-item { display: flex; align-items: center; gap: 0.375rem; font-size: 0.8125rem; font-weight: 500; color: var(--color-text-light); }
  .hp-trust-item svg { color: var(--color-forest); flex-shrink: 0; }
  .hp-hero__visual { position: relative; }

  .hp-hero__img-wrapper {
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 0 0 1px rgba(141, 155, 142, 0.06), 0 32px 80px -20px rgba(74, 69, 67, 0.12);
  }

  .hp-hero__img-wrapper img { width: 100%; height: auto; display: block; aspect-ratio: 4/3; object-fit: cover; }

  .hp-hero__badge {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--color-white);
    padding: 0.625rem 1rem;
    border-radius: 12px;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-text);
    box-shadow: 0 8px 24px -6px rgba(74, 69, 67, 0.1);
    z-index: 2;
  }

  .hp-hero__badge--1 { bottom: -1rem; left: -1.5rem; }
  .hp-hero__badge--2 { top: 1.5rem; right: -1rem; }

  .hp-ages { padding: 6rem 0; background: var(--color-white); }
  .hp-ages__grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 1.25rem; }

  .hp-ages__card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 2rem 1.25rem;
    border-radius: 20px;
    border: 1.5px solid rgba(141, 155, 142, 0.1);
    background: var(--color-bg);
    text-decoration: none;
    color: var(--color-text);
    transition: all 0.35s cubic-bezier(0.32, 0.72, 0, 1);
  }

  .hp-ages__card:hover { border-color: var(--color-forest); transform: translateY(-4px); box-shadow: 0 12px 32px -8px rgba(141, 155, 142, 0.15); }

  .hp-ages__icon {
    width: 56px;
    height: 56px;
    border-radius: 16px;
    background: rgba(141, 155, 142, 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-forest);
    margin-bottom: 1rem;
    transition: background 0.35s ease;
  }

  .hp-ages__card:hover .hp-ages__icon { background: rgba(141, 155, 142, 0.14); }
  .hp-ages__label { font-size: 1rem; font-weight: 700; letter-spacing: -0.01em; }
  .hp-ages__range { font-size: 0.8125rem; color: var(--color-text-light); margin-top: 0.25rem; }

  .hp-pillars { padding: 6rem 0; }
  .hp-pillars__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; }

  .hp-pillars__card {
    display: block;
    text-decoration: none;
    color: var(--color-text);
    border-radius: 24px;
    overflow: hidden;
    background: var(--color-white);
    border: 1px solid rgba(141, 155, 142, 0.06);
    box-shadow: 0 4px 24px -6px rgba(74, 69, 67, 0.06);
    transition: all 0.4s cubic-bezier(0.32, 0.72, 0, 1);
  }

  .hp-pillars__card:hover { transform: translateY(-4px); box-shadow: 0 16px 48px -12px rgba(74, 69, 67, 0.1); }
  .hp-pillars__img { overflow: hidden; aspect-ratio: 3/2; }
  .hp-pillars__img img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s cubic-bezier(0.32, 0.72, 0, 1); }
  .hp-pillars__card:hover .hp-pillars__img img { transform: scale(1.04); }
  .hp-pillars__body { padding: 2rem 2.25rem 2.5rem; }

  .hp-pillars__icon {
    width: 48px;
    height: 48px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.25rem;
  }

  .hp-pillars__card--montessori .hp-pillars__icon { background: rgba(141, 155, 142, 0.08); }
  .hp-pillars__card--positive .hp-pillars__icon { background: rgba(196, 168, 130, 0.1); }
  .hp-pillars__body h3 { font-size: 1.5rem; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 0.75rem; }
  .hp-pillars__body p { font-size: 0.9375rem; color: var(--color-text-light); line-height: 1.65; margin-bottom: 1rem; max-width: 50ch; }
