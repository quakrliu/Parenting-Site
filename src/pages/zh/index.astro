---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import AlertBanner from '../../components/AlertBanner.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';
import { useTranslations } from '../../i18n/utils';

const lang = 'zh';
const t = useTranslations(lang);

const allPosts = await getCollection('blog');
const now = new Date();
const publishedPosts = allPosts
  .filter((post) => post.data.pubDate <= now && post.data.lang === 'zh-TW')
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const featuredPosts = publishedPosts.slice(0, 6);

const ageStages = [
  { key: 'infant', img: '/images/age-newborn.jpg', color: 'forest' },
  { key: 'toddler', img: '/images/age-toddler.jpg', color: 'orange' },
  { key: 'preschool', img: '/images/age-preschool.jpg', color: 'pink' },
  { key: 'school', img: '/images/age-explorer.jpg', color: 'forest' },
  { key: 'teen', img: '/images/age-talker.jpg', color: 'orange' },
];

const stats = [
  { value: '224+', label: t('stats.indicators') },
  { value: '8', label: t('stats.domains') },
  { value: '0-18', label: t('stats.years') },
];
---

<BaseLayout title={`${t('site.title')} | ${t('site.tagline')}`} description={t('site.description')} lang={lang}>
  <Header lang={lang} />
  <AlertBanner lang={lang} />

  <!-- HERO: Full-width asymmetric split with background imagery -->
  <section class="hero">
    <div class="hero__bg" aria-hidden="true">
      <img
        src="/images/hero-family.jpg"
        alt=""
        width="1920"
        height="1080"
        loading="eager"
        class="hero__bg-img"
      />
      <div class="hero__bg-overlay"></div>
    </div>
    <div class="container hero__grid">
      <div class="hero__content">
        <h1 set:html={t('hero.heading')} />
        <p class="hero__desc">{t('hero.desc')}</p>
        <div class="hero__actions">
          <a href={`/${lang}/blog`} class="btn btn--primary btn--lg">
            {t('hero.cta.articles')}
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
        <div class="hero__trust">
          <span class="hero__trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            {t('hero.trust.evidence')}
          </span>
          <span class="hero__trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            {t('hero.trust.parents')}
          </span>
          <span class="hero__trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            {t('hero.trust.free')}
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- AGE NAVIGATOR: Horizontal card grid -->
  <section class="age-nav">
    <div class="container">
      <div class="section-header section-header--center">
        <span class="eyebrow">{t('age.section')}</span>
        <h2>{t('age.section.title')}</h2>
        <p class="section-desc section-desc--center">{t('age.section.desc')}</p>
      </div>
      <div class="age-nav__grid">
        {ageStages.map((stage) => (
          <a href={`/${lang}/blog`} class={`age-nav__card age-nav__card--${stage.color}`}>
            <div class="age-nav__img-wrap">
              <img
                src={stage.img}
                alt={t(`age.${stage.key}` as any)}
                width="480"
                height="560"
                loading="lazy"
                class="age-nav__img"
              />
            </div>
            <div class="age-nav__label">
              <span class="age-nav__name">{t(`age.${stage.key}` as any)}</span>
              <span class="age-nav__range">{t(`age.${stage.key}.range` as any)}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- TWO PILLARS: Montessori + Positive Parenting with imagery -->
  <section class="pillars">
    <div class="container">
      <div class="section-header section-header--center">
        <span class="eyebrow">{t('section.philosophy')}</span>
        <h2>{t('section.philosophy.title')}</h2>
        <p class="section-desc section-desc--center">{t('section.philosophy.desc')}</p>
      </div>
      <div class="pillars__grid">
        <div class="pillars__card">
          <div class="pillars__img-wrap">
            <img
              src="/images/montessori-play.jpg"
              alt="孩子探索蒙特梭利教具"
              width="800"
              height="600"
              loading="lazy"
              class="pillars__img"
            />
          </div>
          <div class="pillars__body">
            <div class="pillars__icon pillars__icon--forest">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>
              </svg>
            </div>
            <h3>{t('philosophy.montessori.title')}</h3>
            <p>{t('philosophy.montessori.desc')}</p>
            <ul class="pillars__points">
              <li>{t('philosophy.montessori.point1')}</li>
              <li>{t('philosophy.montessori.point2')}</li>
              <li>{t('philosophy.montessori.point3')}</li>
            </ul>
            <a href={`/${lang}/blog/montessori-at-home-guide-zh`} class="pillars__cta">
              閱讀完整指南
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>
        </div>
        <div class="pillars__card">
          <div class="pillars__img-wrap">
            <img
              src="/images/parent-reading.jpg"
              alt="親子共讀的溫馨時刻"
              width="800"
              height="600"
              loading="lazy"
              class="pillars__img"
            />
          </div>
          <div class="pillars__body">
            <div class="pillars__icon pillars__icon--orange">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
              </svg>
            </div>
            <h3>{t('philosophy.positive.title')}</h3>
            <p>{t('philosophy.positive.desc')}</p>
            <ul class="pillars__points">
              <li>{t('philosophy.positive.point1')}</li>
              <li>{t('philosophy.positive.point2')}</li>
              <li>{t('philosophy.positive.point3')}</li>
            </ul>
            <a href={`/${lang}/blog/positive-parenting-guide-zh`} class="pillars__cta">
              閱讀完整指南
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- STATS BAR: Full-width accent strip -->
  <section class="stats-bar">
    <div class="container">
      <div class="stats-bar__grid">
        {stats.map((stat) => (
          <div class="stats-bar__item">
            <span class="stats-bar__value">{stat.value}</span>
            <span class="stats-bar__label">{stat.label}</span>
          </div>
        ))}
        <div class="stats-bar__item stats-bar__item--badge">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <span class="stats-bar__label">{t('stats.research')}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- DAILY STICKINESS: Dynamic daily-changing features -->
  <section class="daily">
    <div class="container">
      <div class="section-header section-header--center">
        <span class="eyebrow">{t('daily.section')}</span>
        <h2>{t('daily.section.title')}</h2>
        <p class="section-desc section-desc--center">{t('daily.section.desc')}</p>
      </div>
      <div class="daily__grid">
        <div class="daily__card daily__card--task">
          <div class="daily__card-header">
            <div class="daily__icon daily__icon--forest">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <span class="daily__badge">{t('daily.task.time')}</span>
          </div>
          <h3>{t('daily.task.title')}</h3>
          <p id="daily-task-text" class="daily__body">Loading...</p>
          <div id="daily-task-age" class="daily__tag"></div>
        </div>

        <div class="daily__card daily__card--focus">
          <div class="daily__card-header">
            <div class="daily__icon daily__icon--orange">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
            </div>
          </div>
          <h3>{t('daily.focus.title')}</h3>
          <p id="weekly-focus-text" class="daily__body">Loading...</p>
          <div id="weekly-focus-age" class="daily__tag"></div>
        </div>

        <div class="daily__card daily__card--quote">
          <div class="daily__card-header">
            <div class="daily__icon daily__icon--pink">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V21z"/><path d="M15 21c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2h.75c0 2.25.25 4-2.75 4v3c0 1 0 1 1 1z"/></svg>
            </div>
            <button id="quote-copy-btn" class="daily__copy-btn" aria-label="複製名言">{t('daily.quote.btn')}</button>
          </div>
          <h3>{t('daily.quote.title')}</h3>
          <blockquote id="daily-quote-text" class="daily__quote">Loading...</blockquote>
          <cite id="daily-quote-author" class="daily__cite"></cite>
        </div>

        <div class="daily__card daily__card--normal">
          <div class="daily__card-header">
            <div class="daily__icon daily__icon--forest">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            </div>
          </div>
          <h3>{t('daily.normal.title')}</h3>
          <p class="daily__body-sm">{t('daily.normal.desc')}</p>
          <div class="daily__form">
            <select id="normal-age" class="daily__select" aria-label={t('daily.normal.select.age')}>
              <option value="">{t('daily.normal.select.age')}</option>
              <option value="infant">0-1 歲</option>
              <option value="toddler">1-3 歲</option>
              <option value="preschool">3-6 歲</option>
              <option value="school">6-12 歲</option>
              <option value="teen">12-18 歲</option>
            </select>
            <select id="normal-behavior" class="daily__select" aria-label={t('daily.normal.select.behavior')}>
              <option value="">{t('daily.normal.select.behavior')}</option>
            </select>
            <button id="normal-check-btn" class="btn btn--primary btn--sm">{t('daily.normal.check')}</button>
          </div>
          <div id="normal-result" class="daily__result"></div>
          <p class="daily__disclaimer">{t('daily.normal.disclaimer')}</p>
        </div>

        <div class="daily__card daily__card--journal">
          <div class="daily__card-header">
            <div class="daily__icon daily__icon--orange">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
            </div>
            <div id="journal-streak" class="daily__streak"></div>
          </div>
          <h3>{t('daily.journal.title')}</h3>
          <textarea id="journal-input" class="daily__textarea" placeholder={t('daily.journal.prompt')} rows="3"></textarea>
          <button id="journal-save-btn" class="btn btn--primary btn--sm">{t('daily.journal.save')}</button>
          <div id="journal-saved" class="daily__saved"></div>
        </div>
      </div>
    </div>
  </section>

  <script>
    (function() {
      var today = new Date();
      var dayOfYear = Math.floor((today.getTime() - new Date(today.getFullYear(), 0, 0).getTime()) / 86400000);
      var weekOfYear = Math.floor(dayOfYear / 7);

      var activities = [
        { text: '一起蓋毛毯城堡，在裡面讀一本故事書。讓孩子選書、主導搭建。', age: '學齡前 (3-6)' },
        { text: '散步時玩「我看到」遊戲，只用顏色描述。訓練觀察力和詞彙。', age: '學步期 (1-3)' },
        { text: '讓寶寶探索不同觸感：絲綢、毛線、砂紙、涼涼的湯匙。邊摸邊說給他聽。', age: '嬰兒期 (0-1)' },
        { text: '請學齡孩子教你一件他這週學到的事。角色反轉能建立自信。', age: '學齡期 (6-12)' },
        { text: '一起做一道簡單的料理。量食材教數學，按步驟教排序。', age: '學齡前 (3-6)' },
        { text: '晚餐時做「感受打卡」：每個人分享今天一件開心的事和一件不開心的事。', age: '全年齡' },
        { text: '做一本自然觀察日記：去外面10分鐘，畫下或寫下你注意到的三件事。', age: '學齡期 (6-12)' },
        { text: '練習把水從一個杯子倒到另一個杯子。用小壺讓小手練習。', age: '學步期 (1-3)' },
        { text: '問你的青少年：「你覺得大人最不了解什麼？」然後只是聽。', age: '青少年期 (12-18)' },
        { text: '和寶寶面對面做趴趴時間。唱一首簡單的歌，觀察他的反應。', age: '嬰兒期 (0-1)' },
        { text: '挑戰孩子按顏色分類衣服。生活實踐技能 + 模式辨識。', age: '學齡前 (3-6)' },
        { text: '寫一張小紙條放進青少年的書包裡。簡單的，不附帶條件的。', age: '青少年期 (12-18)' },
        { text: '用家裡的食材玩「雜貨店」遊戲。練習數數和找零。', age: '學齡期 (6-12)' },
        { text: '跳舞時間！放音樂，一起動5分鐘。沒有規則，只有律動。', age: '全年齡' },
      ];
      var todayActivity = activities[dayOfYear % activities.length];
      var taskEl = document.getElementById('daily-task-text');
      var taskAgeEl = document.getElementById('daily-task-age');
      if (taskEl) taskEl.textContent = todayActivity.text;
      if (taskAgeEl) taskAgeEl.textContent = todayActivity.age;

      var weeklyFocuses = [
        { text: '情緒詞彙週：幫助孩子為感受命名。「你好像很挫折」比「不要哭」更有力量。', age: '全年齡' },
        { text: '獨立練習週：讓孩子自己做一件你平常幫他做的事。扣鈕扣、倒自己的水、走路去學校。', age: '學步期 - 學齡期' },
        { text: '無螢幕連結週：每天花15分鐘不被打斷地和孩子在一起。不看手機，沒有議程。', age: '全年齡' },
        { text: '常規建立週：為早晨或睡前做一個視覺化時間表。讓孩子一起設計。', age: '學齡前 (3-6)' },
        { text: '感恩練習週：晚餐時，每個家人分享今天一件感恩的事。', age: '學齡期 - 青少年期' },
        { text: '感官探索週：每天提供寶寶一個新的感官體驗：音樂、觸感、氣味、味道、律動。', age: '嬰兒期 (0-1)' },
        { text: '積極聆聽週：當青少年說話時，先停頓再回應。在給意見前先重複你聽到的。', age: '青少年期 (12-18)' },
        { text: '動作與協調週：在室內或戶外設置簡單的障礙賽。爬、跳、平衡。', age: '學步期 - 學齡前' },
      ];
      var thisWeekFocus = weeklyFocuses[weekOfYear % weeklyFocuses.length];
      var focusEl = document.getElementById('weekly-focus-text');
      var focusAgeEl = document.getElementById('weekly-focus-age');
      if (focusEl) focusEl.textContent = thisWeekFocus.text;
      if (focusAgeEl) focusAgeEl.textContent = thisWeekFocus.age;

      var quotes = [
        { text: '孩子是人類的希望與承諾。', author: '瑪麗亞．蒙特梭利' },
        { text: '孩子不是要被塑造的東西，而是要被展開的人。', author: 'Jess Lair' },
        { text: '當人們感到被看見、被聽見、被重視時，連結的能量就產生了。', author: '布芮尼．布朗' },
        { text: '遊戲是最高形式的研究。', author: '愛因斯坦' },
        { text: '我們能給孩子最好的禮物，是責任的根和獨立的翅膀。', author: '瑪麗亞．蒙特梭利' },
        { text: '當小小的人被大大的情緒淹沒時，我們的工作是分享我們的平靜，而不是加入他們的混亂。', author: 'L.R. Knost' },
        { text: '每個孩子都值得擁有一個冠軍：一個永遠不會放棄他們的大人。', author: 'Rita Pierson' },
        { text: '不要用強迫或嚴厲來訓練孩子學習；用能引起他們興趣的方式引導。', author: '柏拉圖' },
        { text: '每個相信自己的孩子背後，都有一個先相信他的父母。', author: 'Matthew Jacobson' },
        { text: '我們和孩子說話的方式，會成為他們內心的聲音。', author: 'Peggy O\'Mara' },
        { text: '建造堅強的孩子比修復破碎的大人容易得多。', author: 'Frederick Douglass' },
        { text: '孩子的生命中至少需要一個人，認為太陽是為他們升起和落下的。', author: 'Pamela Leo' },
        { text: '專注的孩子是無比快樂的。', author: '瑪麗亞．蒙特梭利' },
        { text: '你的孩子需要你的陪伴，勝過你的禮物。', author: 'Jesse Jackson' },
      ];
      var todayQuote = quotes[dayOfYear % quotes.length];
      var quoteEl = document.getElementById('daily-quote-text');
      var authorEl = document.getElementById('daily-quote-author');
      if (quoteEl) quoteEl.textContent = '\u201C' + todayQuote.text + '\u201D';
      if (authorEl) authorEl.textContent = '\u2014\u2014 ' + todayQuote.author;

      var copyBtn = document.getElementById('quote-copy-btn');
      if (copyBtn) {
        copyBtn.addEventListener('click', function() {
          navigator.clipboard.writeText(todayQuote.text + ' —— ' + todayQuote.author).then(function() {
            copyBtn.textContent = '\u5DF2\u8907\u88FD\uFF01';
            setTimeout(function() { copyBtn.textContent = '\u8907\u88FD'; }, 2000);
          });
        });
      }

      var behaviorsByAge = {
        infant: [
          { label: '\u9084\u6C92\u6709\u7B11', value: 'no-smile' },
          { label: '\u807D\u5230\u5927\u8072\u97F3\u6703\u56DA\u5687', value: 'startle' },
          { label: '\u5F88\u611B\u54ED', value: 'cries' },
          { label: '\u9084\u4E0D\u6703\u7FFB\u8EAB', value: 'no-roll' },
        ],
        toddler: [
          { label: '\u6703\u54AC\u5176\u4ED6\u5C0F\u670B\u53CB', value: 'biting' },
          { label: '\u9084\u4E0D\u6703\u8AAA\u8A71', value: 'no-talk' },
