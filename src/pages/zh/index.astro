        'infant-no-roll': { status: 'watch', text: '\u5927\u90E8\u5206\u5B9D\u5B9D\u57284-6\u500B\u6708\u5B78\u6703\u7FFB\u8EAB\u3002\u591A\u63D0\u4F9B\u8DA3\u8DA3\u6642\u9593\u3002\u5982\u679C7\u500B\u6708\u5927\u4ECD\u4E0D\u6703\u7FFB\u8EAB\uFF0C\u8ACB\u8AEE\u8A62\u5152\u79D1\u91AB\u5E2B\u3002' },
        'toddler-biting': { status: 'normal', text: '1-3\u6B72\u975E\u5E38\u5E38\u898B\u3002\u4ED6\u5011\u7F3A\u4E4F\u8868\u9054\u632B\u6298\u611F\u7684\u8A5E\u5F59\u3002\u4FDD\u6301\u5E73\u975C\uFF0C\u8AAA\u300C\u4E0D\u53EF\u4EE5\u54AC\u300D\uFF0C\u7136\u5F8C\u8F49\u79FB\u6CE8\u610F\u529B\u3002\u901A\u5E383\u6B72\u524D\u6703\u6539\u5584\u3002' },
        'toddler-no-talk': { status: 'watch', text: '18\u500B\u6708\u5927\u6642\u5927\u90E8\u5206\u5B69\u5B50\u81F3\u5C11\u6703\u8AAA\u5E7E\u500B\u8A5E\u30022\u6B72\u6642\u6703\u7D44\u5408\u5169\u500B\u8A5E\u3002\u5982\u679C\u64D4\u5FC3\uFF0C\u53EF\u4EE5\u8A62\u554F\u65E9\u671F\u7642\u80B2\u7BE9\u6AA2\u3002' },
        'toddler-tantrums': { status: 'normal', text: '\u5927\u54ED\u5927\u9B27\u768418\u500B\u6708\u523D3\u6B72\u662F\u9AD8\u5CF0\u671F\u3002\u4ED6\u5011\u7684\u60C5\u7DD2\u8166\u767C\u5C55\u5F97\u6BD4\u8ABF\u7BC0\u80FD\u529B\u5FEB\u3002\u4FDD\u6301\u5E73\u975C\uFF0C\u9673\u5728\u3002' },
        'toddler-picky-eat': { status: 'normal', text: '\u98DF\u7269\u6050\u65B0\u75C7\u57282-6\u6B72\u662F\u767C\u5C55\u6027\u6B63\u5E38\u7684\u3002\u7E7C\u7E8C\u63D0\u4F9B\u591A\u6A23\u5316\u98DF\u7269\u4F46\u4E0D\u65BD\u58D3\u3002\u53EF\u80FD\u9700\u898115-20\u6B21\u63A5\u89F8\u624D\u6703\u63A5\u53D7\u3002' },
        'preschool-imaginary': { status: 'normal', text: '\u5E7B\u60F3\u670B\u53CB\u662F\u5065\u5EB7\u5275\u9020\u529B\u548C\u793E\u4EA4\u767C\u5C55\u7684\u8868\u73FE\u3002\u7D0465%\u7684\u5B69\u5B50\u5728\u67D0\u500B\u6642\u5019\u6703\u6709\u3002\u4E0D\u7528\u64D4\u5FC3\u3002' },
        'preschool-no-share': { status: 'normal', text: '\u771F\u6B63\u7684\u5206\u4EAB\u80FD\u529B\u57284-5\u6B72\u5DE6\u53F3\u767C\u5C55\u3002\u5728\u90A3\u4E4B\u524D\uFF0C\u5B69\u5B50\u4ECD\u5728\u767C\u5C55\u5FC3\u667A\u7406\u8AD6\u3002\u793A\u7BC4\u5206\u4EAB\u548C\u8F2A\u6D41\uFF0C\u4F46\u4E0D\u8981\u5F37\u8FEB\u3002' },
        'preschool-bedwet': { status: 'normal', text: '\u591C\u9593\u81A8\u80F1\u63A7\u5236\u57284-7\u6B72\u9593\u767C\u5C55\u3002\u7D0415%\u76845\u6B72\u5B69\u5B50\u4ECD\u6703\u5C3F\u5E8A\u30027\u6B72\u4E4B\u524D\u901A\u5E38\u4E0D\u662F\u554F\u984C\u3002' },
        'preschool-why': { status: 'normal', text: '\u8A8D\u77E5\u767C\u5C55\u7684\u7F8E\u9E97\u8868\u73FE\uFF01\u4ED6\u5011\u6B63\u5728\u5EFA\u7ACB\u56E0\u679C\u95DC\u4FC2\u7684\u7406\u89E3\u3002\u80FD\u56DE\u7B54\u5C31\u56DE\u7B54\uFF0C\u4E5F\u53EF\u4EE5\u8AAA\u300C\u4F60\u89BA\u5F97\u5462\uFF1F\u300D' },
        'school-read-struggle': { status: 'watch', text: '\u65E9\u671F\u5E74\u7D1A\u7684\u95B1\u8B80\u80FD\u529B\u5DEE\u7570\u5F88\u5927\u30027-8\u6B72\u4ECD\u660E\u986F\u56F0\u96E3\u7684\u8A71\uFF0C\u8003\u616E\u7BE9\u6AA2\u8B80\u5BEB\u969C\u7919\u6216\u5B78\u7FD2\u5DEE\u7570\u3002\u65E9\u671F\u652F\u6301\u5E6B\u52A9\u5F88\u5927\u3002' },
        'school-school-avoid': { status: 'watch', text: '\u5076\u723E\u4E0D\u60F3\u4E0A\u5B78\u662F\u6B63\u5E38\u7684\u3002\u6301\u7E8C\u8FF4\u907F\uFF08\u7279\u5225\u662F\u4F34\u96A8\u8EAB\u9AD4\u4E0D\u9069\uFF09\u53EF\u80FD\u8868\u793A\u7126\u616E\u3001\u9738\u51CC\u6216\u5B78\u7FD2\u56F0\u96E3\u3002\u8ACB\u8207\u5B78\u6821\u8F14\u5C0E\u8001\u5E2B\u8AC7\u8AC7\u3002' },
        'school-stomach': { status: 'watch', text: '\u6C92\u6709\u91AB\u5B78\u539F\u56E0\u7684\u53CD\u8986\u809A\u5B50\u75DB\u901A\u5E38\u8207\u7126\u616E\u6709\u95DC\u3002\u5982\u679C\u7D93\u5E38\u5728\u4E0A\u5B78\u524D\u767C\u751F\uFF0C\u63A2\u7D22\u53EF\u80FD\u9020\u6210\u58D3\u529B\u7684\u539F\u56E0\u3002' },
        'school-friend-trouble': { status: 'watch', text: '\u793E\u4EA4\u6280\u5DE7\u767C\u5C55\u901F\u5EA6\u4E0D\u540C\u3002\u5982\u679C\u5B69\u5B50\u60F3\u4EA4\u670B\u53CB\u4F46\u6709\u56F0\u96E3\uFF0C\u8003\u616E\u793E\u4EA4\u6280\u5DE7\u5718\u9AD4\u3002\u5982\u679C\u4ED6\u5011\u55AE\u7368\u4E5F\u5F88\u6EFF\u8DB3\uFF0C\u90A3\u4E5F\u53EF\u4EE5\u3002' },
        'teen-isolation': { status: 'watch', text: '\u9752\u5C11\u5E74\u9700\u8981\u4E00\u4E9B\u7368\u8655\u6642\u9593\u662F\u6B63\u5E38\u7684\u3002\u4F46\u5982\u679C\u5B8C\u5168\u9000\u7E2E\u8D85\u9054\u5169\u9031\uFF0C\u52A0\u4E0A\u5176\u4ED6\u8B8A\u5316\uFF0C\u53EF\u80FD\u662F\u6291\u9B31\u7684\u8DE1\u8C61\u3002\u6EAB\u67D4\u5730\u95DC\u5FC3\u3002' },
        'teen-moods': { status: 'normal', text: '\u8377\u723E\u8499\u8B8A\u5316\u8B93\u60C5\u7DD2\u8D77\u4F0F\u5728\u9752\u6625\u671F\u5F88\u5E38\u898B\u3002\u5982\u679C\u60C5\u7DD2\u8B8A\u5316\u6301\u7E8C\u5169\u9031\u4EE5\u4E0A\u4E14\u5F71\u97FF\u65E5\u5E38\u529F\u80FD\uFF0C\u53EF\u80FD\u4E0D\u53EA\u662F\u5178\u578B\u7684\u9752\u5C11\u5E74\u884C\u70BA\u3002' },
        'teen-talks-back': { status: 'normal', text: '\u53CD\u6297\u662F\u767C\u5C55\u81EA\u4E3B\u548C\u8EAB\u4EFD\u8A8D\u540C\u7684\u6B63\u5E38\u90E8\u5206\u3002\u9078\u64C7\u4F60\u7684\u6230\u5834\u3002\u5728\u5C0A\u91CD\u6E9D\u901A\u4E0A\u8A2D\u5B9A\u6E05\u695A\u7684\u754C\u7DDA\uFF0C\u4F46\u5141\u8A31\u4E0D\u540C\u610F\u898B\u3002' },
        'teen-oversleep': { status: 'normal', text: '\u9752\u5C11\u5E74\u751F\u7406\u4E0A\u9700\u89818-10\u5C0F\u6642\u7761\u7720\uFF0C\u4E14\u751F\u7406\u6642\u9418\u6703\u5F80\u5F8C\u79FB\u3002\u9031\u672B\u7761\u5230\u4E2D\u5348\u662F\u5E38\u898B\u7684\u3002\u5982\u679C\u6BCF\u5929\u77612\u5C0F\u6642\u4EE5\u4E0A\u4E14\u5931\u53BB\u8208\u8DA3\uFF0C\u5247\u9700\u95DC\u6CE8\u3002' },
      };

      var ageSelect = document.getElementById('normal-age');
      var behaviorSelect = document.getElementById('normal-behavior');
      var checkBtn = document.getElementById('normal-check-btn');
      var resultEl = document.getElementById('normal-result');

      if (ageSelect && behaviorSelect) {
        ageSelect.addEventListener('change', function() {
          var age = ageSelect.value;
          behaviorSelect.innerHTML = '<option value="">\u9078\u64C7\u884C\u70BA</option>';
          if (resultEl) resultEl.innerHTML = '';
          if (age && behaviorsByAge[age]) {
            behaviorsByAge[age].forEach(function(b) {
              var opt = document.createElement('option');
              opt.value = b.value;
              opt.textContent = b.label;
              behaviorSelect.appendChild(opt);
            });
          }
        });

        if (checkBtn) {
          checkBtn.addEventListener('click', function() {
            var age = ageSelect.value;
            var behavior = behaviorSelect.value;
            if (!age || !behavior) return;
            var key = age + '-' + behavior;
            var answer = normalAnswers[key];
            if (answer && resultEl) {
              var statusClass = answer.status === 'normal' ? 'daily__result--normal' : 'daily__result--watch';
              var statusIcon = answer.status === 'normal' ? '\u901A\u5E38\u6B63\u5E38' : '\u503C\u5F97\u95DC\u6CE8';
              resultEl.innerHTML = '<div class="daily__result-badge ' + statusClass + '">' + statusIcon + '</div><p>' + answer.text + '</p>';
            }
          });
        }
      }

      var journalInput = document.getElementById('journal-input');
      var journalSaveBtn = document.getElementById('journal-save-btn');
      var journalSaved = document.getElementById('journal-saved');
      var journalStreak = document.getElementById('journal-streak');

      function getDateKey() { return today.toISOString().split('T')[0]; }

      function calcStreak() {
        var entries = JSON.parse(localStorage.getItem('bp-journal') || '{}');
        var streak = 0;
        var d = new Date(today);
        while (true) {
          var key = d.toISOString().split('T')[0];
          if (entries[key]) { streak++; d.setDate(d.getDate() - 1); } else { break; }
        }
        return streak;
      }

      function updateStreakUI() {
        var streak = calcStreak();
        if (journalStreak && streak > 0) {
          journalStreak.textContent = streak + ' \u5929\u9023\u7E8C\u8A18\u9304';
          journalStreak.style.display = 'inline-block';
        }
      }

      var entries = JSON.parse(localStorage.getItem('bp-journal') || '{}');
      var todayKey = getDateKey();
      if (entries[todayKey] && journalInput) journalInput.value = entries[todayKey];
      updateStreakUI();

      if (journalSaveBtn && journalInput) {
        journalSaveBtn.addEventListener('click', function() {
          var text = journalInput.value.trim();
          if (!text) return;
          var entries = JSON.parse(localStorage.getItem('bp-journal') || '{}');
          entries[todayKey] = text;
          localStorage.setItem('bp-journal', JSON.stringify(entries));
          if (journalSaved) {
            journalSaved.textContent = '\u5DF2\u5132\u5B58\uFF01';
            journalSaved.style.opacity = '1';
            setTimeout(function() { journalSaved.style.opacity = '0'; }, 2000);
          }
          updateStreakUI();
        });
      }
    })();
  </script>

  <!-- FEATURED ARTICLES: Asymmetric grid -->
  {featuredPosts.length > 0 && (
    <section class="articles">
      <div class="container">
        <div class="section-header">
          <span class="eyebrow">{t('section.latest')}</span>
          <h2>{t('section.latest.title')}</h2>
          <p class="section-desc">{t('section.latest.desc')}</p>
        </div>
        <div class="articles__grid">
          {featuredPosts.map((post) => (
            <article class="articles__card">
              <div class="articles__meta">
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString('zh-TW', { month: 'short', day: 'numeric', year: 'numeric' })}
                </time>
              </div>
              <h3><a href={`/${lang}/blog/${post.id}`}>{post.data.title}</a></h3>
              <p>{post.data.description}</p>
              {post.data.tags && post.data.tags.length > 0 && (
                <div class="articles__tags">
                  {post.data.tags.slice(0, 3).map((tag: string) => (<span class="tag">{tag}</span>))}
                </div>
              )}
            </article>
          ))}
        </div>
        <div class="section-cta">
          <a href={`/${lang}/blog`} class="btn btn--ghost">{t('section.latest.viewAll')}</a>
        </div>
      </div>
    </section>
  )}

  <!-- APP PREVIEW: Soft CTA -->
  <section class="app-preview">
    <div class="container">
      <div class="app-preview__inner">
        <div class="app-preview__content">
          <span class="eyebrow">{t('app.section')}</span>
          <h2>{t('app.section.title')}</h2>
          <p>{t('app.section.desc')}</p>
          <a href="#newsletter" class="btn btn--primary">{t('app.cta')}</a>
        </div>
        <div class="app-preview__visual" aria-hidden="true">
          <div class="app-preview__phone">
            <div class="app-preview__screen">
              <img
                src="/images/montessori-play.jpg"
                alt=""
                width="390"
                height="844"
                loading="lazy"
                class="app-preview__screen-img"
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- NEWSLETTER -->
  <section id="newsletter" class="newsletter">
    <div class="container">
      <div class="newsletter__inner">
        <div class="newsletter__content">
          <span class="eyebrow eyebrow--light">{t('section.newsletter')}</span>
          <h2>{t('section.newsletter.title')}</h2>
          <p>{t('section.newsletter.desc')}</p>
        </div>
        <div class="newsletter__form">
          <p class="newsletter__placeholder">{t('section.newsletter.placeholder')}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section id="about" class="about">
    <div class="container">
      <div class="about__inner">
        <div class="about__content">
          <span class="eyebrow">{t('section.about')}</span>
          <h2>{t('section.about.title')}</h2>
          <p>{t('section.about.p1')}</p>
          <p>{t('section.about.p2')}</p>
          <div class="about__values">
            <div class="about__value">
              <strong>{t('section.about.evidence')}</strong>
              <span>{t('section.about.evidence.desc')}</span>
            </div>
            <div class="about__value">
              <strong>{t('section.about.practical')}</strong>
              <span>{t('section.about.practical.desc')}</span>
            </div>
            <div class="about__value">
              <strong>{t('section.about.inclusive')}</strong>
              <span>{t('section.about.inclusive.desc')}</span>
            </div>
          </div>
        </div>
        <div class="about__visual" aria-hidden="true">
          <img
            src="/images/about-family.jpg"
            alt=""
            width="640"
            height="800"
            loading="lazy"
            class="about__img"
          />
        </div>
      </div>
    </div>
  </section>

  <Footer lang={lang} />
</BaseLayout>

<style>
  /* ================================================
     BLOOMPATH HOMEPAGE — LOVEVERY-QUALITY REBUILD
     Desktop-first. 1440px target. Morandi palette.
     Font: Outfit. No Tailwind — pure CSS.
     DESIGN_VARIANCE: 8 | MOTION_INTENSITY: 6 | VISUAL_DENSITY: 4
     ================================================ */

  /* ===== SHARED TOKENS ===== */
  .eyebrow {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-orange-dark);
    background: rgba(196, 168, 130, 0.1);
    padding: 0.3125rem 0.875rem;
    border-radius: 100px;
    margin-bottom: 1rem;
  }

  .eyebrow--light {
    background: rgba(255, 255, 255, 0.1);
    color: var(--color-orange);
  }

  .section-header { margin-bottom: 3.5rem; }
  .section-header--center { text-align: center; }

  .section-header h2 {
    font-size: 2.75rem;
    font-weight: 800;
    letter-spacing: -0.035em;
    color: var(--color-text);
    line-height: 1.1;
    text-wrap: balance;
  }

  .section-desc {
    font-size: 1.0625rem;
    color: var(--color-text-light);
    margin-top: 0.875rem;
    max-width: 55ch;
    line-height: 1.7;
  }

  .section-desc--center { margin-inline: auto; }

  .section-cta {
    text-align: center;
    margin-top: 3.5rem;
  }

  /* ===== BUTTONS ===== */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-primary);
    font-size: 0.9375rem;
    font-weight: 600;
    padding: 0.8125rem 1.75rem;
    border-radius: 12px;
    border: none;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.32, 0.72, 0, 1);
  }

  .btn:active { transform: translateY(1px) scale(0.98); }

