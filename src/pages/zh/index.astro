---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import AlertBanner from '../../components/AlertBanner.astro';
import Footer from '../../components/Footer.astro';
import HomeHero from '../../components/HomeHero.astro';
import AgeNavigator from '../../components/AgeNavigator.astro';
import FeaturedArticles from '../../components/FeaturedArticles.astro';
import NewsletterSection from '../../components/NewsletterSection.astro';
import AboutSection from '../../components/AboutSection.astro';
import { getCollection } from 'astro:content';
import { useTranslations } from '../../i18n/utils';

const lang = 'zh';
const t = useTranslations(lang);

const allPosts = await getCollection('blog');
const now = new Date();
const featuredPosts = allPosts
  .filter((post) => post.data.pubDate <= now && post.data.lang === 'zh-TW')
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);
---

<BaseLayout title={`${t('site.title')} | ${t('site.tagline')}`} description={t('site.description')} lang={lang}>
  <Header lang={lang} />
  <AlertBanner lang={lang} />
  <HomeHero lang={lang} />
  <AgeNavigator lang={lang} />
  <FeaturedArticles lang={lang} posts={featuredPosts} />
  <NewsletterSection lang={lang} />
  <AboutSection lang={lang} />
  <Footer lang={lang} />
</BaseLayout>
