---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';

const lang = 'zh';
---

<BaseLayout
  title="寶寶與幼兒睡眠時間表 | BloomPath"
  description="根據適齡的睡眠建議，為你的寶寶或幼兒生成個人化的睡眠時間表。"
  lang={lang}
>
  <Header lang={lang} />

  <main class="tool-page">
    <div class="container">
      <div class="tool-header">
        <div class="tool-icon">🌙</div>
        <h1>睡眠時間表</h1>
        <p class="tool-subtitle">
          輸入孩子的年齡和起床、就寢時間，取得附午睡時段的個人化每日睡眠時間表。
        </p>
      </div>

      <div class="tool-card">
        <div class="inputs-grid">
          <div class="input-group">
            <label for="child-age" class="input-label">孩子的年齡（月）</label>
            <div class="age-input-row">
              <input type="number" id="child-age" min="0" max="60" value="6" class="number-input" />
              <span class="input-unit">個月</span>
            </div>
          </div>
          <div class="input-group">
            <label for="wake-time" class="input-label">早上起床時間</label>
            <input type="time" id="wake-time" value="07:00" class="time-input" />
          </div>
          <div class="input-group">
            <label for="bed-time" class="input-label">目標就寢時間</label>
            <input type="time" id="bed-time" value="19:30" class="time-input" />
          </div>
        </div>
        <button id="generate-btn" class="generate-btn">生成時間表</button>
      </div>

      <div id="results" class="results hidden">
        <div class="sleep-summary" id="sleep-summary"></div>
        <div class="schedule-timeline">
          <h3 class="section-title">你的每日睡眠時間表</h3>
          <div id="timeline" class="timeline"></div>
        </div>
        <div class="tips-section">
          <h3 class="section-title">這個年齡的睡眠小撇步</h3>
          <ul id="tips-list" class="tips-list"></ul>
        </div>
        <div class="disclaimer">
          <span class="disclaimer-icon">🌟</span>
          <p>每個寶寶都不一樣。這份時間表只是一個起點——請根據孩子的睡意訊號做調整。如有疑問，請諮詢你的兒科醫師。</p>
        </div>
        <div class="related-articles">
          <h3>相關文章</h3>
          <div class="article-links">
            <a href="https://bloom-path.app/en/blog/newborn-sleep-guide" class="article-link">新生兒睡眠指南</a>
            <a href="https://bloom-path.app/en/blog/baby-nap-schedule-by-age" class="article-link">各年齡午睡時間表</a>
            <a href="https://bloom-path.app/en/blog/toddler-sleep-regression" class="article-link">睡眠倒退期完整說明</a>
          </div>
        </div>
      </div>
    </div>
  </main>

  <Footer lang={lang} />
</BaseLayout>

<style>
  .tool-page { min-height: 80vh; padding: 3rem 0 6rem; background: #F5F0EB; }
  .container { max-width: 800px; margin: 0 auto; padding: 0 1.5rem; }
  .tool-header { text-align: center; margin-bottom: 2.5rem; }
  .tool-icon { font-size: 3rem; margin-bottom: 1rem; }
  h1 { font-size: clamp(1.75rem, 4vw, 2.5rem); font-weight: 700; color: #4A4543; margin-bottom: 0.75rem; letter-spacing: -0.02em; }
  .tool-subtitle { font-size: 1.0625rem; color: #6b6461; max-width: 52ch; margin: 0 auto; line-height: 1.65; }
  .tool-card { background: #fff; border-radius: 16px; padding: 2rem; box-shadow: 0 2px 16px rgba(74,69,67,0.06); margin-bottom: 2rem; }
  .inputs-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1.5rem; margin-bottom: 2rem; }
  .input-label { display: block; font-size: 0.875rem; font-weight: 600; color: #4A4543; margin-bottom: 0.5rem; }
  .age-input-row { display: flex; align-items: center; gap: 0.625rem; border: 2px solid #e8e4e0; border-radius: 10px; padding: 0.625rem 1rem; background: #faf8f6; transition: border-color 0.2s; }
  .age-input-row:focus-within { border-color: #8D9B8E; }
  .number-input { border: none; background: transparent; font-size: 1.125rem; font-weight: 700; color: #4A4543; width: 60px; outline: none; }
  .input-unit { font-size: 0.875rem; color: #9d9896; }
  .time-input { width: 100%; border: 2px solid #e8e4e0; border-radius: 10px; padding: 0.75rem 1rem; font-size: 1.0625rem; font-weight: 600; color: #4A4543; background: #faf8f6; outline: none; transition: border-color 0.2s; cursor: pointer; }
  .time-input:focus { border-color: #8D9B8E; }
  .generate-btn { width: 100%; padding: 0.875rem; background: #8D9B8E; color: #fff; font-size: 1rem; font-weight: 700; border: none; border-radius: 10px; cursor: pointer; transition: background 0.2s, transform 0.1s; }
  .generate-btn:hover { background: #7a8a7b; }
  .generate-btn:active { transform: scale(0.98); }
  .hidden { display: none; }
  .results { animation: fadeIn 0.35s ease; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
  .sleep-summary { display: grid; grid-template-columns: repeat(3,1fr); gap: 1rem; margin-bottom: 2rem; }
  .summary-card { background: #fff; border-radius: 14px; padding: 1.25rem; text-align: center; box-shadow: 0 2px 12px rgba(74,69,67,0.05); }
  .summary-icon { font-size: 1.5rem; margin-bottom: 0.375rem; }
  .summary-value { font-size: 1.375rem; font-weight: 800; color: #4A4543; margin-bottom: 0.25rem; }
  .summary-label { font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: #9d9896; }
  .schedule-timeline { background: #fff; border-radius: 16px; padding: 2rem; box-shadow: 0 2px 12px rgba(74,69,67,0.05); margin-bottom: 1.5rem; }
  .section-title { font-size: 1rem; font-weight: 700; color: #4A4543; margin-bottom: 1.5rem; }
  .timeline { display: flex; flex-direction: column; }
  .timeline-item { display: flex; align-items: stretch; gap: 1rem; }
  .timeline-line-wrap { display: flex; flex-direction: column; align-items: center; flex-shrink: 0; width: 20px; }
  .timeline-dot { width: 14px; height: 14px; border-radius: 50%; background: var(--dot-color, #8D9B8E); flex-shrink: 0; margin-top: 0.375rem; border: 2px solid #fff; box-shadow: 0 0 0 2px var(--dot-color, #8D9B8E); }
  .timeline-connector { flex: 1; width: 2px; background: #e8e4e0; margin: 4px auto 0; }
  .timeline-item:last-child .timeline-connector { display: none; }
  .timeline-content { padding-bottom: 1.25rem; flex: 1; }
  .timeline-time { font-size: 0.8125rem; font-weight: 700; margin-bottom: 0.125rem; }
  .timeline-event { font-size: 0.9375rem; font-weight: 600; color: #4A4543; }
  .timeline-detail { font-size: 0.8125rem; color: #6b6461; margin-top: 0.125rem; line-height: 1.5; }
  .tips-section { background: #fff; border-radius: 14px; padding: 1.5rem; box-shadow: 0 2px 12px rgba(74,69,67,0.05); margin-bottom: 1.5rem; }
  .tips-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.75rem; }
  .tips-list li { font-size: 0.9375rem; color: #5c5856; line-height: 1.55; padding-left: 1.5rem; position: relative; }
  .tips-list li::before { content: "\2192"; position: absolute; left: 0; color: #8D9B8E; font-weight: 700; }
  .disclaimer { background: rgba(212,181,176,0.15); border: 1px solid rgba(212,181,176,0.4); border-radius: 12px; padding: 1.25rem 1.5rem; display: flex; gap: 0.75rem; align-items: flex-start; margin-bottom: 2rem; }
  .disclaimer-icon { font-size: 1.125rem; flex-shrink: 0; margin-top: 0.1rem; }
  .disclaimer p { font-size: 0.875rem; color: #6b6461; line-height: 1.65; margin: 0; }
  .related-articles h3 { font-size: 1rem; font-weight: 700; color: #4A4543; margin-bottom: 0.875rem; }
  .article-links { display: flex; flex-wrap: wrap; gap: 0.625rem; }
  .article-link { font-size: 0.875rem; color: #8D9B8E; text-decoration: none; padding: 0.375rem 0.875rem; border: 1px solid rgba(141,155,142,0.4); border-radius: 20px; transition: all 0.2s ease; }
  .article-link:hover { background: #8D9B8E; color: #fff; border-color: #8D9B8E; }
  @media (max-width: 640px) { .inputs-grid { grid-template-columns: 1fr; } .sleep-summary { grid-template-columns: 1fr; } }
</style>

<script>
  interface SleepProfile {
    label: string;
    totalMin: number;
    totalMax: number;
    naps: number;
    napMin: number;
    napMax: number;
    wakeWindows: number[];
    tips: string[];
  }

  function getSleepProfile(months: number): SleepProfile {
    if (months <= 1) return { label: "新生兒", totalMin: 14, totalMax: 17, naps: 4, napMin: 30, napMax: 90, wakeWindows: [0.75, 1, 1, 1], tips: ["新生兒全天候以 2-4 小時為週期睡眠。", "觀察睡意訊號：揉眼睛、打哈欠、變安靜。", "一致的睡前小儀式（即使只有 2 分鐘）能幫助入睡。", "安全睡眠：仰睡、平坦堅實的床面、床上無鬆散物品。", "日夜顛倒是正常的——保持夜晚昏暗和無趣。"] };
    if (months <= 3) return { label: "0-3 個月", totalMin: 14, totalMax: 17, naps: 4, napMin: 45, napMax: 90, wakeWindows: [1, 1.25, 1.25, 1.25], tips: ["大多數寶寶需要 4-5 次小睡。長時段的睡眠稍後才會來。", "這個年齡的清醒時段只有 45-90 分鐘。", "白噪音可以幫助寶寶度過睡眠週期轉換。", "6-8 週時，很多寶寶開始出現較長的夜間睡眠——鼓勵這樣做。", "跟著清醒時段走，而不是看時鐘。"] };
    if (months <= 5) return { label: "4-5 個月", totalMin: 12, totalMax: 16, naps: 3, napMin: 45, napMax: 90, wakeWindows: [1.5, 1.75, 2], tips: ["4 個月睡眠倒退期：睡眠週期成熟，醒來次數增加。", "三次小睡：2 次較長的加上下午一次短小睡。", "最後一次小睡應在下午 5:00-5:30 前結束，以保護夜間睡眠。", "開始簡單的睡前儀式：洗澡、喝奶、唱歌、入睡。", "睡前「困但清醒」有助培養獨立入睡技巧。"] };
    if (months <= 8) return { label: "6-8 個月", totalMin: 12, totalMax: 15, naps: 2, napMin: 60, napMax: 90, wakeWindows: [2.5, 2.75, 3], tips: ["大多數寶寶約 6-8 個月轉為 2 次小睡。", "跡象：抗拒第 3 次小睡、小睡非常短或就寢時間很晚。", "第 1 次小睡在起床約 2.5 小時後；第 2 次在第 1 次醒來約 3 小時後。", "最後一次小睡醒來和就寢之間留 3-4 小時。", "6 和 8 個月的睡眠倒退期很常見——保持一致性。"] };
    if (months <= 11) return { label: "9-11 個月", totalMin: 12, totalMax: 15, naps: 2, napMin: 60, napMax: 90, wakeWindows: [3, 3.25, 3.5], tips: ["兩次小睡通常持續到 12-15 個月。", "分離焦慮在 9 個月達到高峰，可能影響睡眠。", "避免午睡時間拖到下午太晚。", "如果體重正常，9 個月可以慢慢減少夜奶。", "固定的時間表是最好的工具——寶寶靠規律茁壯。"] };
    if (months <= 15) return { label: "12-15 個月", totalMin: 11, totalMax: 14, naps: 2, napMin: 60, napMax: 90, wakeWindows: [3.5, 3.5, 4], tips: ["平均轉為 1 次小睡發生在 15-18 個月。不用急。", "準備好的跡象：抗拒兩次小睡或就寢時間很晚。", "轉換期間 1 次和 2 次小睡交替是正常的。", "每天晚上保持一致的平靜睡前儀式。", "12 個月的倒退期讓很多爸媽措手不及——它會過去的。"] };
    if (months <= 24) return { label: "16-24 個月", totalMin: 11, totalMax: 14, naps: 1, napMin: 60, napMax: 120, wakeWindows: [5, 6], tips: ["午餐後的一次小睡最理想，通常是中午 12:00-12:30。", "小睡時長因人而異：1-2.5 小時都正常。", "如果小睡開始擠壓就寢時間，上限設在 2 小時。", "即使沒睡著，床上的安靜休息時間也能維持規律。", "18 個月倒退期可能造成拒絕小睡——要堅持。"] };
    if (months <= 36) return { label: "2-3 歲", totalMin: 11, totalMax: 14, naps: 1, napMin: 60, napMax: 90, wakeWindows: [5.5, 6.5], tips: ["大多數 2-3 歲的孩子仍受益於一次午間小睡。", "部分 3 歲孩子已不睡——改為 45 分鐘安靜時間。", "就寢時間通常是晚上 7:00-8:00。", "睡前 1 小時避免螢幕——螢幕會延遲褪黑激素分泌。", "夜間恐懼在這個階段出現——保持令人安心的睡前儀式。"] };
    return { label: "3-5 歲", totalMin: 10, totalMax: 13, naps: 0, napMin: 0, napMax: 0, wakeWindows: [], tips: ["大多數孩子在 3-5 歲之間放棄午睡。", "改為在自己房間 30-45 分鐘的安靜休息時間。", "就寢時間稍稍推遲：晚上 7:30-8:30。", "睡眠需求仍高——目標是 10-13 小時總睡眠。", "固定的就寢時間有助於專注力、情緒和學習。", "這個年齡完全避免臥室裡有螢幕。"] };
  }

  function parseTime(t: string): number {
    const p = t.split(":");
    return parseInt(p[0]) * 60 + parseInt(p[1]);
  }

  function toAmPm(mins: number): string {
    const n = ((mins % 1440) + 1440) % 1440;
    const h = Math.floor(n / 60);
    const m = n % 60;
    const ap = h < 12 ? "上午" : "下午";
    const dh = h === 0 ? 12 : h > 12 ? h - 12 : h;
    return ap + " " + dh + ":" + String(m).padStart(2,"0");
  }

  const COLORS: Record<string,string> = { wake:"#8D9B8E", nap:"#a8b8c8", rest:"#C4A882", routine:"#D4B5B0", sleep:"#4A4543" };

  const EVENT_NAMES: Record<string,string> = {
    "Wake up": "起床",
    "Quiet rest time": "安靜休息時間",
    "Nap 1": "第 1 次小睡",
    "Nap 2": "第 2 次小睡",
    "Catnap": "短小睡",
    "Wake from Nap 1": "第 1 次小睡結束",
    "Wake from Nap 2": "第 2 次小睡結束",
    "Wake from Catnap": "短小睡結束",
    "Bedtime routine begins": "睡前儀式開始",
    "Lights out / Bedtime": "關燈 / 就寢",
  };

  const EVENT_DETAILS: Record<string,string> = {
    "Start the day with natural light exposure.": "開始新的一天，接觸自然光。",
    "45 min in bed with books. No screens.": "在床上看書 45 分鐘。不用螢幕。",
    "Allow 5 min to wake fully before activity.": "讓孩子有 5 分鐘充分清醒再開始活動。",
    "Bath, PJs, milk/water, story, song. Dim lights.": "洗澡、換睡衣、喝奶或水、說故事、唱歌。調暗燈光。",
    "Dark, cool room (65-68F / 18-20C).": "昏暗涼爽的房間（18-20°C）。",
  };

  document.getElementById("generate-btn")?.addEventListener("click", () => {
    const ageEl = document.getElementById("child-age") as HTMLInputElement;
    const wakeEl = document.getElementById("wake-time") as HTMLInputElement;
    const bedEl = document.getElementById("bed-time") as HTMLInputElement;
    const months = parseInt(ageEl.value) || 0;
    const wake = parseTime(wakeEl.value || "07:00");
    const bed = parseTime(bedEl.value || "19:30");
    const p = getSleepProfile(months);

    const events: Array<{time:number;event:string;detail:string;type:string}> = [];
    events.push({ time: wake, event: "起床", detail: "開始新的一天，接觸自然光。", type: "wake" });

    if (p.naps === 0) {
      events.push({ time: wake + 300, event: "安靜休息時間", detail: "在床上看書 45 分鐘。不用螢幕。", type: "rest" });
    } else {
      let cur = wake;
      for (let i = 0; i < p.naps; i++) {
        const ww = p.wakeWindows[i] !== undefined ? p.wakeWindows[i] : p.wakeWindows[p.wakeWindows.length - 1];
        const ns = cur + Math.round(ww * 60);
        const nl = Math.round((p.napMin + p.napMax) / 2);
        const napNames = ["第 1 次小睡", "第 2 次小睡", "短小睡"];
        const wakeNames = ["第 1 次小睡結束", "第 2 次小睡結束", "短小睡結束"];
        const name = napNames[i] || ("第 " + (i+1) + " 次小睡");
        const wakeName = wakeNames[i] || ("第 " + (i+1) + " 次小睡結束");
        events.push({ time: ns, event: name, detail: "約 " + nl + " 分鐘。睡前放鬆：5 分鐘。", type: "nap" });
        cur = ns + nl;
        events.push({ time: cur, event: wakeName, detail: "讓孩子有 5 分鐘充分清醒再開始活動。", type: "wake" });
      }
    }
    events.push({ time: bed - 30, event: "睡前儀式開始", detail: "洗澡、換睡衣、喝奶或水、說故事、唱歌。調暗燈光。", type: "routine" });
    events.push({ time: bed, event: "關燈 / 就寢", detail: "昏暗涼爽的房間（18-20°C）。", type: "sleep" });
    events.sort((a,b) => a.time - b.time);

    const nightSleep = bed > wake ? 1440 - (bed - wake) : wake - bed;

    const napLabel = p.naps === 0 ? "僅安靜休息" : p.naps === 1 ? "1 次小睡" : p.naps + " 次小睡";

    const summaryEl = document.getElementById("sleep-summary")!;
    summaryEl.innerHTML =
      '<div class="summary-card"><div class="summary-icon">😴</div><div class="summary-value">' + p.totalMin + "–" + p.totalMax + 'h</div><div class="summary-label">建議總睡眠</div></div>' +
      '<div class="summary-card"><div class="summary-icon">☀️</div><div class="summary-value">' + napLabel + '</div><div class="summary-label">白天睡眠</div></div>' +
      '<div class="summary-card"><div class="summary-icon">🌙</div><div class="summary-value">' + (nightSleep/60).toFixed(1) + 'h</div><div class="summary-label">夜間睡眠（約）</div></div>';

    document.getElementById("timeline")!.innerHTML = events.map((item, idx) => {
      const c = COLORS[item.type] || "#8D9B8E";
      return '<div class="timeline-item"><div class="timeline-line-wrap"><div class="timeline-dot" style="--dot-color:' + c + '"></div>' + (idx < events.length-1 ? '<div class="timeline-connector"></div>' : '') + '</div><div class="timeline-content"><div class="timeline-time" style="color:' + c + '">' + toAmPm(item.time) + '</div><div class="timeline-event">' + item.event + '</div><div class="timeline-detail">' + item.detail + '</div></div></div>';
    }).join("");

    document.getElementById("tips-list")!.innerHTML = p.tips.map(t => "<li>" + t + "</li>").join("");

    const res = document.getElementById("results")!;
    res.classList.remove("hidden");
    res.scrollIntoView({ behavior: "smooth", block: "nearest" });
  });
</script>
