---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import ToolsNav from '../../../components/ToolsNav.astro';

const lang = 'zh';
---

<BaseLayout
  title="發展里程碑檢測 | BloomPath"
  description="從動作、語言、認知、社交情緒到生活自理，查看孩子在各年齡階段的發展里程碑。BloomPath 免費互動工具。"
  lang={lang}
>
  <Header lang={lang} />
  <div class="container" style="padding-top:1.5rem"><ToolsNav lang={lang} current="milestone-checker" /></div>

  <main class="tool-page">
    <div class="container">

      <div class="tool-hero">
        <div class="tool-badge">免費工具</div>
        <h1>發展里程碑檢測</h1>
        <p class="tool-intro">
          探索大多數孩子在各年齡階段、五大發展領域的表現。
          記住——每個孩子都有自己的成長節奏。
        </p>
      </div>

      <div class="tool-card">
        <div class="input-section">
          <label for="age-select" class="input-label">孩子的年齡</label>
          <div class="age-control">
            <input
              type="range"
              id="age-slider"
              min="0"
              max="72"
              value="12"
              step="1"
              class="age-slider"
              aria-label="Child age in months"
            />
            <div class="age-display">
              <span id="age-value">12</span>
              <span class="age-unit">個月</span>
            </div>
          </div>
          <div class="age-presets">
            <button class="preset-btn" data-age="3">3 個月</button>
            <button class="preset-btn" data-age="6">6 個月</button>
            <button class="preset-btn" data-age="9">9 個月</button>
            <button class="preset-btn" data-age="12">1 歲</button>
            <button class="preset-btn" data-age="18">18 個月</button>
            <button class="preset-btn" data-age="24">2 歲</button>
            <button class="preset-btn" data-age="36">3 歲</button>
            <button class="preset-btn" data-age="48">4 歲</button>
            <button class="preset-btn" data-age="60">5 歲</button>
            <button class="preset-btn" data-age="72">6 歲</button>
          </div>
        </div>

        <div id="results" class="results-section" aria-live="polite">
          <!-- Populated by JS -->
        </div>

        <div class="disclaimer-box">
          <span class="disclaimer-icon">&#x2665;</span>
          <p>每個孩子的發展節奏不同。這些里程碑反映的是一般參考範圍，不是硬性截止時間。如果你有任何擔心，請諮詢你的兒科醫師。</p>
        </div>
      </div>

      <div class="related-articles">
        <h2>相關文章</h2>
        <div class="article-links">
          <a href="/en/blog/developmental-milestones-first-year" class="article-link">
            <span class="article-link-icon">&#x1F4D6;</span>
            <span>寶寶第一年的發展里程碑</span>
          </a>
          <a href="/en/blog/language-development-stages" class="article-link">
            <span class="article-link-icon">&#x1F4D6;</span>
            <span>語言發展：各階段可以期待什麼</span>
          </a>
          <a href="/en/blog/when-to-talk-to-pediatrician" class="article-link">
            <span class="article-link-icon">&#x1F4D6;</span>
            <span>什麼時候該去找兒科醫師談談孩子的發展</span>
          </a>
        </div>
      </div>

    </div>
  </main>

  <Footer lang={lang} />
</BaseLayout>

<style>
  .tool-page {
    padding: 4rem 0 2rem;
    min-height: 60vh;
  }

  .tool-hero {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .tool-badge {
    display: inline-block;
    background: rgba(141, 155, 142, 0.12);
    color: #8D9B8E;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.25rem 0.75rem;
    border-radius: 100px;
    margin-bottom: 1rem;
  }

  .tool-hero h1 {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 700;
    color: #4A4543;
    letter-spacing: -0.02em;
    margin-bottom: 0.75rem;
  }

  .tool-intro {
    font-size: 1.0625rem;
    color: #7A7573;
    max-width: 52ch;
    margin: 0 auto;
    line-height: 1.65;
  }

  .tool-card {
    background: #FFFFFF;
    border-radius: 20px;
    padding: 2.5rem;
    box-shadow: 0 2px 24px rgba(74, 69, 67, 0.06);
    max-width: 860px;
    margin: 0 auto 3rem;
  }

  .input-label {
    display: block;
    font-size: 0.875rem;
    font-weight: 600;
    color: #4A4543;
    margin-bottom: 1rem;
    letter-spacing: 0.01em;
  }

  .age-control {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .age-slider {
    flex: 1;
    -webkit-appearance: none;
    height: 6px;
    border-radius: 3px;
    background: linear-gradient(to right, #8D9B8E 0%, #8D9B8E var(--progress, 16.7%), #EDE6DF var(--progress, 16.7%), #EDE6DF 100%);
    outline: none;
    cursor: pointer;
  }

  .age-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: #8D9B8E;
    cursor: pointer;
    box-shadow: 0 2px 8px rgba(141, 155, 142, 0.4);
    transition: transform 0.15s ease;
  }

  .age-slider::-webkit-slider-thumb:hover {
    transform: scale(1.15);
  }

  .age-display {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 60px;
  }

  #age-value {
    font-size: 2rem;
    font-weight: 700;
    color: #8D9B8E;
    line-height: 1;
  }

  .age-unit {
    font-size: 0.75rem;
    color: #7A7573;
    margin-top: 0.125rem;
  }

  .age-presets {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .preset-btn {
    padding: 0.3rem 0.75rem;
    border: 1.5px solid #EDE6DF;
    border-radius: 100px;
    background: transparent;
    color: #7A7573;
    font-size: 0.8125rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
    font-family: inherit;
  }

  .preset-btn:hover,
  .preset-btn.active {
    border-color: #8D9B8E;
    background: rgba(141, 155, 142, 0.08);
    color: #4A4543;
  }

  .results-section {
    margin-top: 2rem;
  }

  .results-header {
    text-align: center;
    margin-bottom: 1.75rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid #F5F0EB;
  }

  .results-age-label {
    font-size: 1.125rem;
    font-weight: 600;
    color: #4A4543;
  }

  .results-age-label span {
    color: #8D9B8E;
  }

  .domains-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  @media (min-width: 640px) {
    .domains-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .domain-card {
    background: #F5F0EB;
    border-radius: 14px;
    padding: 1.25rem 1.375rem;
  }

  .domain-header {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    margin-bottom: 0.875rem;
  }

  .domain-icon {
    font-size: 1.25rem;
  }

  .domain-name {
    font-size: 0.875rem;
    font-weight: 700;
    color: #4A4543;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .milestone-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .milestone-item {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.9rem;
    color: #4A4543;
    line-height: 1.5;
  }

  .milestone-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #8D9B8E;
    flex-shrink: 0;
    margin-top: 0.375rem;
  }

  .disclaimer-box {
    margin-top: 2rem;
    background: rgba(212, 181, 176, 0.12);
    border: 1px solid rgba(212, 181, 176, 0.3);
    border-radius: 12px;
    padding: 1rem 1.25rem;
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .disclaimer-icon {
    color: #D4B5B0;
    font-size: 1rem;
    flex-shrink: 0;
    margin-top: 0.125rem;
  }

  .disclaimer-box p {
    font-size: 0.875rem;
    color: #7A7573;
    line-height: 1.6;
  }

  .related-articles {
    max-width: 860px;
    margin: 0 auto;
  }

  .related-articles h2 {
    font-size: 1.25rem;
    font-weight: 700;
    color: #4A4543;
    margin-bottom: 1rem;
  }

  .article-links {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .article-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: #FFFFFF;
    border: 1px solid #F5F0EB;
    border-radius: 12px;
    padding: 0.875rem 1.125rem;
    color: #4A4543;
    font-size: 0.9375rem;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .article-link:hover {
    border-color: #8D9B8E;
    background: rgba(141, 155, 142, 0.04);
    color: #4A4543;
  }

  .article-link-icon {
    font-size: 1rem;
    flex-shrink: 0;
  }
</style>

