---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const now = new Date();
const publishedPosts = allPosts
  .filter((post) => post.data.pubDate <= now)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const featuredPosts = publishedPosts.slice(0, 4);

const categories = [
  {
    title: 'Montessori Basics',
    titleZh: '蒙特梭利基礎',
    desc: 'Self-directed learning methods you can apply at home from day one.',
    icon: 'M12 3L4 9v12h16V9l-8-6zm0 3l5 3.75V18h-3v-4h-4v4H7V9.75L12 6z',
  },
  {
    title: 'Positive Parenting',
    titleZh: '正向教養',
    desc: 'Research-based approaches that build cooperation without punishment.',
    icon: 'M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z',
  },
  {
    title: 'Development Milestones',
    titleZh: '發展里程碑',
    desc: 'Age-appropriate benchmarks and what to do when you have concerns.',
    icon: 'M13 2L3 14h9l-1 8 10-12h-9l1-8z',
  },
  {
    title: 'Home Environment',
    titleZh: '居家環境',
    desc: 'Design spaces that encourage independence and exploration.',
    icon: 'M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z',
  },
  {
    title: 'Reviews & Guides',
    titleZh: '評測與指南',
    desc: 'Honest toy, book, and resource reviews from parents who test everything.',
    icon: 'M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z',
  },
  {
    title: 'Nutrition & Health',
    titleZh: '營養與健康',
    desc: 'Practical feeding guides and wellness tips backed by pediatric research.',
    icon: 'M18.06 22.99h.01c.35-.01.67-.19.89-.49l.01-.02c.28-.38.4-.85.34-1.32-.06-.47-.26-.9-.57-1.22l-3.6-3.6c-.31-.31-.74-.49-1.18-.49h-1.44l-3.58-3.58c.74-1.54.47-3.42-.8-4.69-1.56-1.56-4.09-1.56-5.66 0-1.56 1.56-1.56 4.09 0 5.66 1.27 1.27 3.15 1.54 4.69.8l3.58 3.58v1.44c0 .44.18.87.49 1.18l3.6 3.6c.32.31.75.51 1.22.57.47.06.94-.06 1.32-.34z',
  },
];
---

<BaseLayout title="BloomPath | Grow Together, One Step at a Time">
  <Header />

  <!-- Hero Section — Asymmetric Split -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-content">
        <span class="hero-badge">Research-backed parenting</span>
        <h1>Grow Together,<br/>One Step at a Time</h1>
        <p class="hero-subtitle-zh">每一步，都是成長的開始</p>
        <p class="hero-desc">
          Practical guides, developmental insights, and free tools
          to help your child thrive — written by parents, backed by science.
        </p>
        <div class="hero-actions">
          <a href="/blog" class="btn btn-primary">Explore Articles</a>
          <a href="#newsletter" class="btn btn-outline">Get Weekly Tips</a>
        </div>
        <div class="hero-trust">
          <div class="trust-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
              <polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
            <span>Evidence-based</span>
          </div>
          <div class="trust-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
              <polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
            <span>Written by parents</span>
          </div>
          <div class="trust-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
              <polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
            <span>100% free</span>
          </div>
        </div>
      </div>
      <div class="hero-visual">
        <div class="hero-shape hero-shape-1"></div>
        <div class="hero-shape hero-shape-2"></div>
        <div class="hero-shape hero-shape-3"></div>
        <div class="hero-card floating">
          <div class="card-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#2D6A4F" stroke-width="2" stroke-linecap="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
          <span>Trusted guidance</span>
        </div>
        <div class="hero-card floating-delayed">
          <div class="card-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#F4A261" stroke-width="2" stroke-linecap="round">
              <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
            </svg>
          </div>
          <span>Track milestones</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Categories Section -->
  <section id="categories" class="categories">
    <div class="container">
      <div class="section-header">
        <span class="section-label">Topics</span>
        <h2>What We Cover</h2>
        <p class="section-desc">Deep dives into the topics that matter most during the early years.</p>
      </div>
      <div class="categories-grid">
        {categories.map((cat, i) => (
          <div class="category-item" style={`--delay: ${i * 0.08}s`}>
            <div class="category-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="var(--color-forest)" opacity="0.8">
                <path d={cat.icon}/>
              </svg>
            </div>
            <div class="category-text">
              <h3>{cat.title}</h3>
              <span class="category-zh">{cat.titleZh}</span>
              <p>{cat.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Featured Articles -->
  {featuredPosts.length > 0 && (
    <section class="featured">
      <div class="container">
        <div class="section-header">
          <span class="section-label">Latest</span>
          <h2>Recent Articles</h2>
          <p class="section-desc">Practical, research-backed guides updated regularly.</p>
        </div>
        <div class="articles-grid">
          {featuredPosts.map((post, i) => (
            <article class="article-card" style={`--delay: ${i * 0.1}s`}>
              <div class="article-meta">
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                </time>
                {post.data.lang && (
                  <span class="lang-tag">{post.data.lang === 'zh-TW' ? 'ZH' : 'EN'}</span>
                )}
              </div>
              <h3>
                <a href={`/blog/${post.id}`}>{post.data.title}</a>
              </h3>
              <p>{post.data.description}</p>
              {post.data.tags && post.data.tags.length > 0 && (
                <div class="article-tags">
                  {post.data.tags.slice(0, 3).map((tag: string) => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
              )}
            </article>
          ))}
        </div>
        <div class="section-cta">
          <a href="/blog" class="btn btn-outline">View All Articles</a>
        </div>
      </div>
    </section>
  )}

  <!-- Free Tools Section -->
  <section id="tools" class="tools">
    <div class="container">
      <div class="section-header">
        <span class="section-label">Free Tools</span>
        <h2>Built for Busy Parents</h2>
        <p class="section-desc">Interactive tools to support your child's growth — launching soon.</p>
      </div>
      <div class="tools-grid">
        <div class="tool-card">
          <div class="tool-badge">Coming Soon</div>
          <div class="tool-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-forest)" stroke-width="1.5" stroke-linecap="round">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
              <line x1="16" y1="2" x2="16" y2="6"/>
              <line x1="8" y1="2" x2="8" y2="6"/>
              <line x1="3" y1="10" x2="21" y2="10"/>
              <path d="M8 14l2 2 4-4"/>
            </svg>
          </div>
          <h3>Milestone Tracker</h3>
          <p>Track your child's developmental milestones with age-appropriate checklists based on pediatric guidelines.</p>
        </div>
        <div class="tool-card">
          <div class="tool-badge">Coming Soon</div>
          <div class="tool-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-orange)" stroke-width="1.5" stroke-linecap="round">
              <circle cx="12" cy="12" r="10"/>
              <path d="M8 12l2 2 4-4"/>
            </svg>
          </div>
          <h3>Activity Recommender</h3>
          <p>Get personalized activity suggestions based on your child's age, interests, and developmental stage.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Newsletter Section -->
  <section id="newsletter" class="newsletter">
    <div class="container">
      <div class="newsletter-inner">
        <div class="newsletter-content">
          <span class="section-label">Newsletter</span>
          <h2>Weekly Parenting Insights</h2>
          <p>
            One practical, research-backed tip delivered to your inbox every week.
            No spam. Unsubscribe anytime.
          </p>
        </div>
        <div class="newsletter-form-area">
          <p class="newsletter-placeholder">
            Newsletter signup coming soon. Follow us to stay updated.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section id="about" class="about">
    <div class="container">
      <div class="about-inner">
        <div class="about-content">
          <span class="section-label">About</span>
          <h2>Built by Parents, Backed by Research</h2>
          <p>
            BloomPath started from a simple frustration: parenting advice is everywhere,
            but finding reliable, evidence-based guidance shouldn't require a PhD.
          </p>
          <p>
            Every article we publish references peer-reviewed studies, pediatric guidelines,
            or expert recommendations. We translate the research so you can act on it today.
          </p>
          <div class="about-values">
            <div class="value">
              <strong>Evidence First</strong>
              <span>Every claim links to its source</span>
            </div>
            <div class="value">
              <strong>Practical Focus</strong>
              <span>Actionable steps, not abstract theory</span>
            </div>
            <div class="value">
              <strong>Inclusive</strong>
              <span>Content in English and Traditional Chinese</span>
            </div>
          </div>
        </div>
        <div class="about-visual">
          <div class="about-shape"></div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  /* ========== Hero ========== */
  .hero {
    padding: 4rem 0 5rem;
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, var(--color-bg) 60%, var(--color-cream) 100%);
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }

  .hero-badge {
    display: inline-block;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--color-forest);
    background: rgba(45, 106, 79, 0.08);
    padding: 0.375rem 1rem;
    border-radius: 100px;
    margin-bottom: 1.25rem;
  }

  .hero h1 {
    font-size: clamp(2.25rem, 5vw, 3.75rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--color-text);
  }

  .hero-subtitle-zh {
    font-size: 1.125rem;
    color: var(--color-forest);
    margin-top: 0.75rem;
    font-weight: 500;
    opacity: 0.85;
  }

  .hero-desc {
    font-size: 1.0625rem;
    color: var(--color-text-light);
    line-height: 1.7;
    max-width: 50ch;
    margin-top: 1.25rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    font-size: 0.9375rem;
    font-weight: 600;
    padding: 0.75rem 1.5rem;
    border-radius: 10px;
    border: none;
    text-decoration: none;
    transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .btn:active {
    transform: translateY(1px) scale(0.98);
  }

  .btn-primary {
    background: var(--color-forest);
    color: var(--color-white);
  }

  .btn-primary:hover {
    background: var(--color-forest-dark);
    color: var(--color-white);
  }

  .btn-outline {
    background: transparent;
    color: var(--color-forest);
    border: 1.5px solid var(--color-forest);
  }

  .btn-outline:hover {
    background: var(--color-forest);
    color: var(--color-white);
  }

  .hero-trust {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    margin-top: 2rem;
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
    color: var(--color-text-light);
  }

  .trust-item svg {
    color: var(--color-forest);
    flex-shrink: 0;
  }

  /* Hero visual */
  .hero-visual {
    position: relative;
    min-height: 280px;
    display: none;
  }

  .hero-shape {
    position: absolute;
    border-radius: 50%;
  }

  .hero-shape-1 {
    width: 320px;
    height: 320px;
    background: radial-gradient(circle, rgba(45, 106, 79, 0.08) 0%, transparent 70%);
    top: -20px;
    right: 20px;
  }

  .hero-shape-2 {
    width: 200px;
    height: 200px;
    background: radial-gradient(circle, rgba(244, 162, 97, 0.1) 0%, transparent 70%);
    bottom: 20px;
    right: 140px;
  }

  .hero-shape-3 {
    width: 120px;
    height: 120px;
    background: radial-gradient(circle, rgba(45, 106, 79, 0.06) 0%, transparent 70%);
    top: 60px;
    left: 20px;
  }

  .hero-card {
    position: absolute;
    background: var(--color-white);
    border: 1px solid rgba(45, 106, 79, 0.1);
    border-radius: 16px;
    padding: 1.25rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.875rem;
    box-shadow: 0 8px 30px -10px rgba(0, 0, 0, 0.06);
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-text);
  }

  .hero-card .card-icon {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .hero-card:nth-child(4) .card-icon {
    background: rgba(45, 106, 79, 0.08);
  }

  .hero-card:nth-child(5) .card-icon {
    background: rgba(244, 162, 97, 0.12);
  }

  .floating {
    top: 40px;
    right: 40px;
    animation: float 6s ease-in-out infinite;
  }

  .floating-delayed {
    bottom: 60px;
    left: 20px;
    animation: float 6s ease-in-out infinite;
    animation-delay: -3s;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-12px); }
  }

  /* ========== Section Shared ========== */
  .section-header {
    margin-bottom: 3rem;
  }

  .section-label {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-orange);
    margin-bottom: 0.5rem;
  }

  .section-header h2 {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-text);
    line-height: 1.2;
  }

  .section-desc {
    font-size: 1rem;
    color: var(--color-text-light);
    margin-top: 0.625rem;
    max-width: 55ch;
    line-height: 1.6;
  }

  .section-cta {
    text-align: center;
    margin-top: 2.5rem;
  }

  /* ========== Categories ========== */
  .categories {
    padding: 5rem 0;
  }

  .categories-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    background: rgba(45, 106, 79, 0.08);
    border-radius: 20px;
    overflow: hidden;
  }

  .category-item {
    display: flex;
    gap: 1.25rem;
    padding: 1.75rem;
    background: var(--color-white);
    transition: background 0.2s ease;
  }

  .category-item:hover {
    background: var(--color-cream);
  }

  .category-icon {
    width: 48px;
    height: 48px;
    border-radius: 14px;
    background: rgba(45, 106, 79, 0.06);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .category-text h3 {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.3;
  }

  .category-zh {
    font-size: 0.8125rem;
    color: var(--color-forest);
    opacity: 0.7;
    display: block;
    margin-top: 0.125rem;
  }

  .category-text p {
    font-size: 0.9375rem;
    color: var(--color-text-light);
    line-height: 1.6;
    margin-top: 0.375rem;
  }

  /* ========== Featured Articles ========== */
  .featured {
    padding: 5rem 0;
    background: var(--color-cream);
  }

  .articles-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  .article-card {
    background: var(--color-white);
    border-radius: 16px;
    padding: 1.75rem;
    border: 1px solid rgba(45, 106, 79, 0.06);
    transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .article-card:hover {
    border-color: rgba(45, 106, 79, 0.15);
    box-shadow: 0 8px 30px -10px rgba(45, 106, 79, 0.08);
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    margin-bottom: 0.75rem;
  }

  .article-meta time {
    font-size: 0.8125rem;
    color: var(--color-text-light);
  }

  .lang-tag {
    font-size: 0.6875rem;
    font-weight: 600;
    padding: 0.125rem 0.5rem;
    border-radius: 4px;
    background: rgba(45, 106, 79, 0.08);
    color: var(--color-forest);
    letter-spacing: 0.04em;
  }

  .article-card h3 {
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1.4;
    letter-spacing: -0.01em;
  }

  .article-card h3 a {
    color: var(--color-text);
    text-decoration: none;
  }

  .article-card h3 a:hover {
    color: var(--color-forest);
  }

  .article-card p {
    font-size: 0.9375rem;
    color: var(--color-text-light);
    line-height: 1.6;
    margin-top: 0.5rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-top: 0.875rem;
  }

  .tag {
    font-size: 0.75rem;
    color: var(--color-text-light);
    background: rgba(45, 106, 79, 0.05);
    padding: 0.1875rem 0.625rem;
    border-radius: 6px;
  }

  /* ========== Tools ========== */
  .tools {
    padding: 5rem 0;
  }

  .tools-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  .tool-card {
    position: relative;
    background: var(--color-white);
    border: 1px solid rgba(45, 106, 79, 0.08);
    border-radius: 20px;
    padding: 2.5rem 2rem;
    transition: all 0.25s ease;
  }

  .tool-card:hover {
    border-color: rgba(45, 106, 79, 0.15);
    box-shadow: 0 12px 40px -15px rgba(45, 106, 79, 0.08);
  }

  .tool-badge {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-orange-dark);
    background: rgba(244, 162, 97, 0.12);
    padding: 0.25rem 0.75rem;
    border-radius: 6px;
  }

  .tool-icon {
    width: 56px;
    height: 56px;
    border-radius: 16px;
    background: rgba(45, 106, 79, 0.06);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.25rem;
  }

  .tool-card:nth-child(2) .tool-icon {
    background: rgba(244, 162, 97, 0.1);
  }

  .tool-card h3 {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .tool-card p {
    font-size: 0.9375rem;
    color: var(--color-text-light);
    line-height: 1.6;
    max-width: 45ch;
  }

  /* ========== Newsletter ========== */
  .newsletter {
    padding: 5rem 0;
    background: var(--color-forest-dark);
    color: var(--color-white);
  }

  .newsletter-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: center;
  }

  .newsletter .section-label {
    color: var(--color-orange);
  }

  .newsletter h2 {
    color: var(--color-white);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .newsletter-content p {
    color: rgba(255, 255, 255, 0.7);
    font-size: 1rem;
    line-height: 1.7;
    margin-top: 0.75rem;
    max-width: 45ch;
