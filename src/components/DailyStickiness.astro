    var normalAnswersEn = {
      'infant-no-smile': { status: 'watch', text: 'Most babies smile by 2 months. If no social smile by 3 months, mention it to your pediatrician at the next visit.' },
      'infant-startle': { status: 'normal', text: 'Completely normal. The Moro reflex is present at birth and usually fades by 4-6 months.' },
