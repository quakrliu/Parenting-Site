    background: rgba(141, 155, 142, 0.06);
    padding: 0.25rem 0.625rem;
    border-radius: 6px;
    display: inline-block;
    margin-top: 0.875rem;
    align-self: flex-start;
  }

  .daily__tag:empty { display: none; }

  .daily__quote {
    font-size: 1rem;
    font-style: italic;
    color: var(--color-text);
    line-height: 1.7;
    border: none;
    padding: 0;
    margin: 0;
    background: none;
    flex: 1;
  }

  .daily__cite {
    font-size: 0.8125rem;
    font-style: normal;
    color: var(--color-text-light);
    margin-top: 0.75rem;
    display: block;
  }

  .daily__copy-btn {
    font-family: var(--font-primary);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-forest);
    background: rgba(141, 155, 142, 0.06);
    border: 1px solid rgba(141, 155, 142, 0.12);
    padding: 0.25rem 0.75rem;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .daily__copy-btn:hover {
    background: rgba(141, 155, 142, 0.12);
  }

  .daily__form {
    display: flex;
    gap: 0.625rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .daily__select {
    font-family: var(--font-primary);
    font-size: 0.875rem;
    padding: 0.5rem 0.875rem;
    border-radius: 10px;
    border: 1px solid rgba(141, 155, 142, 0.15);
    background: var(--color-white);
    color: var(--color-text);
    cursor: pointer;
    min-width: 140px;
    transition: border-color 0.2s ease;
  }

  .daily__select:focus {
    outline: none;
    border-color: var(--color-forest);
  }

  .daily__result {
    margin-top: 1rem;
    font-size: 0.9375rem;
    color: var(--color-text);
    line-height: 1.65;
  }

  .daily__result:empty { display: none; }

  .daily__result-badge {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.25rem 0.75rem;
    border-radius: 100px;
    margin-bottom: 0.5rem;
  }

  .daily__result--normal {
    background: rgba(141, 155, 142, 0.1);
    color: var(--color-forest);
  }

  .daily__result--watch {
    background: rgba(196, 168, 130, 0.12);
