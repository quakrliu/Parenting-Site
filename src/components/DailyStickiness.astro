  }

  .daily__icon--forest { background: rgba(141, 155, 142, 0.08); color: var(--color-forest); }
  .daily__icon--orange { background: rgba(196, 168, 130, 0.1); color: var(--color-orange-dark); }
  .daily__icon--pink { background: rgba(212, 181, 176, 0.12); color: #a8706a; }

  .daily__badge {
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
