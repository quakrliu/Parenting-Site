    resize: vertical;
    line-height: 1.6;
    transition: border-color 0.2s ease;
    margin-bottom: 0.75rem;
  }

  .daily__textarea:focus {
    outline: none;
    border-color: var(--color-forest);
  }

  .daily__streak {
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
