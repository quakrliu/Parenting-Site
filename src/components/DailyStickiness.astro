    display: flex;
    flex-direction: column;
  }

  .daily__card:hover {
    border-color: rgba(141, 155, 142, 0.15);
    box-shadow: 0 12px 36px -12px rgba(141, 155, 142, 0.08);
    transform: translateY(-2px);
  }

  .daily__card--normal {
    grid-column: 1 / 3;
  }

  .daily__card-header {
    display: flex;
