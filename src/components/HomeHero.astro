---
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: 'en' | 'zh';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="hero">
  <div class="hero__bg" aria-hidden="true">
    <img
      src="/images/hero-family.jpg"
      alt=""
      width="1920"
      height="1080"
      loading="eager"
      class="hero__bg-img"
    />
    <div class="hero__bg-overlay"></div>
  </div>
  <div class="container hero__grid">
    <div class="hero__content">
      <h1 set:html={t('hero.heading')} />
      <p class="hero__desc">{t('hero.desc')}</p>
      <div class="hero__actions">
        <a href={`/${lang}/blog`} class="btn btn--primary btn--lg">
          {t('hero.cta.articles')}
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
      <div class="hero__trust">
        <span class="hero__trust-item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          {t('hero.trust.evidence')}
        </span>
        <span class="hero__trust-item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          {t('hero.trust.parents')}
        </span>
        <span class="hero__trust-item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          {t('hero.trust.free')}
        </span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 92vh;
    min-height: 92dvh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero__bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
  }

  .hero__bg-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(105deg, rgba(250, 248, 245, 0.95) 0%, rgba(250, 248, 245, 0.82) 45%, rgba(250, 248, 245, 0.3) 75%, transparent 100%);
  }

  .hero__grid {
    position: relative;
    z-index: 1;
    padding: 8rem 0 6rem;
  }

  .hero__content {
    max-width: 620px;
  }

  .hero :global(h1) {
    font-size: 4rem;
    font-weight: 800;
    line-height: 1.04;
    letter-spacing: -0.04em;
    color: var(--color-text);
    text-wrap: balance;
  }

  .hero__desc {
    font-size: 1.1875rem;
    color: var(--color-text-light);
    line-height: 1.7;
    max-width: 50ch;
    margin-top: 1.75rem;
  }

  .hero__actions {
    margin-top: 2.5rem;
  }

  .hero__trust {
    display: flex;
    gap: 1.75rem;
    margin-top: 2.75rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(141, 155, 142, 0.12);
  }

  .hero__trust-item {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-text-light);
  }

  .hero__trust-item svg {
    color: var(--color-forest);
    flex-shrink: 0;
  }

  @media (max-width: 1023px) {
    .hero { min-height: auto; }
    .hero__grid { padding: 4rem 0 3rem; }
    .hero :global(h1) { font-size: clamp(2.25rem, 5.5vw, 3.5rem); }
    .hero__content { max-width: 100%; }
  }

  @media (max-width: 639px) {
    .hero :global(h1) { font-size: 2.125rem; }
    .hero__trust { flex-direction: column; gap: 0.5rem; }
  }

  @media (prefers-reduced-motion: no-preference) {
    .hero__bg-img {
      animation: hero-ken-burns 25s ease-in-out infinite alternate;
    }
    @keyframes hero-ken-burns {
      0% { transform: scale(1) translate(0, 0); }
      100% { transform: scale(1.06) translate(-1%, -1%); }
    }
  }
</style>
