---
interface Props {
  lang: 'en' | 'zh';
}

const { lang } = Astro.props;

const books = [
  {
    title: lang === 'zh' ? '正向教養工具包：30天打造平靜的家' : 'The Positive Parenting Toolkit: 30 Days to a Calmer Home',
    desc: lang === 'zh' ? '每天一個實用腳本，從崩潰到連結。' : 'Daily scripts for what to say when your toddler melts down.',
    url: 'https://www.amazon.com/dp/B0FNBYBQZQ',
    tag: lang === 'zh' ? '正向教養' : 'Positive Parenting',
  },
  {
    title: lang === 'zh' ? '孩子的前三年：焦慮父母的里程碑指南' : "Your Child's First 3 Years: A Milestone Guide",
    desc: lang === 'zh' ? '0-3歲發展里程碑，不再半夜 Google。' : 'What actually matters vs what you can stop googling at 2am.',
    url: 'https://www.amazon.com/dp/B0GVN67RLV',
    tag: lang === 'zh' ? '發展里程碑' : 'Milestones',
  },
  {
    title: lang === 'zh' ? '蒙特梭利居家指南：忙碌父母的入門書' : 'Montessori at Home: A Guide for Busy Parents',
    desc: lang === 'zh' ? '不需要花大錢買木製玩具的蒙特梭利。' : 'The philosophy without the Pinterest pressure.',
    url: 'https://www.amazon.com/dp/B0GVPNRL4F',
    tag: 'Montessori',
  },
];

const heading = lang === 'zh' ? '想讀完整版？' : 'Want the full guide?';
const subtext = lang === 'zh' ? '我們的電子書系列，把這些觀點整理成可執行的 30 天計畫。' : 'Our ebook series turns these ideas into actionable 30-day plans.';
---

<section class="book-cta">
  <div class="book-cta__header">
    <span class="book-cta__icon">📚</span>
    <div>
      <h3 class="book-cta__heading">{heading}</h3>
      <p class="book-cta__sub">{subtext}</p>
    </div>
  </div>
  <div class="book-cta__grid">
    {books.map((book) => (
      <a href={book.url} target="_blank" rel="noopener noreferrer" class="book-cta__card">
        <span class="book-cta__tag">{book.tag}</span>
        <h4>{book.title}</h4>
        <p>{book.desc}</p>
        <span class="book-cta__link">$4.99 on Amazon &rarr;</span>
      </a>
    ))}
  </div>
</section>

<style>
  .book-cta {
    margin-top: 3rem;
    padding: 2rem;
    background: var(--color-cream, #F5F0EB);
    border-radius: 16px;
    border: 1px solid rgba(141, 155, 142, 0.1);
  }

  .book-cta__header {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .book-cta__icon {
    font-size: 1.5rem;
    line-height: 1;
  }

  .book-cta__heading {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-text, #4A4543);
    margin: 0;
  }

  .book-cta__sub {
    font-size: 0.875rem;
    color: var(--color-text-light, #7A7572);
    margin: 0.25rem 0 0;
  }

  .book-cta__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .book-cta__card {
    background: white;
    border-radius: 12px;
    padding: 1.25rem;
    text-decoration: none;
    border: 1px solid rgba(141, 155, 142, 0.08);
    transition: all 0.25s ease;
  }

  .book-cta__card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px -8px rgba(74, 69, 67, 0.1);
  }

  .book-cta__tag {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 600;
    color: var(--color-forest, #8D9B8E);
    background: rgba(141, 155, 142, 0.1);
    padding: 0.125rem 0.5rem;
    border-radius: 999px;
    margin-bottom: 0.5rem;
  }

  .book-cta__card h4 {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-text, #4A4543);
    line-height: 1.3;
    margin: 0 0 0.375rem;
  }

  .book-cta__card p {
    font-size: 0.8125rem;
    color: var(--color-text-light, #7A7572);
    line-height: 1.5;
    margin: 0;
  }

  .book-cta__link {
    display: inline-block;
    margin-top: 0.75rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-forest, #8D9B8E);
  }

  @media (max-width: 768px) {
    .book-cta__grid { grid-template-columns: 1fr; }
  }
</style>
