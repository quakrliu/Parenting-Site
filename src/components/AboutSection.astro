---
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: 'en' | 'zh';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="about" class="about">
  <div class="container">
    <div class="about__inner">
      <div class="about__content">
        <span class="eyebrow">{t('section.about')}</span>
        <h2>{t('section.about.title')}</h2>
        <p>{t('section.about.p1')}</p>
        <p>{t('section.about.p2')}</p>
        <div class="about__values">
          <div class="about__value">
            <strong>{t('section.about.evidence')}</strong>
            <span>{t('section.about.evidence.desc')}</span>
          </div>
          <div class="about__value">
            <strong>{t('section.about.practical')}</strong>
            <span>{t('section.about.practical.desc')}</span>
          </div>
          <div class="about__value">
            <strong>{t('section.about.inclusive')}</strong>
            <span>{t('section.about.inclusive.desc')}</span>
          </div>
        </div>
      </div>
      <div class="about__visual" aria-hidden="true">
        <img
          src="/images/about-family.jpg"
          alt=""
          width="640"
          height="800"
          loading="lazy"
          class="about__img"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .about {
    padding: 7rem 0;
  }

  .about__inner {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: 4rem;
    align-items: center;
  }

  .about h2 {
    font-size: 2.25rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.15;
  }

  .about__content p {
    font-size: 1rem;
    color: var(--color-text-light);
    line-height: 1.7;
    margin-top: 1rem;
    max-width: 55ch;
  }

  .about__values {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(141, 155, 142, 0.08);
  }

  .about__value { display: flex; flex-direction: column; gap: 0.125rem; }
  .about__value strong { font-size: 0.9375rem; font-weight: 600; color: var(--color-forest); }
  .about__value span { font-size: 0.8125rem; color: var(--color-text-light); line-height: 1.5; }

  .about__visual {
    border-radius: 24px;
    overflow: hidden;
  }

  .about__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    aspect-ratio: 4 / 5;
    border-radius: 24px;
    transition: transform 0.5s cubic-bezier(0.32, 0.72, 0, 1);
  }

  .about__visual:hover .about__img {
    transform: scale(1.02);
  }

  @media (max-width: 1023px) {
    .about__inner { grid-template-columns: 1fr; }
    .about__visual { max-width: 480px; }
  }

  @media (max-width: 639px) {
    .about { padding: 4rem 0; }
    .about__values { grid-template-columns: 1fr; }
  }

  @media (prefers-reduced-motion: no-preference) {
    .about__visual {
      opacity: 0;
      transform: translateY(20px);
      animation: fade-up 0.6s cubic-bezier(0.32, 0.72, 0, 1) forwards;
    }
    @keyframes fade-up {
      to { opacity: 1; transform: translateY(0); }
    }
  }
</style>
