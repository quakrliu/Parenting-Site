---
import { useTranslations } from '../i18n/utils';
import type { CollectionEntry } from 'astro:content';

interface Props {
  lang: 'en' | 'zh';
  posts: CollectionEntry<'blog'>[];
}

const { lang, posts } = Astro.props;
const t = useTranslations(lang);

const dateLocale = lang === 'en' ? 'en-US' : 'zh-TW';
---

{posts.length > 0 && (
  <section class="articles">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">{t('section.latest')}</span>
        <h2>{t('section.latest.title')}</h2>
        <p class="section-desc">{t('section.latest.desc')}</p>
      </div>
      <div class="articles__grid">
        {posts.map((post) => (
          <article class="articles__card">
            <div class="articles__meta">
              <time datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString(dateLocale, { month: 'short', day: 'numeric', year: 'numeric' })}
              </time>
            </div>
            <h3><a href={`/${lang}/blog/${post.id}`}>{post.data.title}</a></h3>
            <p>{post.data.description}</p>
            {post.data.tags && post.data.tags.length > 0 && (
              <div class="articles__tags">
                {post.data.tags.slice(0, 3).map((tag: string) => (<span class="tag">{tag}</span>))}
              </div>
            )}
          </article>
        ))}
      </div>
      <div class="section-cta">
        <a href={`/${lang}/blog`} class="btn btn--ghost">{t('section.latest.viewAll')}</a>
      </div>
    </div>
  </section>
)}

<style>
  .articles {
    padding: 7rem 0;
  }

  .articles__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .articles__card {
    background: var(--color-white);
    border-radius: 20px;
    padding: 2rem;
    border: 1px solid rgba(141, 155, 142, 0.06);
    transition: all 0.3s cubic-bezier(0.32, 0.72, 0, 1);
    display: flex;
    flex-direction: column;
  }

  .articles__card:hover {
    border-color: rgba(141, 155, 142, 0.15);
    box-shadow: 0 12px 36px -12px rgba(141, 155, 142, 0.08);
    transform: translateY(-2px);
  }

  .articles__meta { margin-bottom: 0.625rem; }
  .articles__meta time {
    font-size: 0.8125rem;
    color: var(--color-text-light);
  }

  .articles__card h3 {
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1.4;
    letter-spacing: -0.01em;
  }

  .articles__card h3 a {
    color: var(--color-text);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .articles__card h3 a:hover { color: var(--color-forest); }

  .articles__card p {
    font-size: 0.9375rem;
    color: var(--color-text-light);
    line-height: 1.65;
    margin-top: 0.5rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }

  .articles__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-top: auto;
    padding-top: 1rem;
  }

  .tag {
    font-size: 0.75rem;
    color: var(--color-text-light);
    background: rgba(141, 155, 142, 0.05);
    padding: 0.1875rem 0.625rem;
    border-radius: 6px;
  }

  @media (max-width: 1023px) {
    .articles__grid { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 639px) {
    .articles { padding: 4rem 0; }
    .articles__grid { grid-template-columns: 1fr; }
  }
</style>
