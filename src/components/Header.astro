---
import { useTranslations, getAlternateLang, localePath } from '../i18n/utils';
import { languages, type Lang } from '../i18n/ui';

interface Props {
  lang?: Lang;
}
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
const altLang = getAlternateLang(lang);

// Build alternate URL by swapping locale prefix
const currentPath = Astro.url.pathname;
const altPath = currentPath.replace(`/${lang}/`, `/${altLang}/`) || `/${altLang}/`;
---

<div class="app-banner">
  <div class="container app-banner-inner">
    <span>{lang === 'zh' ? '🌱 BloomPath App 已上架！追蹤寶貝 224 項發展里程碑' : '🌱 BloomPath App is live! Track 224 developmental milestones'}</span>
    <a href="https://bloompath.quakr.dev" target="_blank" class="app-banner-cta">{lang === 'zh' ? '免費下載' : 'Download Free'}</a>
  </div>
</div>
<header class="site-header">
  <div class="container header-inner">
    <a href={localePath('/', lang)} class="logo" aria-label="BloomPath Home">
      <img src="/logo-nav.png" alt="" width="32" height="32" class="logo-img" />
      <span class="logo-text">{lang === 'zh' ? '育見未來' : 'BloomPath'}</span>
    </a>

    <nav class="main-nav" aria-label="Main navigation">
      <a href={localePath('/blog', lang)}>{t('nav.articles')}</a>
      <a href={`${localePath('/', lang)}#categories`}>{t('nav.topics')}</a>
      <a href={localePath('/tools/milestone-checker', lang)}>{t('nav.tools')}</a>
      <a href={`${localePath('/', lang)}#about`}>{t('nav.about')}</a>
      <a href={altPath} class="lang-switch" aria-label={`Switch to ${languages[altLang]}`}>{languages[altLang]}</a>
    </nav>

    <div class="header-right">
      <a href={altPath} class="lang-switch-mobile" aria-label={`Switch to ${languages[altLang]}`}>
        {altLang === 'zh' ? '中' : 'EN'}
      </a>
      <button class="mobile-toggle" aria-label="Toggle menu" aria-expanded="false">
        <span class="toggle-bar"></span>
        <span class="toggle-bar"></span>
        <span class="toggle-bar"></span>
      </button>
    </div>
  </div>
</header>

<style>
  .app-banner {
    background: var(--color-forest, #8D9B8E);
    color: white;
    font-size: 0.85rem;
    padding: 0.5rem 0;
  }
  .app-banner-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .app-banner-cta {
    background: white;
    color: var(--color-forest, #8D9B8E);
    padding: 0.25rem 0.75rem;
    border-radius: 6px;
    font-weight: 700;
    font-size: 0.8rem;
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .app-banner-cta:hover { opacity: 0.9; }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 40;
    background: rgba(250, 248, 245, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(141, 155, 142, 0.08);
    padding: 0.875rem 0;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    text-decoration: none;
    color: var(--color-text);
  }

  .logo:hover { color: var(--color-forest); }

  .logo-img {
    width: 32px;
    height: 32px;
    object-fit: contain;
    border-radius: 6px;
  }

  .logo-text {
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .main-nav {
    display: none;
    gap: 2rem;
  }

  .main-nav a {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-text-light);
    text-decoration: none;
    position: relative;
    padding: 0.25rem 0;
  }

  .main-nav a::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--color-forest);
    border-radius: 1px;
    transition: width 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .main-nav a:hover { color: var(--color-forest); }
  .main-nav a:hover::after { width: 100%; }

  .lang-switch {
    font-size: 0.8125rem;
    font-weight: 600;
    padding: 0.25rem 0.75rem;
    border-radius: 6px;
    background: rgba(141, 155, 142, 0.08);
    color: var(--color-forest);
    transition: all 0.2s ease;
  }

  .lang-switch:hover {
    background: var(--color-forest);
    color: var(--color-white);
  }

  .lang-switch::after { display: none; }

  .header-right {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .lang-switch-mobile {
    font-size: 0.8125rem;
    font-weight: 600;
    padding: 0.25rem 0.625rem;
    border-radius: 6px;
    background: rgba(141, 155, 142, 0.08);
    color: var(--color-forest);
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .lang-switch-mobile:hover {
    background: var(--color-forest);
    color: var(--color-white);
  }

  .mobile-toggle {
    display: flex;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    padding: 4px;
    cursor: pointer;
  }

  .toggle-bar {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--color-text);
    border-radius: 1px;
    transition: all 0.25s ease;
  }

  @media (min-width: 768px) {
    .main-nav { display: flex; }
    .mobile-toggle { display: none; }
    .lang-switch-mobile { display: none; }
  }
</style>

<script>
  const toggle = document.querySelector('.mobile-toggle');
  const nav = document.querySelector('.main-nav');
  if (toggle && nav) {
    toggle.addEventListener('click', () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!expanded));
      (nav as HTMLElement).style.display = expanded ? 'none' : 'flex';
      if (!expanded) {
        (nav as HTMLElement).style.flexDirection = 'column';
        (nav as HTMLElement).style.position = 'absolute';
        (nav as HTMLElement).style.top = '100%';
        (nav as HTMLElement).style.left = '0';
        (nav as HTMLElement).style.right = '0';
        (nav as HTMLElement).style.background = 'rgba(250, 248, 245, 0.98)';
        (nav as HTMLElement).style.padding = '1rem 1.5rem';
        (nav as HTMLElement).style.borderBottom = '1px solid rgba(141, 155, 142, 0.08)';
        (nav as HTMLElement).style.gap = '0.75rem';
      }
    });
  }
</script>
