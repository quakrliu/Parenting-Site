---
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: 'en' | 'zh';
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const topics = [
  {
    key: 'montessori',
    color: 'forest',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>`,
  },
  {
    key: 'positive',
    color: 'orange',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>`,
  },
  {
    key: 'milestones',
    color: 'pink',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,
  },
  {
    key: 'home',
    color: 'forest',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
  },
  {
    key: 'school',
    color: 'orange',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>`,
  },
  {
    key: 'teen',
    color: 'pink',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>`,
  },
];
---

<section class="topics">
  <div class="container">
    <div class="section-header section-header--center">
      <span class="eyebrow">{t('section.topics')}</span>
      <h2>{t('section.topics.title')}</h2>
      <p class="section-desc section-desc--center">{t('section.topics.desc')}</p>
    </div>
    <div class="topics__grid">
      {topics.map((topic) => (
        <a href={`/${lang}/blog`} class={`topics__card topics__card--${topic.color}`}>
          <div class={`topics__icon topics__icon--${topic.color}`} set:html={topic.icon} />
          <h3 class="topics__name">{t(`cat.${topic.key}` as any)}</h3>
          <p class="topics__desc">{t(`cat.${topic.key}.desc` as any)}</p>
          <span class="topics__link">
            {lang === 'en' ? 'Explore' : '探索'}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .topics {
    padding: 7rem 0;
    background: var(--color-cream);
  }

  .topics__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .topics__card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 2rem 1.75rem 1.75rem;
    background: var(--color-white);
    border-radius: 20px;
    border: 1px solid rgba(141, 155, 142, 0.06);
    text-decoration: none;
    transition: all 0.35s cubic-bezier(0.32, 0.72, 0, 1);
  }

  .topics__card:hover {
    transform: translateY(-3px);
    box-shadow: 0 20px 48px -16px rgba(74, 69, 67, 0.1);
  }

  .topics__card--forest { border-top: 3px solid var(--color-forest); }
  .topics__card--orange { border-top: 3px solid var(--color-orange); }
  .topics__card--pink { border-top: 3px solid var(--color-pink, #C8A8A2); }

  .topics__icon {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .topics__icon--forest { background: rgba(141, 155, 142, 0.08); color: var(--color-forest); }
  .topics__icon--orange { background: rgba(196, 168, 130, 0.1); color: var(--color-orange-dark); }
  .topics__icon--pink { background: rgba(200, 168, 162, 0.1); color: #8B6E69; }

  .topics__name {
    font-size: 1.0625rem;
    font-weight: 700;
    letter-spacing: -0.015em;
    color: var(--color-text);
    line-height: 1.3;
  }

  .topics__desc {
    font-size: 0.875rem;
    color: var(--color-text-light);
    line-height: 1.65;
    flex: 1;
  }

  .topics__link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-forest);
    margin-top: 0.5rem;
    transition: gap 0.2s ease;
  }

  .topics__card:hover .topics__link { gap: 0.625rem; }

  @media (max-width: 1023px) {
    .topics__grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 639px) {
    .topics { padding: 4rem 0; }
    .topics__grid { grid-template-columns: 1fr; }
  }

  @media (prefers-reduced-motion: no-preference) {
    .topics__card {
      opacity: 0;
      transform: translateY(20px);
      animation: fade-up 0.6s cubic-bezier(0.32, 0.72, 0, 1) forwards;
    }
    .topics__card:nth-child(1) { animation-delay: 0.05s; }
    .topics__card:nth-child(2) { animation-delay: 0.1s; }
    .topics__card:nth-child(3) { animation-delay: 0.15s; }
    .topics__card:nth-child(4) { animation-delay: 0.2s; }
    .topics__card:nth-child(5) { animation-delay: 0.25s; }
    .topics__card:nth-child(6) { animation-delay: 0.3s; }
    @keyframes fade-up {
      to { opacity: 1; transform: translateY(0); }
    }
  }
</style>
