---
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: 'en' | 'zh';
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const windows = [
  {
    key: 'language',
    color: 'forest',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
  },
  {
    key: 'movement',
    color: 'orange',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="5" r="2"/><path d="M12 7v6"/><path d="M8.5 11.5 12 13l3.5-1.5"/><path d="M8 21l4-8 4 8"/></svg>`,
  },
  {
    key: 'order',
    color: 'pink',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>`,
  },
  {
    key: 'social',
    color: 'forest',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
  },
  {
    key: 'school',
    color: 'orange',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>`,
  },
  {
    key: 'teen',
    color: 'pink',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>`,
  },
];
---

<section class="dev-windows">
  <div class="container">
    <div class="section-header section-header--center">
      <span class="eyebrow">{t('section.windows')}</span>
      <h2>{t('section.windows.title')}</h2>
      <p class="section-desc section-desc--center">{t('section.windows.desc')}</p>
    </div>
    <div class="dev-windows__grid">
      {windows.map((w) => (
        <div class={`dev-windows__card dev-windows__card--${w.color}`}>
          <div class={`dev-windows__icon dev-windows__icon--${w.color}`} set:html={w.icon} />
          <div class="dev-windows__body">
            <div class="dev-windows__meta">
              <h3>{t(`windows.${w.key}.title` as any)}</h3>
              <span class="dev-windows__age">{t(`windows.${w.key}.age` as any)}</span>
            </div>
            <p>{t(`windows.${w.key}.desc` as any)}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .dev-windows {
    padding: 7rem 0;
  }

  .dev-windows__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  .dev-windows__card {
    display: flex;
    gap: 1.25rem;
    padding: 1.75rem;
    background: var(--color-white);
    border-radius: 18px;
    border: 1px solid rgba(141, 155, 142, 0.06);
    border-left: 3px solid transparent;
    transition: all 0.3s cubic-bezier(0.32, 0.72, 0, 1);
    align-items: flex-start;
  }

  .dev-windows__card:hover {
    box-shadow: 0 12px 36px -12px rgba(74, 69, 67, 0.08);
    transform: translateY(-2px);
  }

  .dev-windows__card--forest { border-left-color: var(--color-forest); }
  .dev-windows__card--orange { border-left-color: var(--color-orange); }
  .dev-windows__card--pink { border-left-color: var(--color-pink, #C8A8A2); }

  .dev-windows__icon {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .dev-windows__icon--forest { background: rgba(141, 155, 142, 0.08); color: var(--color-forest); }
  .dev-windows__icon--orange { background: rgba(196, 168, 130, 0.1); color: var(--color-orange-dark); }
  .dev-windows__icon--pink { background: rgba(200, 168, 162, 0.1); color: #8B6E69; }

  .dev-windows__body {
    flex: 1;
    min-width: 0;
  }

  .dev-windows__meta {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 0.5rem;
  }

  .dev-windows__meta h3 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: -0.01em;
    margin: 0;
  }

  .dev-windows__age {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-text-light);
    background: rgba(141, 155, 142, 0.07);
    padding: 0.125rem 0.625rem;
    border-radius: 999px;
    white-space: nowrap;
  }

  .dev-windows__body p {
    font-size: 0.875rem;
    color: var(--color-text-light);
    line-height: 1.65;
    margin: 0;
  }

  @media (max-width: 1023px) {
    .dev-windows__grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 639px) {
    .dev-windows { padding: 4rem 0; }
  }

  @media (prefers-reduced-motion: no-preference) {
    .dev-windows__card {
      opacity: 0;
      transform: translateY(16px);
      animation: fade-up 0.5s cubic-bezier(0.32, 0.72, 0, 1) forwards;
    }
    .dev-windows__card:nth-child(1) { animation-delay: 0.05s; }
    .dev-windows__card:nth-child(2) { animation-delay: 0.1s; }
    .dev-windows__card:nth-child(3) { animation-delay: 0.15s; }
    .dev-windows__card:nth-child(4) { animation-delay: 0.2s; }
    .dev-windows__card:nth-child(5) { animation-delay: 0.25s; }
    .dev-windows__card:nth-child(6) { animation-delay: 0.3s; }
    @keyframes fade-up {
      to { opacity: 1; transform: translateY(0); }
    }
  }
</style>
