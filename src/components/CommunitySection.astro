---
interface Props {
  lang: 'en' | 'zh';
}

const { lang } = Astro.props;

const content = {
  en: {
    eyebrow: 'Community',
    title: 'You\'re Not Parenting Alone',
    desc: 'Join parents sharing real experiences, asking real questions, and supporting each other — no judgment, no perfect Instagram lives.',
    cta: 'Join the Community',
    features: [
      { icon: '💬', title: 'Ask Anything', desc: 'No question is too small. Sleep struggles, picky eating, meltdowns — we\'ve all been there.' },
      { icon: '🤝', title: 'Share Your Wins', desc: 'First steps, first words, first time they said "I love you" unprompted. Celebrate together.' },
      { icon: '📚', title: 'Learn Together', desc: 'Montessori tips, positive parenting strategies, age-specific advice from parents who get it.' },
    ],
  },
  zh: {
    eyebrow: '家長社群',
    title: '育兒路上，你不孤單',
    desc: '加入正在分享真實經驗、互相支持的爸媽社群 — 沒有批判，沒有完美人設。',
    cta: '加入社群',
    features: [
      { icon: '💬', title: '什麼都能問', desc: '沒有笨問題。睡不好、挑食、崩潰 — 我們都經歷過。' },
      { icon: '🤝', title: '分享你的小確幸', desc: '第一步、第一句話、第一次主動說愛你。一起慶祝。' },
      { icon: '📚', title: '一起學習', desc: '蒙特梭利技巧、正向教養策略、過來人的年齡建議。' },
    ],
  },
};

const c = content[lang];
---

<section class="community">
  <div class="container">
    <div class="community__inner">
      <div class="community__content">
        <span class="eyebrow">{c.eyebrow}</span>
        <h2>{c.title}</h2>
        <p class="community__desc">{c.desc}</p>
        <div class="community__features">
          {c.features.map((f) => (
            <div class="community__feature">
              <span class="community__feature-icon">{f.icon}</span>
              <div>
                <strong>{f.title}</strong>
                <p>{f.desc}</p>
              </div>
            </div>
          ))}
        </div>
        <a href="https://discord.gg/INVITE_LINK_HERE" target="_blank" rel="noopener noreferrer" class="btn btn--primary btn--lg community__cta">
          {c.cta}
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .community {
    padding: 7rem 0;
    background: var(--color-cream);
  }

  .community__inner {
    max-width: 680px;
    margin: 0 auto;
    text-align: center;
  }

  .community h2 {
    font-size: 2.5rem;
    font-weight: 800;
    letter-spacing: -0.035em;
    line-height: 1.1;
    color: var(--color-text);
  }

  .community__desc {
    font-size: 1.0625rem;
    color: var(--color-text-light);
    line-height: 1.7;
    margin-top: 1rem;
    max-width: 52ch;
    margin-inline: auto;
  }

  .community__features {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-top: 2.5rem;
    text-align: left;
  }

  .community__feature {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    background: var(--color-white);
    border-radius: 16px;
    padding: 1.25rem 1.5rem;
    border: 1px solid rgba(141, 155, 142, 0.06);
  }

  .community__feature-icon {
    font-size: 1.5rem;
    line-height: 1;
    flex-shrink: 0;
    margin-top: 0.125rem;
  }

  .community__feature strong {
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--color-text);
    display: block;
    margin-bottom: 0.25rem;
  }

  .community__feature p {
    font-size: 0.875rem;
    color: var(--color-text-light);
    line-height: 1.6;
    margin: 0;
  }

  .community__cta {
    margin-top: 2.5rem;
    display: inline-flex;
  }

  @media (max-width: 639px) {
    .community { padding: 4rem 0; }
    .community h2 { font-size: 2rem; }
  }
</style>
