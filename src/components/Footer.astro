---
import { useTranslations, localePath } from '../i18n/utils';
import type { Lang } from '../i18n/ui';

interface Props {
  lang?: Lang;
}
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <span class="footer-logo">{lang === 'zh' ? '育見未來' : 'BloomPath'}</span>
      <p class="footer-tagline">{t('footer.tagline')}</p>
    </div>

    <div class="footer-links">
      <div class="footer-col">
        <h4>{t('footer.explore')}</h4>
        <a href={localePath('/blog', lang)}>{t('footer.allArticles')}</a>
        <a href={`${localePath('/', lang)}#categories`}>{t('footer.topics')}</a>
        <a href={`${localePath('/', lang)}#tools`}>{t('footer.freeTools')}</a>
      </div>
      <div class="footer-col">
        <h4>{t('footer.connect')}</h4>
        <a href={`${localePath('/', lang)}#newsletter`}>{t('footer.newsletter')}</a>
        <a href={`${localePath('/', lang)}#about`}>{t('footer.aboutUs')}</a>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {year} {t('footer.copyright')}</p>
      <p class="footer-disclaimer">{t('footer.disclaimer')}</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-forest-dark);
    color: rgba(255, 255, 255, 0.85);
    padding: 4rem 0 2rem;
    margin-top: 6rem;
  }

  .footer-inner { display: grid; gap: 3rem; }

  .footer-logo {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-white);
    letter-spacing: -0.02em;
  }

  .footer-tagline {
    margin-top: 0.5rem;
    font-size: 0.9375rem;
    line-height: 1.6;
    max-width: 32ch;
    color: rgba(255, 255, 255, 0.65);
  }

  .footer-links {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  .footer-col h4 {
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 0.75rem;
  }

  .footer-col { display: flex; flex-direction: column; gap: 0.5rem; }

  .footer-col a {
    font-size: 0.9375rem;
    color: rgba(255, 255, 255, 0.75);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-col a:hover { color: var(--color-orange); }

  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: 1.5rem;
  }

  .footer-bottom p {
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.45);
    line-height: 1.6;
  }

  .footer-disclaimer { margin-top: 0.5rem; font-size: 0.75rem !important; }

  @media (min-width: 768px) {
    .footer-inner { grid-template-columns: 1fr 1fr; }
    .footer-bottom { grid-column: 1 / -1; }
  }
</style>
