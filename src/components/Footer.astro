---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <span class="footer-logo">BloomPath</span>
      <p class="footer-tagline">Research-backed guidance for the journey of parenthood.</p>
    </div>

    <div class="footer-links">
      <div class="footer-col">
        <h4>Explore</h4>
        <a href="/blog">All Articles</a>
        <a href="/#categories">Topics</a>
        <a href="/#tools">Free Tools</a>
      </div>
      <div class="footer-col">
        <h4>Connect</h4>
        <a href="/#newsletter">Newsletter</a>
        <a href="/#about">About Us</a>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {year} BloomPath. Built with care by parents, for parents.</p>
      <p class="footer-disclaimer">Content is for informational purposes only. Not medical or professional advice. Consult qualified professionals for your family's specific needs.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-forest-dark);
    color: rgba(255, 255, 255, 0.85);
    padding: 4rem 0 2rem;
    margin-top: 6rem;
  }

  .footer-inner {
    display: grid;
    gap: 3rem;
  }

  .footer-logo {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-white);
    letter-spacing: -0.02em;
  }

  .footer-tagline {
    margin-top: 0.5rem;
    font-size: 0.9375rem;
    line-height: 1.6;
    max-width: 32ch;
    color: rgba(255, 255, 255, 0.65);
  }

  .footer-links {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  .footer-col h4 {
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 0.75rem;
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-col a {
    font-size: 0.9375rem;
    color: rgba(255, 255, 255, 0.75);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-col a:hover {
    color: var(--color-orange);
  }

  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: 1.5rem;
  }

  .footer-bottom p {
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.45);
    line-height: 1.6;
  }

  .footer-disclaimer {
    margin-top: 0.5rem;
    font-size: 0.75rem !important;
  }

  @media (min-width: 768px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;
    }

    .footer-bottom {
      grid-column: 1 / -1;
    }
  }
</style>
