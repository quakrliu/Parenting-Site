---
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: 'en' | 'zh';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="newsletter" class="newsletter">
  <div class="container">
    <div class="newsletter__inner">
      <div class="newsletter__content">
        <span class="eyebrow eyebrow--light">{t('section.newsletter')}</span>
        <h2>{t('section.newsletter.title')}</h2>
        <p>{t('section.newsletter.desc')}</p>
      </div>
      <div class="newsletter__form">
        <p class="newsletter__placeholder">{t('section.newsletter.placeholder')}</p>
      </div>
    </div>
  </div>
</section>

<style>
  .newsletter {
    padding: 6rem 0;
    background: var(--color-forest-dark);
    color: var(--color-white);
  }

  .newsletter__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .newsletter h2 {
    color: var(--color-white);
    font-size: 2.25rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.15;
  }

  .newsletter__content p {
    color: rgba(255, 255, 255, 0.7);
    font-size: 1rem;
    line-height: 1.7;
    margin-top: 0.75rem;
    max-width: 45ch;
  }

  .newsletter__placeholder {
    background: rgba(255, 255, 255, 0.06);
    border: 1px dashed rgba(255, 255, 255, 0.15);
    border-radius: 16px;
    padding: 2.5rem 2rem;
    text-align: center;
    color: rgba(255, 255, 255, 0.45);
    font-size: 0.9375rem;
  }

  @media (max-width: 1023px) {
    .newsletter__inner { grid-template-columns: 1fr; }
  }

  @media (max-width: 639px) {
    .newsletter { padding: 3.5rem 0; }
  }
</style>
